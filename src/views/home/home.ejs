          +   '</div>'
          +   '<span class=\"text-sm font-semibold text-gray-800 text-center leading-tight\">' + (cat.name || '') + '</span>'
          + '</a>';
      }).join('');
    }

    function renderFeaturedProductsClient(products) {
      if (!Array.isArray(products)) return '';
      return products.map(function(product) {
        const productHref = '/products/' + (product.slug || product.id || '');
        const image = product.image || product.thumbnail || product.featured_image || '';
        const title = product.product_name || product.name || product.title || 'Product';
        const unitPrice = Number(product.unit_price || product.price || product.sale_price || product.base_price || 0);
        const discountValue = Number(product.discount || 0);
        const discountType = product.discount_type || '';
        const hasDiscount = discountValue > 0;
        let finalPrice = unitPrice;
        let discountLabel = '';

        if (hasDiscount) {
          if (discountType === 'percent') {
            finalPrice = unitPrice - ((unitPrice * discountValue) / 100);
            discountLabel = '-' + discountValue + '%';
          } else {
            finalPrice = Math.max(unitPrice - discountValue, 0);
            discountLabel = '-&#8377;' + discountValue;
          }
        }

        const oldPrice = hasDiscount ? unitPrice.toFixed(2) : '';
        const price = Number.isFinite(finalPrice) ? finalPrice.toFixed(2) : Number.isFinite(unitPrice) ? unitPrice.toFixed(2) : '--';
        const discount = product.discount_label || discountLabel;
        const discountDisplay = discount ? (discountType === 'percent' ? 'Percent' : 'Flat') + '-' + discount.replace(/^-/, '') : '';

        return ''
          + '<a href="' + productHref + '" class="featured-card min-w-[195px] max-w-[195px] flex-shrink-0 rounded-3xl bg-white p-2.5 transition-transform duration-200 hover:-translate-y-1">'
