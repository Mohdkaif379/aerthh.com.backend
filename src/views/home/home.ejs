          ? (discountType === 'percent'
            ? unitPrice - ((unitPrice * discountValue) / 100)
            : Math.max(unitPrice - discountValue, 0))
          : unitPrice;
        const discountLabel = hasDiscount
          ? (discountType === 'percent' ? '-' + discountValue + '%' : '-&#8377;' + discountValue)
          : '';
        const discountDisplay = hasDiscount ? (discountType === 'percent' ? 'Percent' : 'Flat') + '-' + discountLabel.replace(/^-/, '') : '';

        recommendedCard.innerHTML = ''
          + '<div class="rounded-[0.8rem] bg-[linear-gradient(180deg,#f8fcff_0%,#eef7ff_100%)] p-2.5 ring-1 ring-sky-100">'
          + '<div class="relative overflow-hidden rounded-[0.6rem] border border-sky-100 bg-sky-50/70">'
          + (discountDisplay ? '<span class="absolute left-3 top-3 z-10 rounded-md bg-sky-500 px-2.5 py-1.5 text-[11px] font-bold text-white">' + discountDisplay + '</span>' : '')
          + '<img src="' + image + '" alt="' + title + '" class="h-[170px] sm:h-[185px] w-full object-contain">'
          + '</div>'
          + '<div class="pt-2 text-center">'
          + '<h3 class="truncate text-[14px] font-medium uppercase tracking-[0.02em] text-[#0f172a]">' + title + '</h3>'
          + '<div class="mt-1.5 flex items-end justify-center gap-2">'
          + (hasDiscount ? '<span class="text-[12px] text-gray-400 line-through">&#8377;' + unitPrice.toFixed(2) + '</span>' : '')
          + '<span class="text-[16px] font-bold text-[#334155]">&#8377;' + finalPrice.toFixed(2) + '</span>'
          + '</div>'
          + '<a href="/products/buy?id=' + (product.id || '') + '" class="mt-3 inline-flex items-center justify-center rounded-[0.8rem] bg-gradient-to-r from-sky-500 to-blue-500 px-6 py-2 text-[11px] font-bold uppercase tracking-[0.04em] text-white transition hover:from-sky-600 hover:to-blue-600">Buy Now</a>'
          + '</div>'
          + '</div>';
      }
      // Client-only base URL for APIs
      const apiBaseClient = 'https://aerthh.newhopeindia17.com/api/';

      async function loadCategories() {
        if (!catTrack || !apiBaseClient) return;
        const endpoint = apiBaseClient + "categories";
        try {
          const resp = await fetch(endpoint);
          if (!resp.ok) throw new Error('HTTP ' + resp.status);
          const data = await resp.json();
          const list = Array.isArray(data.data) ? data.data : [];
          catTrack.innerHTML = renderCategoriesClient(list);
        } catch (err) {
          console.error('Failed to load categories:', err.message || err);
          catTrack.innerHTML = '<div class="text-sm text-gray-500">Categories unavailable</div>';
        }
