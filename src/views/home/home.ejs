        +         '<i class="fas fa-share-alt text-sm"></i>'
        +       '</button>'
        +       '<img src="' + image + '" alt="' + title + '" class="h-[250px] w-full object-contain">'
        +       '</div>'
        +     '</div>'
        +     additionalImagesHtml
        +   '</div>'
        +   '<div class="rounded-[0.35rem] border border-[#dce8ff] bg-white p-3.5 md:p-4">'
        +     '<h4 class="text-[17px] font-medium text-slate-900">' + title + '</h4>'
        +     '<div class="mt-3 flex items-end gap-2">'
        +       (discountValue > 0 ? '<span class="text-[13px] text-slate-400 line-through">' + formatMoney(unitPrice) + '</span>' : '')
        +       '<span class="text-[24px] font-bold text-slate-700">' + formatMoney(finalPrice) + '</span>'
        +     '</div>'
        +     (discountDisplay ? '<p class="mt-1.5 text-[12px] font-semibold text-emerald-600">Discount: ' + discountDisplay + '</p>' : '')
        +     '<div class="mt-5 flex items-center gap-3">'
        +       '<span class="text-[14px] font-semibold text-slate-700">Quantity :</span>'
        +       '<div class="flex items-center overflow-hidden rounded-[0.35rem] border border-cyan-300">'
        +         '<button type="button" class="latest-product-qty-btn flex h-[34px] w-[34px] items-center justify-center text-[17px] text-cyan-700" data-direction="decrement">-</button>'
        +         '<div id="latestProductQtyValue" class="flex h-[34px] min-w-[52px] items-center justify-center border-x border-cyan-300 text-[16px] text-[#4b5563]">1</div>'
        +         '<button type="button" class="latest-product-qty-btn flex h-[34px] w-[34px] items-center justify-center text-[17px] text-cyan-700" data-direction="increment">+</button>'
        +       '</div>'
        +     '</div>'
        +     '<div class="mt-4 text-[13px] font-semibold text-slate-700">Total Price : <span id="latestProductTotalPrice" class="text-[13px] font-bold text-slate-800">' + formatMoney(finalPrice) + '</span></div>'
        +     '<div class="mt-4 flex flex-wrap items-center gap-2.5">'
        +       '<a href="/products/' + (product.slug || product.id || '') + '" class="inline-flex items-center justify-center rounded-[0.45rem] bg-gradient-to-r from-emerald-500 to-cyan-500 px-5 py-2.5 text-[12px] font-semibold text-white transition hover:from-emerald-600 hover:to-cyan-600">Buy now</a>'
        +       '<a href="/products/' + (product.slug || product.id || '') + '" class="inline-flex items-center justify-center rounded-[0.45rem] bg-slate-700 px-5 py-2.5 text-[12px] font-semibold text-white transition hover:bg-slate-800">Add to cart</a>'
        +       '<button type="button" class="inline-flex h-[40px] min-w-[70px] items-center justify-center gap-2 rounded-[0.45rem] border border-slate-200 bg-white px-3 text-[12px] text-slate-500 transition hover:border-slate-300 hover:text-slate-700"><i class="far fa-heart"></i><span>0</span></button>'
        +     '</div>'
        +     '<hr class="my-4 border-slate-200">'
        +     '<div>'
