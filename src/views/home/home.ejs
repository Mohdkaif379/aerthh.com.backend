      if (!Array.isArray(cats)) return '';
      return cats.map(function(cat) {
        const targetHref = '/category/' + (cat.id || '');
        return ''
          + '<a href=\"' + targetHref + '\" class=\"cat-card min-w-[120px] flex-shrink-0 flex flex-col items-center gap-2  rounded-2xl p-6  transition-transform outline-none\">'
          +   '<div class=\"w-20 h-20 md:w-24 md:h-24 rounded-full  flex items-center justify-center overflow-hidden ring-2 ring-white/50\">'
