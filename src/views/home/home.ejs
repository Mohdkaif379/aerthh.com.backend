        return date.toLocaleDateString('en-IN', {
          day: 'numeric',
          month: 'short',
          year: 'numeric'
        });
      }

      function renderHomeReviewCard(review) {
        const customerFirst = String(review?.customer?.first_name || '').trim();
        const customerLast = String(review?.customer?.last_name || '').trim();
        const reviewerName = (customerFirst || customerLast)
          ? [customerFirst, customerLast].filter(Boolean).join(' ')
          : (review?.customer_id ? 'Customer #' + String(review.customer_id) : 'Customer');
        const customerInitial = (reviewerName.charAt(0) || 'C').toUpperCase();
        const customerImage = String(review?.customer?.profile_image || review?.customer?.image || '').trim();
        const reviewText = String(review?.comment || review?.review || review?.description || '').trim();
        const reviewDate = formatReviewDate(review?.created_at || review?.updated_at);

        return ''
          + '<article class="snap-start shrink-0 basis-full rounded-[1rem] border border-sky-100 bg-white p-4 sm:basis-[calc(50%-0.5rem)] xl:basis-[calc(33.333%-0.95rem)]">'
          + '<div class="flex items-center gap-3">'
          + (customerImage
            ? '<img src="' + customerImage + '" alt="' + escapeReviewHtml(reviewerName) + '" class="h-12 w-12 shrink-0 rounded-full object-cover ring-2 ring-sky-100">'
            : '<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-sky-500 to-blue-500 text-sm font-bold text-white ring-2 ring-sky-100">' + escapeReviewHtml(customerInitial) + '</div>')
          + '<div class="min-w-0 flex-1">'
          + '<p class="truncate text-sm font-semibold text-slate-900">' + escapeReviewHtml(reviewerName) + '</p>'
          + '<div class="mt-1 flex items-center gap-1">' + renderHomeReviewStars(review?.rating || review?.stars || review?.score) + '</div>'
          + '</div>'
          + '</div>'
          + '<p class="mt-3 text-sm leading-6 text-slate-600">' + escapeReviewHtml(reviewText || 'Review unavailable') + '</p>'
          + (reviewDate ? '<p class="mt-3 text-[11px] font-medium text-slate-400">' + escapeReviewHtml(reviewDate) + '</p>' : '')
          + '</article>';
      }

      function renderHomeReviews(reviews) {
        if (!homeReviewsTrack) return;
        if (!Array.isArray(reviews) || !reviews.length) {
          homeReviewsTrack.innerHTML = '<div class="flex min-w-full items-center justify-center rounded-[1rem] border border-dashed border-sky-200 bg-white px-5 py-10 text-sm text-slate-500">No reviews available right now.</div>';
          return;
        }
        homeReviewsTrack.innerHTML = reviews.slice(0, 12).map(renderHomeReviewCard).join('');
      }

      async function loadHomeReviews() {
        if (!homeReviewsTrack) return;
        try {
          const response = await fetch(reviewsApiEndpoint, {
            headers: { 'Accept': 'application/json' }
          });
          const result = await response.json();
          const reviews = Array.isArray(result?.data) ? result.data : [];
          renderHomeReviews(reviews);
          startHomeReviewsAutoScroll();
        } catch (error) {
          console.error('Failed to load home reviews:', error);
          homeReviewsTrack.innerHTML = '<div class="flex min-w-full items-center justify-center rounded-[1rem] border border-dashed border-rose-200 bg-white px-5 py-10 text-sm text-rose-600">Unable to load reviews.</div>';
        }
      }

      function scrollHomeReviews(direction) {
        if (!homeReviewsTrack) return;
        const amount = Math.max(320, Math.floor(homeReviewsTrack.clientWidth * 0.85));
        const maxScrollLeft = homeReviewsTrack.scrollWidth - homeReviewsTrack.clientWidth;
        if (direction > 0 && homeReviewsTrack.scrollLeft >= maxScrollLeft - 8) {
          homeReviewsTrack.scrollTo({ left: 0, behavior: 'smooth' });
          return;
        }
        homeReviewsTrack.scrollBy({ left: amount * direction, behavior: 'smooth' });
      }

      function startHomeReviewsAutoScroll() {
        if (!homeReviewsTrack) return;
        if (homeReviewsAutoScrollInterval) {
          clearInterval(homeReviewsAutoScrollInterval);
        }
        homeReviewsAutoScrollInterval = setInterval(function () {
          scrollHomeReviews(1);
        }, 4500);
      }

      if (homeReviewsPrevBtn) {
        homeReviewsPrevBtn.addEventListener('click', function () {
          scrollHomeReviews(-1);
          startHomeReviewsAutoScroll();
        });
      }

      if (homeReviewsNextBtn) {
        homeReviewsNextBtn.addEventListener('click', function () {
          scrollHomeReviews(1);
          startHomeReviewsAutoScroll();
        });
      }

      function renderReviewStars(value) {
        const rating = Math.max(0, Math.min(5, Number(value || 0)));
        if (!rating) return '';
        return '&#9733;'.repeat(Math.round(rating)) + '&#9734;'.repeat(5 - Math.round(rating));
      }

