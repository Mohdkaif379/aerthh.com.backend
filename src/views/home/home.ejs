  <script>
    (function () {
      const termsStorageKey = 'home_terms_policy_accepted';
      let currentSlide = 0;
      const slides = document.querySelectorAll('.carousel-slide');
      const dots = document.querySelectorAll('.carousel-dot');
      let autoSlideInterval;
      

      function showSlide(index) {
        if (index < 0) index = slides.length - 1;
        if (index >= slides.length) index = 0;
        currentSlide = index;
        slides.forEach((slide, i) => {
          slide.classList.toggle('opacity-100', i === currentSlide);
          slide.classList.toggle('opacity-0', i !== currentSlide);
        });
        dots.forEach((dot, i) => {
          dot.classList.toggle('bg-white', i === currentSlide);
          dot.classList.toggle('bg-white/50', i !== currentSlide);
        });
      }

      function nextSlide() { showSlide(currentSlide + 1); resetAutoSlide(); }
      function resetAutoSlide() { clearInterval(autoSlideInterval); autoSlideInterval = setInterval(nextSlide, 5000); }

      dots.forEach((dot, i) => dot.addEventListener('click', () => { showSlide(i); resetAutoSlide(); }));
      autoSlideInterval = setInterval(nextSlide, 5000);
      const carousel = document.querySelector('.relative.w-full.overflow-hidden');
      if (carousel && window.matchMedia('(hover: hover)').matches) {
        carousel.addEventListener('mouseenter', () => clearInterval(autoSlideInterval));
        carousel.addEventListener('mouseleave', () => { autoSlideInterval = setInterval(nextSlide, 5000); });
      }

      // auto-scroll categories horizontally
      const catTrack = document.querySelector('.cat-track');
      const brandTrack = document.querySelector('.brand-track');
      const bestSellerTrack = document.querySelector('.best-seller-track');
      const topSellingTrack = document.querySelector('.top-selling-track');
      const featuredTrack = document.querySelector('.featured-track');
      const topDealsTrack = document.querySelector('.top-deals-track');
      const latestTrack = document.querySelector('.latest-track');
      const recommendedCard = document.querySelector('.recommended-product-card');
      const homeReviewsTrack = document.getElementById('homeReviewsTrack');
      const homeReviewsPrevBtn = document.getElementById('homeReviewsPrevBtn');
      const homeReviewsNextBtn = document.getElementById('homeReviewsNextBtn');
      const latestProductModal = document.getElementById('latestProductModal');
      const latestProductModalContent = document.getElementById('latestProductModalContent');
      const closeLatestProductModal = document.getElementById('closeLatestProductModal');
      const termsPolicyModal = document.getElementById('termsPolicyModal');
      const termsPolicyCheckbox = document.getElementById('termsPolicyCheckbox');
      const acceptTermsPolicyBtn = document.getElementById('acceptTermsPolicyBtn');
      const rejectTermsPolicyBtn = document.getElementById('rejectTermsPolicyBtn');
      const homeCartSuccessModal = document.getElementById('homeCartSuccessModal');
      const homeCartSuccessMessage = document.getElementById('homeCartSuccessMessage');
      const latestProductMap = new Map();
      const cartAddEndpoint = 'https://aerthh.newhopeindia17.com/api/cart/add';
      const reviewsApiEndpoint = 'https://aerthh.newhopeindia17.com/api/reviews';
      let homeReviewsAutoScrollInterval = null;

      function openTermsPolicyModal() {
        if (!termsPolicyModal) return;
        termsPolicyModal.classList.remove('hidden');
        termsPolicyModal.classList.add('flex');
        document.body.classList.add('overflow-hidden');
      }

      function closeTermsPolicyModal() {
        if (!termsPolicyModal) return;
        termsPolicyModal.classList.add('hidden');
        termsPolicyModal.classList.remove('flex');
        if (!latestProductModal || latestProductModal.classList.contains('hidden')) {
          document.body.classList.remove('overflow-hidden');
        }
      }

      function initTermsPolicyModal() {
        if (!termsPolicyModal) return;

        const isAccepted = window.localStorage.getItem(termsStorageKey) === 'true';
        if (!isAccepted) {
          openTermsPolicyModal();
        }

        if (acceptTermsPolicyBtn) {
          acceptTermsPolicyBtn.addEventListener('click', function () {
            if (!termsPolicyCheckbox || !termsPolicyCheckbox.checked) {
              if (termsPolicyCheckbox) {
                termsPolicyCheckbox.focus();
              }
              window.alert('Please accept Terms & Conditions to continue.');
              return;
            }

            window.localStorage.setItem(termsStorageKey, 'true');
            closeTermsPolicyModal();
          });
        }

        if (rejectTermsPolicyBtn) {
          rejectTermsPolicyBtn.addEventListener('click', function () {
            window.localStorage.removeItem(termsStorageKey);
            window.location.href = '/';
          });
        }
      }

      function openCartSuccessModal(message) {
        if (!homeCartSuccessModal || !homeCartSuccessMessage) return;
        homeCartSuccessMessage.textContent = message || 'Product added to cart successfully.';
        homeCartSuccessModal.classList.remove('hidden');
        homeCartSuccessModal.classList.add('flex');
        document.body.classList.add('overflow-hidden');
      }

      function closeCartSuccessModal() {
        if (!homeCartSuccessModal) return;
        homeCartSuccessModal.classList.add('hidden');
        homeCartSuccessModal.classList.remove('flex');
        if ((!latestProductModal || latestProductModal.classList.contains('hidden')) &&
            (!termsPolicyModal || termsPolicyModal.classList.contains('hidden'))) {
          document.body.classList.remove('overflow-hidden');
        }
      }

      function getCustomerAuth() {
        try {
          return {
            token: localStorage.getItem('customerToken') || '',
            tokenType: localStorage.getItem('tokenType') || 'Bearer'
          };
        } catch (error) {
          return { token: '', tokenType: 'Bearer' };
        }
      }

      function hasCustomerSession() {
        const auth = getCustomerAuth();
        return !!auth.token;
      }

      function clearClearedCartItem(productId) {
        try {
          const normalizedId = String(productId || '').trim();
          if (!normalizedId) return;
          const parsed = JSON.parse(localStorage.getItem('clearedCartItemIds') || '[]');
          if (!Array.isArray(parsed) || !parsed.length) return;
          const nextIds = parsed
            .map(function (value) { return String(value); })
            .filter(function (value) { return value !== normalizedId; });
          localStorage.setItem('clearedCartItemIds', JSON.stringify(nextIds));
        } catch (error) {
          console.warn('Unable to update cleared cart item ids:', error);
        }
      }

      async function addProductToCart(productId, quantity) {
        const auth = getCustomerAuth();
        if (!auth.token) {
          window.location.href = '/auth/customer/signin?redirect=' + encodeURIComponent('/products/buy?id=' + encodeURIComponent(String(productId || '')));
          return false;
        }

        const response = await fetch(cartAddEndpoint, {
          method: 'POST',
          headers: {
            'Accept': 'application/json',
            'Content-Type': 'application/json',
            'Authorization': (auth.tokenType || 'Bearer') + ' ' + auth.token
          },
          body: JSON.stringify({
            product_id: Number(productId),
            quantity: quantity
          })
        });

        const result = await response.json();

        if (!response.ok || !result?.status) {
          throw new Error(result?.message || 'Unable to add product to cart.');
        }

        clearClearedCartItem(productId);
        window.dispatchEvent(new CustomEvent('cart:updated'));
