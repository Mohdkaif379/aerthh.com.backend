      function openLatestProductModal(product) {
        if (!latestProductModal || !product) return;
        renderProductModal(product);
        latestProductModal.classList.remove('hidden');
        latestProductModal.classList.add('flex');
        document.body.classList.add('overflow-hidden');

        const qtyValueEl = document.getElementById('latestProductQtyValue');
        const totalPriceEl = document.getElementById('latestProductTotalPrice');
        const mainImageEl = document.getElementById('latestProductMainImage');
        const descriptionTabEl = document.getElementById('latestProductDescriptionTab');
        const reviewsTabEl = document.getElementById('latestProductReviewsTab');
        const title = product.product_name || product.name || 'Product';
        const unitPrice = Number(product.unit_price || product.price || 0);
        const discountValue = Number(product.discount || 0);
        const discountType = product.discount_type || '';
        const discountedPrice = discountValue > 0
          ? (discountType === 'percent'
            ? unitPrice - ((unitPrice * discountValue) / 100)
            : Math.max(unitPrice - discountValue, 0))
          : unitPrice;

        if (latestProductModalContent && qtyValueEl && totalPriceEl) {
          latestProductModalContent.querySelectorAll('.latest-product-qty-btn').forEach(function (button) {
            button.addEventListener('click', function () {
              const currentQty = Number(qtyValueEl.textContent || 1);
              const nextQty = this.dataset.direction === 'increment'
                ? currentQty + 1
                : Math.max(currentQty - 1, 1);

              qtyValueEl.textContent = String(nextQty);
              totalPriceEl.textContent = formatMoney(discountedPrice * nextQty);
            });
          });

          latestProductModalContent.querySelectorAll('.latest-product-thumb-btn').forEach(function (button) {
            button.addEventListener('click', function () {
              if (!mainImageEl) return;

              const nextImage = this.dataset.imageSrc || '';
              if (!nextImage) return;

              mainImageEl.src = nextImage;
              mainImageEl.alt = title + ' preview';

              latestProductModalContent.querySelectorAll('.latest-product-thumb-btn').forEach(function (thumb) {
                thumb.classList.remove('border-sky-500');
                thumb.classList.add('border-slate-200');
              });

              this.classList.remove('border-slate-200');
              this.classList.add('border-sky-500');
            });
          });

          latestProductModalContent.querySelectorAll('.latest-product-tab-btn').forEach(function (button) {
            button.addEventListener('click', function () {
              const selectedTab = this.dataset.tab || 'description';
              const isDescriptionTab = selectedTab === 'description';

              if (descriptionTabEl) {
                descriptionTabEl.classList.toggle('hidden', !isDescriptionTab);
              }

              if (reviewsTabEl) {
                reviewsTabEl.classList.toggle('hidden', isDescriptionTab);
              }

              latestProductModalContent.querySelectorAll('.latest-product-tab-btn').forEach(function (tabButton) {
                const isActive = tabButton.dataset.tab === selectedTab;
                tabButton.classList.toggle('border-sky-500', isActive);
                tabButton.classList.toggle('text-sky-600', isActive);
                tabButton.classList.toggle('border-transparent', !isActive);
                tabButton.classList.toggle('text-slate-500', !isActive);
              });
            });
          });

          latestProductModalContent.querySelectorAll('.latest-product-add-to-cart-btn').forEach(function (button) {
            button.addEventListener('click', async function () {
              const modalQty = Math.max(Number(qtyValueEl ? qtyValueEl.textContent : 1), 1);
              const currentProductId = this.getAttribute('data-product-id') || product.id || '';
              const originalText = this.innerHTML;

              this.disabled = true;
              this.innerHTML = 'Adding...';

              try {
                await addProductToCart(currentProductId, modalQty);
              } catch (error) {
                console.error('Add to cart error:', error);
                window.alert(error.message || 'Unable to add product to cart.');
              } finally {
                this.disabled = false;
                this.innerHTML = originalText;
              }
            });
          });
        }
      }

      function closeProductModal() {
        if (!latestProductModal) return;
        latestProductModal.classList.add('hidden');
        latestProductModal.classList.remove('flex');
        document.body.classList.remove('overflow-hidden');
      }

      function renderRecommendedProduct(product) {
