        +       '<p class="mt-1.5 text-[12px] leading-5 text-slate-600">' + (description || 'Description unavailable') + '</p>'
        +     '</div>'
        +   '</div>'
        + '</div>';
    }
    function openLatestProductModal(product) {
      if (!latestProductModal || !product) return;
      renderProductModal(product);
      latestProductModal.classList.remove('hidden');
      latestProductModal.classList.add('flex');
      document.body.classList.add('overflow-hidden');

      const qtyValueEl = document.getElementById('latestProductQtyValue');
      const totalPriceEl = document.getElementById('latestProductTotalPrice');
      const unitPrice = Number(product.unit_price || product.price || 0);
      const discountValue = Number(product.discount || 0);
      const discountType = product.discount_type || '';
      const discountedPrice = discountValue > 0
        ? (discountType === 'percent'
          ? unitPrice - ((unitPrice * discountValue) / 100)
          : Math.max(unitPrice - discountValue, 0))
        : unitPrice;

      if (latestProductModalContent && qtyValueEl && totalPriceEl) {
        latestProductModalContent.querySelectorAll('.latest-product-qty-btn').forEach(function(button) {
          button.addEventListener('click', function() {
            const currentQty = Number(qtyValueEl.textContent || 1);
            const nextQty = this.dataset.direction === 'increment'
              ? currentQty + 1
              : Math.max(currentQty - 1, 1);

            qtyValueEl.textContent = String(nextQty);
            totalPriceEl.textContent = formatMoney(discountedPrice * nextQty);
          });
        });
      }
    }

    function closeProductModal() {
      if (!latestProductModal) return;
      latestProductModal.classList.add('hidden');
      latestProductModal.classList.remove('flex');
      document.body.classList.remove('overflow-hidden');
    }

    function renderRecommendedProduct(product) {
      if (!recommendedCard || !product) return;

      const image = product.image || '';
      const title = product.product_name || product.name || 'Product';
      const unitPrice = Number(product.unit_price || product.price || 0);
      const discountValue = Number(product.discount || 0);
      const discountType = product.discount_type || '';
      const hasDiscount = discountValue > 0;
      const finalPrice = hasDiscount
        ? (discountType === 'percent'
          ? unitPrice - ((unitPrice * discountValue) / 100)
          : Math.max(unitPrice - discountValue, 0))
        : unitPrice;
      const discountLabel = hasDiscount
        ? (discountType === 'percent' ? '-' + discountValue + '%' : '-&#8377;' + discountValue)
        : '';
      const discountDisplay = hasDiscount ? (discountType === 'percent' ? 'Percent' : 'Flat') + '-' + discountLabel.replace(/^-/, '') : '';

      recommendedCard.innerHTML = ''
        + '<div class="rounded-[0.8rem] bg-white p-2.5">'
        +   '<div class="relative overflow-hidden rounded-[0.6rem] border border-gray-100 bg-white">'
        +     (discountDisplay ? '<span class="absolute left-3 top-3 z-10 rounded-md bg-emerald-500 px-2.5 py-1.5 text-[11px] font-bold text-white">' + discountDisplay + '</span>' : '')
        +     '<img src="' + image + '" alt="' + title + '" class="h-[185px] w-full object-contain">'
        +   '</div>'
        +   '<div class="pt-2 text-center">'
        +     '<h3 class="truncate text-[14px] font-medium uppercase tracking-[0.02em] text-[#0f172a]">' + title + '</h3>'
        +     '<div class="mt-1.5 flex items-end justify-center gap-2">'
        +       (hasDiscount ? '<span class="text-[12px] text-gray-400 line-through">&#8377;' + unitPrice.toFixed(2) + '</span>' : '')
        +       '<span class="text-[16px] font-bold text-[#334155]">&#8377;' + finalPrice.toFixed(2) + '</span>'
        +     '</div>'
        +     '<a href="/products/' + (product.slug || product.id || '') + '" class="mt-3 inline-flex items-center justify-center rounded-[0.8rem] bg-gradient-to-r from-emerald-500 to-cyan-500 px-6 py-2 text-[11px] font-bold uppercase tracking-[0.04em] text-white transition hover:from-emerald-600 hover:to-cyan-600">Buy Now</a>'
        +   '</div>'
        + '</div>';
    }
    // Client-only base URL for APIs
    const apiBaseClient = 'https://aerthh.newhopeindia17.com/api/';

    async function loadCategories() {
      if (!catTrack || !apiBaseClient) return;
      const endpoint = apiBaseClient + "categories";
      try {
        const resp = await fetch(endpoint);
        if (!resp.ok) throw new Error('HTTP ' + resp.status);
        const data = await resp.json();
        const list = Array.isArray(data.data) ? data.data : [];
        catTrack.innerHTML = renderCategoriesClient(list);
        initInfiniteCarousel(catTrack, 'cat-card');
      } catch (err) {
        console.error('Failed to load categories:', err.message || err);
        catTrack.innerHTML = '<div class="text-sm text-gray-500">Categories unavailable</div>';
      }
    }

    async function loadFeaturedProducts() {
      if (!featuredTrack || !apiBaseClient || featuredTrack.dataset.loaded === 'true') return;
      featuredTrack.dataset.loaded = 'true';
      const endpoint = apiBaseClient + "products";
      try {
        const resp = await fetch(endpoint);
        if (!resp.ok) throw new Error('HTTP ' + resp.status);
        const data = await resp.json();
        const list = Array.isArray(data) ? data : Array.isArray(data.data) ? data.data : [];
        latestProductMap.clear();
        list.forEach((item) => {
          if (item?.id !== undefined && item?.id !== null) {
            latestProductMap.set(String(item.id), item);
          }
        });
        featuredTrack.innerHTML = renderFeaturedProductsClient(list);
        initInfiniteCarousel(featuredTrack, 'featured-card');
        const latestProducts = [...list]
          .sort((a, b) => new Date(b.created_at || 0) - new Date(a.created_at || 0))
          .slice(0, 8);
        if (latestTrack) {
          latestTrack.innerHTML = renderLatestProductsClient(latestProducts);
          initInfiniteCarousel(latestTrack, 'latest-card');
        }
        const recommendedProduct = list.find((item) => Number(item.discount || 0) > 0) || list[0];
        renderRecommendedProduct(recommendedProduct);
      } catch (err) {
        console.error('Failed to load featured products:', err.message || err);
        featuredTrack.dataset.loaded = 'false';
        featuredTrack.innerHTML = '<div class="text-sm text-gray-500">Featured products unavailable</div>';
        if (latestTrack) {
          latestTrack.innerHTML = '<div class="text-sm text-gray-500">Latest products unavailable</div>';
        }
        if (recommendedCard) {
          recommendedCard.innerHTML = '<div class="text-sm text-gray-500">Recommended product unavailable</div>';
        }
      }
    }

    function initInfiniteCarousel(track, itemClassName) {
      const items = Array.from(track.children).filter(el => el.classList.contains(itemClassName));
      if (!items.length || track.dataset.carouselReady === 'true') return;

      if (items.length === 1) {
        track.dataset.carouselReady = 'true';
        track.classList.remove('overflow-x-auto');
        track.classList.add('justify-start');
        return;
      }

      track.dataset.carouselReady = 'true';
      const originalMarkup = track.innerHTML;
      track.innerHTML = originalMarkup + originalMarkup + originalMarkup;

      let animationFrameId = null;
      const singleSetWidth = track.scrollWidth / 3;

      const step = () => {
        track.scrollLeft += 0.7;
        if (track.scrollLeft >= singleSetWidth * 2) {
          track.scrollLeft -= singleSetWidth;
        }
        animationFrameId = window.requestAnimationFrame(step);
      };

      if (animationFrameId) {
        window.cancelAnimationFrame(animationFrameId);
      }

      track.scrollLeft = singleSetWidth;
      animationFrameId = window.requestAnimationFrame(step);
    }

    if (latestTrack) {
      latestTrack.addEventListener('click', function(event) {
        const trigger = event.target.closest('.latest-product-view-btn');
        if (!trigger) return;
        event.preventDefault();
        event.stopPropagation();
        const productId = trigger.getAttribute('data-product-id');
        openLatestProductModal(latestProductMap.get(productId));
      });
    }

    if (closeLatestProductModal) {
      closeLatestProductModal.addEventListener('click', closeProductModal);
    }

    if (latestProductModal) {
      latestProductModal.addEventListener('click', function(event) {
        if (event.target === latestProductModal) {
          closeProductModal();
        }
      });
    }

    document.addEventListener('keydown', function(event) {
      if (event.key === 'Escape') {
        closeProductModal();
      }
    });

    loadCategories();
    loadFeaturedProducts();
  })();
</script>
`; %>

<%- include('../layout/app', { title: title || 'Home', body }) %>



