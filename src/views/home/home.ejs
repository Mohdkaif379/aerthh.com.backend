          +     '</div>'
          +   '</div>'
          + '</a>';
      }).join('');
    }
    function renderLatestProductsClient(products) {
      if (!Array.isArray(products)) return '';
      return products.map(function(product) {
        const productHref = '/products/' + (product.slug || product.id || '');
        const image = product.image || '';
        const title = product.product_name || product.name || 'Product';
        const unitPrice = Number(product.unit_price || product.price || 0);
        const discountValue = Number(product.discount || 0);
        const discountType = product.discount_type || '';
        const hasDiscount = discountValue > 0;
        let finalPrice = unitPrice;
        let discountLabel = '';

        if (hasDiscount) {
          if (discountType === 'percent') {
            finalPrice = unitPrice - ((unitPrice * discountValue) / 100);
            discountLabel = '-' + discountValue + '%';
          } else {
            finalPrice = Math.max(unitPrice - discountValue, 0);
            discountLabel = '-&#8377;' + discountValue;
          }
        }

        const oldPrice = hasDiscount ? unitPrice.toFixed(2) : '';
        const price = Number.isFinite(finalPrice) ? finalPrice.toFixed(2) : Number.isFinite(unitPrice) ? unitPrice.toFixed(2) : '--';
        const discountDisplay = hasDiscount ? (discountType === 'percent' ? 'Percent' : 'Flat') + '-' + discountLabel.replace(/^-/, '') : '';

        return ''
          + '<a href="' + productHref + '" class="latest-card min-w-[190px] max-w-[190px] flex-shrink-0 rounded-2xl border border-gray-100 bg-white p-2 shadow-sm transition-transform duration-200 hover:-translate-y-1">'
          +   '<div class="relative h-[150px] overflow-hidden rounded-2xl bg-white">'
          +     (discountDisplay ? '<span class="absolute left-3 top-3 z-10 rounded-md bg-emerald-500 px-2.5 py-1.5 text-[11px] font-bold text-white">' + discountDisplay + '</span>' : '')
          +     '<button type="button" class="latest-product-view-btn absolute inset-0 z-10 flex items-center justify-center bg-slate-900/0 opacity-0 transition-all duration-200 hover:bg-slate-900/35 hover:opacity-100 focus:bg-slate-900/35 focus:opacity-100" data-product-id="' + (product.id || '') + '" aria-label="View product details">'
          +       '<span class="flex h-11 w-11 items-center justify-center rounded-full bg-white text-emerald-600 shadow-lg"><i class="fas fa-eye"></i></span>'
          +     '</button>'
