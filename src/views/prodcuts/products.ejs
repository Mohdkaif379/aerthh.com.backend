<%
  const items = Array.isArray(products) ? products : [];
  const error = typeof errorMessage !== 'undefined' ? errorMessage : '';
  const activeCategoryName = typeof selectedCategoryName !== 'undefined' ? selectedCategoryName : '';
  const activeBrandName = typeof selectedBrandName !== 'undefined' ? selectedBrandName : '';
  const pageTitle = activeCategoryName || activeBrandName || 'All Products';
  const pageLabel = activeCategoryName || activeBrandName ? 'Filtered Products' : 'Catalogue';
  const highestPrice = items.length
    ? items.reduce(function(max, item) {
        const unitPrice = Number(item?.unit_price || item?.price || 0);
        const discountValue = Number(item?.discount || 0);
        const discountType = item?.discount_type || '';
        const finalPrice = discountValue > 0
          ? (discountType === 'percent'
              ? unitPrice - ((unitPrice * discountValue) / 100)
              : Math.max(unitPrice - discountValue, 0))
          : unitPrice;
        return Math.max(max, finalPrice);
      }, 0)
    : 0;
  const maxFilterPrice = Math.ceil(highestPrice || 1000);

  function formatPrice(value) {
    return Number(value || 0).toFixed(2);
  }

  function formatMoney(value) {
    return new Intl.NumberFormat('en-IN', {
      style: 'currency',
      currency: 'INR',
      minimumFractionDigits: 2,
      maximumFractionDigits: 2
    }).format(Number(value || 0));
  }

  const productCards = items.map(function(item) {
    const title = item.product_name || item.name || 'Product';
    const image = item.image || '';
    const unitPrice = Number(item.unit_price || item.price || 0);
    const discountValue = Number(item.discount || 0);
    const discountType = item.discount_type || '';
    const finalPrice = discountValue > 0
      ? (discountType === 'percent'
          ? unitPrice - ((unitPrice * discountValue) / 100)
          : Math.max(unitPrice - discountValue, 0))
      : unitPrice;
    const hasDiscount = discountValue > 0;
    const discountDisplay = hasDiscount
      ? (discountType === 'percent' ? discountValue + '% OFF' : formatMoney(discountValue) + ' OFF')
      : '';

    return `
      <article class="product-card group overflow-hidden rounded-[1rem] border border-slate-200/80 bg-white shadow-[0_8px_22px_rgba(15,23,42,0.05)] transition duration-300 hover:-translate-y-1 hover:shadow-[0_14px_28px_rgba(16,185,129,0.10)]" data-price="${finalPrice}" data-title="${String(title).toLowerCase()}">
        <div class="relative overflow-hidden bg-[radial-gradient(circle_at_top,#ecfeff,transparent_58%),linear-gradient(180deg,#f8fafc_0%,#eef6ff_100%)] p-1.5">
          ${hasDiscount ? `<span class="absolute left-2.5  z-10 rounded-full bg-emerald-500 px-2.5 py-1 text-[9px] font-bold uppercase tracking-[0.12em] text-white">${discountDisplay}</span>` : ''}
          <a href="/products/buy?id=${item.id || ''}" class="block overflow-hidden rounded-[0.8rem] bg-white/90 p-1.5 ring-1 ring-slate-100">
            <img src="${image}" alt="${title}" class="h-[102px] w-full object-contain transition duration-300 group-hover:scale-[1.04]">
          </a>
        </div>
        <div class="p-2.5">
          <div class="flex items-start justify-between gap-2.5">
            <h2 class="line-clamp-2 text-[12px] font-semibold leading-4 text-slate-900">${title}</h2>
            <button type="button" class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full border border-emerald-100 bg-emerald-50 text-emerald-600 transition hover:border-cyan-200 hover:bg-cyan-50 hover:text-cyan-600">
              <i class="far fa-heart text-[11px]"></i>
            </button>
          </div>
          <div class="mt-1 flex items-end gap-1.5">
            ${hasDiscount ? `<span class="text-[11px] font-medium text-slate-400 line-through">${formatMoney(unitPrice)}</span>` : ''}
            <span class="text-[14px] font-bold text-slate-800">${formatMoney(finalPrice)}</span>
          </div>
          <div class="mt-2 flex items-center justify-between gap-2">
            <a href="/products/buy?id=${item.id || ''}" class="inline-flex items-center justify-center rounded-[0.75rem] bg-gradient-to-r from-emerald-500 to-cyan-500 px-2.5 py-1 text-[10px] font-semibold text-white transition hover:from-emerald-600 hover:to-cyan-600">Buy Now</a>
            <button type="button" class="inline-flex items-center justify-center rounded-[0.75rem] border border-cyan-200 bg-cyan-50 px-2.5 py-1 text-[10px] font-semibold text-cyan-700 transition hover:bg-cyan-100">Add</button>
          </div>
        </div>
      </article>
    `;
  }).join('');

  const body = `
  <section class="px-4 py-8 md:px-6 md:py-10">
    <div class="mx-auto max-w-7xl">
      <div class="overflow-hidden rounded-[2rem] bg-[radial-gradient(circle_at_top_left,#d1fae5,transparent_28%),radial-gradient(circle_at_top_right,#cffafe,transparent_24%),linear-gradient(135deg,#f8fafc_0%,#ffffff_58%,#f0fdfa_100%)] p-6 shadow-[0_20px_70px_rgba(15,23,42,0.08)] ring-1 ring-emerald-100 md:p-8">
        <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
          <div class="max-w-2xl">
            <p class="text-xs font-bold uppercase tracking-[0.28em] text-cyan-600">${pageLabel}</p>
            <h1 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">${pageTitle}</h1>
            <p class="mt-3 max-w-xl text-sm leading-6 text-slate-600">Refined picks for everyday shopping, arranged in a cleaner storefront with live filtering and quick sorting.</p>
            ${(activeCategoryName || activeBrandName) ? `
              <div class="mt-4 flex flex-wrap gap-2">
                ${activeCategoryName ? `<span class="inline-flex items-center rounded-full bg-white/90 px-4 py-1.5 text-xs font-semibold text-emerald-700 ring-1 ring-emerald-200">Category: ${activeCategoryName}</span>` : ''}
                ${activeBrandName ? `<span class="inline-flex items-center rounded-full bg-white/90 px-4 py-1.5 text-xs font-semibold text-cyan-700 ring-1 ring-cyan-200">Brand: ${activeBrandName}</span>` : ''}
              </div>
            ` : ''}
          </div>
          ${items.length ? `
            <div class="w-full max-w-[230px]">
              <label for="productsSort" class="mb-2 block text-xs font-bold uppercase tracking-[0.2em] text-slate-500">Sort By</label>
              <select id="productsSort" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-700 shadow-sm outline-none transition focus:border-cyan-400">
                <option value="default">Default Order</option>
                <option value="price_asc">Lowest Price</option>
                <option value="price_desc">Highest Price</option>
                <option value="title_asc">A to Z</option>
                <option value="title_desc">Z to A</option>
              </select>
            </div>
          ` : ''}
        </div>
      </div>

      ${error ? `
        <div class="mt-8 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-600">${error}</div>
      ` : items.length ? `
        <div class="mt-8 grid gap-7 lg:grid-cols-[290px_minmax(0,1fr)]">
          <aside class="h-fit rounded-[1.7rem] bg-white p-5 shadow-[0_14px_45px_rgba(15,23,42,0.07)] ring-1 ring-slate-200">
            <div class="flex items-center justify-between gap-3 border-b border-slate-200 pb-4">
              <div>
                <p class="text-xs font-bold uppercase tracking-[0.18em] text-cyan-600">Narrow Results</p>
                <h2 class="mt-1 text-lg font-bold text-slate-900">Filters</h2>
              </div>
              <button id="clearPriceFilter" type="button" class="text-xs font-bold uppercase tracking-[0.14em] text-emerald-600">Reset</button>
            </div>
            <div class="mt-5 rounded-[1.3rem] bg-slate-50 p-4 ring-1 ring-slate-200">
              <div class="flex items-center justify-between gap-3">
                <h3 class="text-sm font-bold uppercase tracking-[0.18em] text-slate-700">Price Range</h3>
                <span id="priceFilterValue" class="text-sm font-bold text-cyan-700">${formatMoney(maxFilterPrice)}</span>
              </div>
              <div class="mt-5">
                <input id="priceFilterRange" type="range" min="0" max="${maxFilterPrice}" value="${maxFilterPrice}" step="1" class="w-full accent-cyan-600">
              </div>
              <div class="mt-3 flex items-center justify-between text-xs font-medium text-slate-500">
                <span>${formatMoney(0)}</span>
                <span>${formatMoney(maxFilterPrice)}</span>
              </div>
            </div>
          </aside>

          <div>
            <div class="mb-4 flex items-center justify-between gap-3">
              <p id="productsCountLabel" class="text-sm font-medium text-slate-600">Showing ${items.length} products</p>
            </div>
            <div id="productsGrid" class="grid gap-5 sm:grid-cols-2 xl:grid-cols-4">
              ${productCards}
            </div>
          </div>
        </div>
      ` : `
        <div class="mt-8 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-600">${activeCategoryName ? 'No products found in this category.' : activeBrandName ? 'No products found for this brand.' : 'Products unavailable.'}</div>
      `}
    </div>
  </section>

  ${!error && items.length ? `
    <script>
      (function() {
        const priceRange = document.getElementById('priceFilterRange');
        const priceValue = document.getElementById('priceFilterValue');
        const clearButton = document.getElementById('clearPriceFilter');
        const countLabel = document.getElementById('productsCountLabel');
        const sortSelect = document.getElementById('productsSort');
        const productsGrid = document.getElementById('productsGrid');
        const productCards = Array.from(document.querySelectorAll('.product-card'));
        const maxPrice = ${JSON.stringify(maxFilterPrice)};

        function sortProducts(sortType) {
          if (!productsGrid) return;
          const sortedCards = [...productCards].sort(function(a, b) {
            const aPrice = Number(a.dataset.price || 0);
            const bPrice = Number(b.dataset.price || 0);
            const aTitle = a.dataset.title || '';
            const bTitle = b.dataset.title || '';

            if (sortType === 'price_asc') return aPrice - bPrice;
            if (sortType === 'price_desc') return bPrice - aPrice;
            if (sortType === 'title_asc') return aTitle.localeCompare(bTitle);
            if (sortType === 'title_desc') return bTitle.localeCompare(aTitle);
            return 0;
          });

          sortedCards.forEach(function(card) {
            productsGrid.appendChild(card);
          });
        }

        function applyPriceFilter(value) {
          const numericValue = Math.max(0, Math.min(Number(value || maxPrice), maxPrice));
          let visibleCount = 0;

          productCards.forEach(function(card) {
            const cardPrice = Number(card.dataset.price || 0);
            const isVisible = cardPrice <= numericValue;
            card.style.display = isVisible ? '' : 'none';
            if (isVisible) visibleCount += 1;
          });

          if (priceValue) {
            priceValue.textContent = new Intl.NumberFormat('en-IN', {
              style: 'currency',
              currency: 'INR',
              minimumFractionDigits: 2,
              maximumFractionDigits: 2
            }).format(numericValue);
          }

          if (priceRange && String(priceRange.value) !== String(numericValue)) {
            priceRange.value = String(numericValue);
          }

          if (countLabel) {
            countLabel.textContent = 'Showing ' + visibleCount + ' products';
          }
        }

        if (priceRange) {
          priceRange.addEventListener('input', function() {
            applyPriceFilter(this.value);
          });
        }

        if (sortSelect) {
          sortSelect.addEventListener('change', function() {
            sortProducts(this.value);
          });
        }

        if (clearButton && priceRange) {
          clearButton.addEventListener('click', function() {
            priceRange.value = String(maxPrice);
            applyPriceFilter(maxPrice);
          });
        }

        applyPriceFilter(maxPrice);
      })();
    </script>
  ` : ''}
  `; %>

<%- include('../layout/app', { title: title || 'Products' , body }) %>
