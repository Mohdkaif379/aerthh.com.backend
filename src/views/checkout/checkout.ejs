<%
    const isCartMode = typeof cartMode !== 'undefined' ? !!cartMode : false;
    if (isCartMode) {
      const body = `
    <section class="px-3 pt-5 pb-8 sm:px-4 md:px-6 md:pt-5 md:pb-10">
      <div class="mx-auto max-w-[1280px]">
        <div class="mb-6 rounded-[1rem] sm:rounded-[1.2rem] border border-sky-100 bg-[linear-gradient(180deg,#ffffff_0%,#f8fbff_100%)] px-3 py-5 sm:px-5 sm:py-6 shadow-[0_14px_34px_rgba(148,163,184,0.10)]">
          <div class="relative mx-auto flex max-w-4xl items-start justify-between gap-2 sm:gap-4">
            <div class="absolute left-[24px] right-[24px] top-[15px] h-[4px] bg-sky-100 sm:left-[36px] sm:right-[36px]"></div>
            <div class="absolute left-[24px] right-[24px] top-[15px] h-[4px] bg-gradient-to-r from-sky-400 to-blue-400 sm:left-[36px] sm:right-[36px]"></div>
            <div class="relative z-10 flex w-20 sm:w-28 flex-col items-center text-center"><div class="flex h-8 w-8 items-center justify-center rounded-full bg-gradient-to-br from-sky-400 to-blue-500 text-white shadow-sm"><i class="fas fa-cart-arrow-down text-[13px]"></i></div><span class="mt-4 sm:mt-5 text-[11px] sm:text-[13px] font-medium text-slate-700">Cart</span></div>
            <div class="relative z-10 flex w-28 sm:w-40 flex-col items-center text-center"><div class="flex h-8 w-8 items-center justify-center rounded-full bg-gradient-to-br from-sky-400 to-blue-500 text-white shadow-sm"><i class="fas fa-box-open text-[12px]"></i></div><span class="mt-4 sm:mt-5 text-[11px] sm:text-[13px] font-medium text-slate-700">Shipping And Billing</span></div>
            <div class="relative z-10 flex w-20 sm:w-28 flex-col items-center text-center"><div class="flex h-8 w-8 items-center justify-center rounded-full border-2 border-sky-300 bg-gradient-to-br from-sky-400 to-blue-500 text-white shadow-sm"><i class="far fa-credit-card text-[13px]"></i></div><span class="mt-4 sm:mt-5 text-[11px] sm:text-[13px] font-medium text-sky-700">Payment</span></div>
          </div>
        </div>

        <div class="mx-auto max-w-5xl rounded-[1rem] sm:rounded-[1.3rem] border border-sky-100 bg-[linear-gradient(180deg,#ffffff_0%,#f8fbff_100%)] p-4 sm:p-5 shadow-[0_18px_38px_rgba(148,163,184,0.14)] md:p-6">
          <div class="mb-5 flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <p class="text-[11px] font-bold uppercase tracking-[0.22em] text-sky-600">Checkout</p>
              <h1 class="mt-1 text-[24px] sm:text-[26px] font-bold text-slate-900">Review Your Cart Order</h1>
              <p class="mt-2 text-sm text-slate-500">Review your cart items, address details, and payment selection before placing the order.</p>
            </div>
            <a href="/products/address?cart=1" class="inline-flex w-full sm:w-auto items-center justify-center rounded-full bg-sky-50 px-4 py-2 text-sm font-semibold text-sky-700 transition hover:bg-sky-100 hover:text-sky-900">Edit Address</a>
          </div>

          <div id="cartCheckoutMessage" class="hidden rounded-xl px-4 py-3 text-sm"></div>
          <div class="grid gap-5 lg:grid-cols-[1.1fr_0.9fr]">
            <div class="space-y-5">
              <div id="cartCheckoutItems" class="space-y-4"></div>
              <div class="space-y-4">
                <div class="rounded-[1rem] border border-sky-100 bg-[linear-gradient(180deg,#f8fcff_0%,#eef7ff_100%)] p-4"><div class="mb-3"><h2 class="text-base font-bold text-slate-900">Shipping Address</h2></div><div id="cartShippingAddressCard" class="text-sm leading-6 text-slate-600"></div></div>
                <div class="rounded-[1rem] border border-sky-100 bg-white p-4"><div class="mb-3"><h2 class="text-base font-bold text-slate-900">Billing Address</h2></div><div id="cartBillingAddressCard" class="text-sm leading-6 text-slate-600"></div></div>
              </div>
            </div>
            <div class="rounded-[1rem] border border-sky-100 bg-[linear-gradient(180deg,#f8fcff_0%,#eef7ff_100%)] p-4">
              <div class="mb-4 flex flex-wrap items-center justify-between gap-3"><h2 class="text-lg font-bold text-slate-900">Order Summary</h2><span class="rounded-full bg-white px-3 py-1 text-[11px] font-bold uppercase tracking-[0.16em] text-sky-700 ring-1 ring-sky-100">Ready</span></div>
              <div class="space-y-3 rounded-[1rem] border border-sky-100 bg-white/90 p-4 text-sm">
                <div class="flex items-center justify-between gap-3 text-slate-600"><span>Items</span><span id="cartCheckoutCount" class="font-medium text-slate-800">0</span></div>
                <div class="flex items-center justify-between gap-3 text-slate-600"><span>Subtotal</span><span id="cartCheckoutSubtotal" class="font-medium text-slate-800">Rs 0.00</span></div>
                <div class="flex items-center justify-between gap-3 text-slate-600"><span>Tax</span><span id="cartCheckoutTax" class="font-medium text-slate-800">Rs 0.00</span></div>
                <div class="flex items-center justify-between gap-3 text-slate-600"><span>Shipping Cost</span><span id="cartCheckoutShipping" class="font-medium text-slate-800">Rs 0.00</span></div>
                <div class="border-t border-sky-100 pt-3"><div class="flex items-center justify-between gap-3"><span class="text-base font-semibold text-slate-800">Total</span><span id="cartCheckoutTotal" class="text-base font-bold text-sky-700">Rs 0.00</span></div></div>
              </div>
              <div class="mt-4 rounded-[1rem] border border-sky-100 bg-white/90 p-4">
                <div class="mb-3 flex flex-wrap items-center justify-between gap-3"><h3 class="text-base font-bold text-slate-900">Payment Method</h3><span class="rounded-full bg-sky-50 px-3 py-1 text-[11px] font-semibold text-sky-700 ring-1 ring-sky-100">Select One</span></div>
                <div class="grid gap-3">
                  <label class="payment-method-option flex cursor-pointer items-start gap-3 rounded-[0.9rem] border border-sky-200 bg-[linear-gradient(180deg,#ffffff_0%,#f8fbff_100%)] px-4 py-4 transition hover:border-sky-300 hover:bg-sky-50/60"><input type="radio" name="cartCheckoutPaymentMethod" value="cod" checked class="mt-1 h-4 w-4 border-sky-300 text-sky-500 focus:ring-sky-400"><div><p class="text-sm font-semibold text-slate-900">Cash on Delivery</p></div></label>
                  <label class="payment-method-option flex cursor-pointer items-start gap-3 rounded-[0.9rem] border border-sky-200 bg-[linear-gradient(180deg,#ffffff_0%,#f8fbff_100%)] px-4 py-4 transition hover:border-sky-300 hover:bg-sky-50/60"><input type="radio" name="cartCheckoutPaymentMethod" value="online" class="mt-1 h-4 w-4 border-sky-300 text-sky-500 focus:ring-sky-400"><div><p class="text-sm font-semibold text-slate-900">Online Payment</p></div></label>
                </div>
              </div>
            </div>
          </div>
          <div class="mt-6 border-t border-sky-100 pt-5"><button id="confirmCartOrderBtn" type="button" class="inline-flex w-full items-center justify-center rounded-[0.8rem] bg-gradient-to-r from-sky-500 to-blue-500 px-6 py-3.5 text-sm font-semibold text-white transition hover:from-sky-600 hover:to-blue-600">Confirm Order</button></div>
        </div>

        <div id="cartOrderSuccessModal" class="fixed inset-0 z-[20000] hidden items-center justify-center bg-slate-950/55 px-3 sm:px-4">
          <div class="w-full max-w-lg rounded-[1rem] sm:rounded-[1.4rem] border border-sky-100 bg-white p-4 sm:p-6 shadow-[0_24px_60px_rgba(15,23,42,0.24)]">
            <div class="flex items-start justify-between gap-4"><div class="flex min-w-0 items-center gap-3"><div class="flex h-12 w-12 items-center justify-center rounded-full bg-emerald-50 text-emerald-600 ring-1 ring-emerald-100"><i class="fas fa-check text-lg"></i></div><div class="min-w-0"><p class="text-[11px] font-bold uppercase tracking-[0.2em] text-emerald-600">Order Placed</p><h2 class="text-xl font-bold text-slate-900">Cart order placed successfully</h2></div></div><button id="closeCartOrderSuccessModalBtn" type="button" class="flex h-9 w-9 items-center justify-center rounded-full bg-slate-100 text-slate-500 transition hover:bg-slate-200 hover:text-slate-700"><i class="fas fa-xmark"></i></button></div>
            <div class="mt-5 rounded-[1rem] border border-sky-100 bg-[linear-gradient(180deg,#ffffff_0%,#f8fbff_100%)] p-4"><div class="flex items-center justify-between gap-3 text-sm text-slate-600"><span>Total Items Ordered</span><span id="cartOrderSuccessCount" class="font-semibold text-slate-900">0</span></div><div class="mt-3 flex items-center justify-between gap-3 text-sm text-slate-600"><span>Payment Method</span><span id="cartOrderSuccessPayment" class="font-semibold text-slate-900">--</span></div><div class="mt-3 flex items-center justify-between gap-3 border-t border-sky-100 pt-3"><span class="text-base font-semibold text-slate-900">Grand Total</span><span id="cartOrderSuccessTotal" class="text-base font-bold text-sky-700">Rs 0.00</span></div></div>
            <div class="mt-5 flex flex-col gap-3 sm:flex-row"><a href="/products" class="inline-flex flex-1 items-center justify-center rounded-[0.85rem] border border-sky-200 bg-white px-4 py-3 text-sm font-semibold text-sky-700 transition hover:bg-sky-50">Continue Shopping</a><button id="cartOrderSuccessDoneBtn" type="button" class="inline-flex flex-1 items-center justify-center rounded-[0.85rem] bg-gradient-to-r from-sky-500 to-blue-500 px-4 py-3 text-sm font-semibold text-white transition hover:from-sky-600 hover:to-blue-600">Go to Orders</button></div>
          </div>
        </div>
      </div>
    </section>

    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script>
      (function () {
        const messageBox = document.getElementById('cartCheckoutMessage');
        const itemsContainer = document.getElementById('cartCheckoutItems');
        const shippingCard = document.getElementById('cartShippingAddressCard');
        const billingCard = document.getElementById('cartBillingAddressCard');
        const countEl = document.getElementById('cartCheckoutCount');
        const subtotalEl = document.getElementById('cartCheckoutSubtotal');
        const taxEl = document.getElementById('cartCheckoutTax');
        const shippingEl = document.getElementById('cartCheckoutShipping');
        const totalEl = document.getElementById('cartCheckoutTotal');
        const confirmCartOrderBtn = document.getElementById('confirmCartOrderBtn');
        const paymentMethodInputs = Array.from(document.querySelectorAll('input[name="cartCheckoutPaymentMethod"]'));
            const cartOrderSuccessModal = document.getElementById('cartOrderSuccessModal');
            const closeCartOrderSuccessModalBtn = document.getElementById('closeCartOrderSuccessModalBtn');
            const cartOrderSuccessDoneBtn = document.getElementById('cartOrderSuccessDoneBtn');
            const cartOrderSuccessCount = document.getElementById('cartOrderSuccessCount');
            const cartOrderSuccessPayment = document.getElementById('cartOrderSuccessPayment');
            const cartOrderSuccessTotal = document.getElementById('cartOrderSuccessTotal');
            const openOrderReviewModalBtn = document.getElementById('openOrderReviewModalBtn');
            const orderReviewModal = document.getElementById('orderReviewModal');
            const closeOrderReviewModalBtn = document.getElementById('closeOrderReviewModalBtn');
            const cancelOrderReviewBtn = document.getElementById('cancelOrderReviewBtn');
            const submitOrderReviewBtn = document.getElementById('submitOrderReviewBtn');
            const orderReviewRating = document.getElementById('orderReviewRating');
            const orderReviewRatingLabel = document.getElementById('orderReviewRatingLabel');
            const orderReviewRatingStars = Array.from(document.querySelectorAll('[data-review-rating-star]'));
            const orderReviewDescription = document.getElementById('orderReviewDescription');
        let cartItems = [];
        let checkoutState = null;
        let grandTotal = 0;
        let totalQuantity = 0;

        function formatMoney(value) { return new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(Number(value || 0)); }
        function escapeHtml(value) { return String(value || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;'); }
        function getCustomerAuth() { try { return { token: localStorage.getItem('customerToken') || '', tokenType: localStorage.getItem('tokenType') || 'Bearer' }; } catch (error) { return { token: '', tokenType: 'Bearer' }; } }
        function getFinalUnitPrice(product) { const unitPrice = Number(product?.unit_price || 0); const discountValue = Number(product?.discount || 0); const discountType = product?.discount_type || ''; return discountValue > 0 ? (discountType === 'percent' ? unitPrice - ((unitPrice * discountValue) / 100) : Math.max(unitPrice - discountValue, 0)) : unitPrice; }
        function showMessage(text, isError) { if (!messageBox) return; messageBox.textContent = text; messageBox.className = 'rounded-xl px-4 py-3 text-sm ' + (isError ? 'border border-rose-200 bg-rose-50 text-rose-600' : 'border border-sky-200 bg-sky-50 text-sky-700'); messageBox.classList.remove('hidden'); }
        function renderAddress(target, address) { if (!target) return; if (!address) { target.innerHTML = '<p>Address unavailable.</p>'; return; } const fullName = [address.first_name, address.last_name].filter(Boolean).join(' '); const cityStateZip = [address.city, address.state, address.zip_code].filter(Boolean).join(', '); target.innerHTML = '' + (fullName ? '<p class="font-semibold text-slate-900">' + escapeHtml(fullName) + '</p>' : '') + (address.phone ? '<p>' + escapeHtml(address.phone) + '</p>' : '') + (address.email ? '<p>' + escapeHtml(address.email) + '</p>' : '') + (address.address_line ? '<p class="mt-2">' + escapeHtml(address.address_line) + '</p>' : '') + (cityStateZip ? '<p>' + escapeHtml(cityStateZip) + '</p>' : '') + (address.country ? '<p>' + escapeHtml(address.country) + '</p>' : ''); }
        function openOrderSuccessModal(paymentLabel) { if (!cartOrderSuccessModal || !cartOrderSuccessCount || !cartOrderSuccessPayment || !cartOrderSuccessTotal) return; cartOrderSuccessCount.textContent = String(totalQuantity); cartOrderSuccessPayment.textContent = paymentLabel; cartOrderSuccessTotal.textContent = formatMoney(grandTotal); cartOrderSuccessModal.classList.remove('hidden'); cartOrderSuccessModal.classList.add('flex'); document.body.classList.add('overflow-hidden'); }
        function closeOrderSuccessModal() { if (!cartOrderSuccessModal) return; cartOrderSuccessModal.classList.add('hidden'); cartOrderSuccessModal.classList.remove('flex'); document.body.classList.remove('overflow-hidden'); }
        function openOrderReviewModal() {
            if (!orderReviewModal) return;
            closeOrderSuccessModal();
            orderReviewModal.classList.remove('hidden');
            orderReviewModal.classList.add('flex');
            document.body.classList.add('overflow-hidden');
            window.setTimeout(function () {
                if (orderReviewDescription) {
                    orderReviewDescription.focus();
                }
            }, 50);
        }
        function closeOrderReviewModal() {
            if (!orderReviewModal) return;
            orderReviewModal.classList.add('hidden');
            orderReviewModal.classList.remove('flex');
            document.body.classList.remove('overflow-hidden');
        }
        function setClearedCartItemIds(ids) { try { localStorage.setItem('clearedCartItemIds', JSON.stringify(ids.map(function (value) { return String(value); }))); } catch (error) { console.warn('Unable to store cleared cart item ids:', error); } }
        function renderCartItems() { const totals = cartItems.reduce(function (acc, item) { const product = item?.product || {}; const quantity = Number(item?.quantity || 0); const finalUnitPrice = getFinalUnitPrice(product); const shippingCost = Number(product?.shipping_cost || 0); const taxAmount = Number(product?.tax_amount || 0); const lineTotal = (finalUnitPrice + shippingCost + taxAmount) * quantity; acc.count += quantity; acc.subtotal += finalUnitPrice * quantity; acc.tax += taxAmount * quantity; acc.shipping += shippingCost * quantity; acc.html += '' + '<div class="flex flex-col gap-4 sm:flex-row rounded-[1rem] border border-sky-100 bg-white/90 p-4">' + '<div class="flex h-28 w-28 items-center justify-center overflow-hidden rounded-[0.8rem] bg-[linear-gradient(180deg,#f8fcff_0%,#eef7ff_100%)] ring-1 ring-sky-100"><img src="' + escapeHtml(product?.image || 'https://via.placeholder.com/320x320/eef7ff/64748b?text=Product') + '" alt="' + escapeHtml(product?.product_name || 'Product') + '" class="h-full w-full object-contain"></div>' + '<div class="min-w-0 flex-1"><h3 class="text-lg font-semibold text-slate-900">' + escapeHtml(product?.product_name || 'Product') + '</h3><p class="mt-2 text-sm text-slate-500">Product ID: ' + escapeHtml(product?.id || item?.product_id || '--') + '</p><p class="mt-1 text-sm text-slate-500">Quantity: ' + escapeHtml(quantity) + '</p><p class="mt-1 text-sm font-semibold text-sky-700">Line Total: ' + escapeHtml(formatMoney(lineTotal)) + '</p></div>' + '</div>'; return acc; }, { count: 0, subtotal: 0, tax: 0, shipping: 0, html: '' }); totalQuantity = totals.count; grandTotal = totals.subtotal + totals.tax + totals.shipping; itemsContainer.innerHTML = totals.html || '<div class="rounded-[1rem] border border-sky-100 bg-white p-5 text-sm text-slate-500">No cart items found.</div>'; countEl.textContent = String(totals.count); subtotalEl.textContent = formatMoney(totals.subtotal); taxEl.textContent = formatMoney(totals.tax); shippingEl.textContent = formatMoney(totals.shipping); totalEl.textContent = formatMoney(grandTotal); }
        async function createOrder(payload, auth) {
            const controller = new AbortController();
            const timeoutId = window.setTimeout(function () {
                controller.abort();
            }, 25000);

            try {
                const response = await fetch('https://aerthh.newhopeindia17.com/api/order/create', {
                    method: 'POST',
                    headers: {
                        'Accept': 'application/json',
                        'Content-Type': 'application/json',
                        'Authorization': (auth.tokenType || 'Bearer') + ' ' + auth.token
                    },
                    body: JSON.stringify(payload),
                    signal: controller.signal
                });

                const result = await response.json();
                if (!response.ok || !result?.status) {
                    throw new Error(result?.message || result?.error || 'Unable to place order.');
                }
                return result;
            } catch (error) {
                if (error?.name === 'AbortError') {
                    throw new Error('Order request timed out. Please try again.');
                }
                throw error;
            } finally {
                window.clearTimeout(timeoutId);
            }
        }

        async function createReview(payload, auth) {
            const controller = new AbortController();
            const timeoutId = window.setTimeout(function () {
                controller.abort();
            }, 25000);

            try {
                const response = await fetch('https://aerthh.newhopeindia17.com/api/review/add', {
                    method: 'POST',
                    headers: {
                        'Accept': 'application/json',
                        'Content-Type': 'application/json',
                        'Authorization': (auth.tokenType || 'Bearer') + ' ' + auth.token
                    },
                    body: JSON.stringify(payload),
                    signal: controller.signal
                });

                const result = await response.json();

                if (!response.ok || !result?.status) {
                    throw new Error(result?.message || result?.error || 'Unable to save review.');
                }

                return result;
            } catch (error) {
                if (error?.name === 'AbortError') {
                    throw new Error('Review request timed out. Please try again.');
                }
                throw error;
            } finally {
                window.clearTimeout(timeoutId);
            }
        }

        function getCustomerDisplayData() {
            try {
                const rawCustomerData = localStorage.getItem('customerData') || localStorage.getItem('userData') || localStorage.getItem('authData') || '{}';
                const parsed = JSON.parse(rawCustomerData);
                const customer = parsed?.customer || parsed?.data || parsed || {};
                return {
                    name: [customer?.first_name, customer?.last_name].filter(Boolean).join(' ') || customer?.name || checkoutState?.shippingAddress?.first_name || 'Customer',
                    email: customer?.email || checkoutState?.shippingAddress?.email || '',
                    contact: customer?.phone || customer?.mobile || checkoutState?.shippingAddress?.phone || ''
                };
            } catch (error) {
                return {
                    name: checkoutState?.shippingAddress?.first_name || 'Customer',
                    email: checkoutState?.shippingAddress?.email || '',
                    contact: checkoutState?.shippingAddress?.phone || ''
                };
            }
        }

        function loadRazorpaySdk() {
            return new Promise(function (resolve, reject) {
                if (window.Razorpay) {
                    resolve(window.Razorpay);
                    return;
                }

                const existingScript = document.querySelector('script[src="https://checkout.razorpay.com/v1/checkout.js"]');
                if (existingScript) {
                    existingScript.addEventListener('load', function () {
                        if (window.Razorpay) {
                            resolve(window.Razorpay);
                        } else {
                            reject(new Error('Razorpay SDK failed to load.'));
                        }
                    }, { once: true });
                    existingScript.addEventListener('error', function () {
                        reject(new Error('Unable to load Razorpay checkout.'));
                    }, { once: true });
                    return;
                }

                const script = document.createElement('script');
                script.src = 'https://checkout.razorpay.com/v1/checkout.js';
                script.async = true;
                script.onload = function () {
                    if (window.Razorpay) {
                        resolve(window.Razorpay);
                    } else {
                        reject(new Error('Razorpay SDK failed to initialize.'));
                    }
                };
                script.onerror = function () {
                    reject(new Error('Unable to load Razorpay checkout.'));
                };
                document.head.appendChild(script);
            });
        }

        function openRazorpayCheckout(orderResult, paymentLabel) {
            return new Promise(function (resolve, reject) {
                const gateway = orderResult?.payment_gateway || {};
                const razorpayOrderId = gateway?.razorpay_order_id || orderResult?.data?.payment_order_id || orderResult?.data?.razorpay_order_id;
                const razorpayKey = gateway?.razorpay_key || gateway?.key;
                const amount = Number(gateway?.amount || orderResult?.amount || 0);
                const currency = gateway?.currency || 'INR';

                if (!razorpayOrderId || !razorpayKey || !amount) {
                    reject(new Error('Razorpay payment details are missing.'));
                    return;
                }

                loadRazorpaySdk().then(function (Razorpay) {
                    const customer = getCustomerDisplayData();
                    const razorpayInstance = new Razorpay({
                        key: razorpayKey,
                        amount: Math.round(amount * 100),
                        currency: currency,
                        name: 'AERTHH',
                        description: paymentLabel || 'Online Payment',
                        order_id: razorpayOrderId,
                        prefill: {
                            name: customer.name || '',
                            email: customer.email || '',
                            contact: customer.contact || ''
                        },
                        theme: {
                            color: '#0ea5e9'
                        },
                        modal: {
                            ondismiss: function () {
                                reject(new Error('Payment was closed before completion.'));
                            }
                        },
                        handler: function (response) {
                            resolve({
                                response: response,
                                orderResult: orderResult
                            });
                        }
                    });

                    razorpayInstance.on('payment.failed', function (response) {
                        reject(new Error(response?.error?.description || 'Payment failed. Please try again.'));
                    });
                    razorpayInstance.open();
                }).catch(reject);
            });
        }

        try { cartItems = JSON.parse(sessionStorage.getItem('cartCheckoutItems') || '[]'); } catch (error) { cartItems = []; }
        try { checkoutState = JSON.parse(sessionStorage.getItem('checkoutState') || 'null'); } catch (error) { checkoutState = null; }
        if (!cartItems.length) { window.location.href = '/cart'; return; }
        if (!checkoutState || !checkoutState.cartMode || !checkoutState.shippingAddress || !checkoutState.billingAddress) { window.location.href = '/products/address?cart=1'; return; }

        renderCartItems();
        renderAddress(shippingCard, checkoutState.shippingAddress);
        renderAddress(billingCard, checkoutState.billingAddress);

        confirmCartOrderBtn.addEventListener('click', async function () {
          const auth = getCustomerAuth();
          const selectedPaymentMethod = paymentMethodInputs.find(function (input) { return input.checked; });
          const paymentMethod = selectedPaymentMethod ? selectedPaymentMethod.value : 'cod';
          const paymentLabel = paymentMethod === 'online' ? 'Online Payment' : 'Cash on Delivery';
          if (!auth.token) { window.location.replace('/auth/customer/signin?redirect=' + encodeURIComponent('/checkout?cart=1')); return; }
          const originalBtnText = confirmCartOrderBtn.innerHTML;
          confirmCartOrderBtn.disabled = true;
          confirmCartOrderBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2 text-xs"></i> Placing Order';
          showMessage('Placing your order...', false);
          try {
            for (const item of cartItems) {
              const orderResult = await createOrder({ product_id: Number(item?.product?.id || item?.product_id || 0), quantity: Number(item?.quantity || 0), payment_method: paymentMethod }, auth);
              if (paymentMethod === 'online') {
                await openRazorpayCheckout(orderResult, paymentLabel);
              }
            }
            setClearedCartItemIds(cartItems.map(function (item) { return item?.id || ''; }));
            sessionStorage.removeItem('cartCheckoutItems');
            sessionStorage.removeItem('checkoutState');
            showMessage(paymentMethod === 'online' ? 'Payment completed successfully.' : 'Cart order placed successfully.', false);
            openOrderSuccessModal(paymentLabel);
          } catch (error) {
            console.error('Cart checkout order create error:', error);
            showMessage(error.message || 'Unable to place cart order. Please try again.', true);
            confirmCartOrderBtn.disabled = false;
            confirmCartOrderBtn.innerHTML = originalBtnText;
          }
        });

        if (closeCartOrderSuccessModalBtn) closeCartOrderSuccessModalBtn.addEventListener('click', function () { closeOrderSuccessModal(); window.location.href = '/orders'; });
