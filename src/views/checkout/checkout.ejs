                                    class="payment-method-option flex cursor-pointer items-start gap-3 rounded-[0.9rem] border border-sky-200 bg-[linear-gradient(180deg,#ffffff_0%,#f8fbff_100%)] px-4 py-4 transition hover:border-sky-300 hover:bg-sky-50/60">
                                    <input type="radio" name="paymentMethod" value="cod" checked
                                        class="mt-1 h-4 w-4 border-sky-300 text-sky-500 focus:ring-sky-400">
