                        <button id="modalDoneBtn" type="button" class="inline-flex flex-1 items-center justify-center rounded-[0.85rem] bg-gradient-to-r from-sky-500 to-blue-500 px-4 py-3 text-sm font-semibold text-white transition hover:from-sky-600 hover:to-blue-600">Done</button>
