                        'Accept': 'application/json',
                        'Content-Type': 'application/json',
                        'Authorization': (auth.tokenType || 'Bearer') + ' ' + auth.token
                    },
                    body: JSON.stringify(payload),
                    signal: controller.signal
                });

                const result = await response.json();

                if (!response.ok || !result?.status) {
                    throw new Error(result?.message || result?.error || 'Unable to save review.');
                }

                return result;
            } catch (error) {
                if (error?.name === 'AbortError') {
                    throw new Error('Review request timed out. Please try again.');
                }
                throw error;
            } finally {
                window.clearTimeout(timeoutId);
            }
        }

        function getCustomerDisplayData() {
            try {
                const rawCustomerData = localStorage.getItem('customerData') || localStorage.getItem('userData') || localStorage.getItem('authData') || '{}';
                const parsed = JSON.parse(rawCustomerData);
                const customer = parsed?.customer || parsed?.data || parsed || {};
                return {
                    name: [customer?.first_name, customer?.last_name].filter(Boolean).join(' ') || customer?.name || checkoutState?.shippingAddress?.first_name || 'Customer',
                    email: customer?.email || checkoutState?.shippingAddress?.email || '',
                    contact: customer?.phone || customer?.mobile || checkoutState?.shippingAddress?.phone || ''
                };
            } catch (error) {
                return {
                    name: checkoutState?.shippingAddress?.first_name || 'Customer',
                    email: checkoutState?.shippingAddress?.email || '',
                    contact: checkoutState?.shippingAddress?.phone || ''
                };
            }
        }

        function loadRazorpaySdk() {
            return new Promise(function (resolve, reject) {
                if (window.Razorpay) {
                    resolve(window.Razorpay);
                    return;
                }

                const existingScript = document.querySelector('script[src="https://checkout.razorpay.com/v1/checkout.js"]');
                if (existingScript) {
                    existingScript.addEventListener('load', function () {
                        if (window.Razorpay) {
                            resolve(window.Razorpay);
                        } else {
                            reject(new Error('Razorpay SDK failed to load.'));
                        }
                    }, { once: true });
                    existingScript.addEventListener('error', function () {
                        reject(new Error('Unable to load Razorpay checkout.'));
                    }, { once: true });
                    return;
                }

                const script = document.createElement('script');
                script.src = 'https://checkout.razorpay.com/v1/checkout.js';
                script.async = true;
                script.onload = function () {
                    if (window.Razorpay) {
                        resolve(window.Razorpay);
                    } else {
                        reject(new Error('Razorpay SDK failed to initialize.'));
                    }
                };
                script.onerror = function () {
                    reject(new Error('Unable to load Razorpay checkout.'));
                };
                document.head.appendChild(script);
            });
        }

        function openRazorpayCheckout(orderResult, paymentLabel) {
            return new Promise(function (resolve, reject) {
                const gateway = orderResult?.payment_gateway || {};
                const razorpayOrderId = gateway?.razorpay_order_id || orderResult?.data?.payment_order_id || orderResult?.data?.razorpay_order_id;
                const razorpayKey = gateway?.razorpay_key || gateway?.key;
                const amount = Number(gateway?.amount || orderResult?.amount || 0);
                const currency = gateway?.currency || 'INR';

                if (!razorpayOrderId || !razorpayKey || !amount) {
                    reject(new Error('Razorpay payment details are missing.'));
                    return;
                }

                loadRazorpaySdk().then(function (Razorpay) {
                    const customer = getCustomerDisplayData();
                    const razorpayInstance = new Razorpay({
                        key: razorpayKey,
                        amount: Math.round(amount * 100),
                        currency: currency,
                        name: 'AERTHH',
                        description: paymentLabel || 'Online Payment',
                        order_id: razorpayOrderId,
                        prefill: {
                            name: customer.name || '',
                            email: customer.email || '',
                            contact: customer.contact || ''
                        },
                        theme: {
                            color: '#0ea5e9'
                        },
                        modal: {
                            ondismiss: function () {
                                reject(new Error('Payment was closed before completion.'));
                            }
                        },
                        handler: function (response) {
                            resolve({
                                response: response,
                                orderResult: orderResult
                            });
                        }
                    });

                    razorpayInstance.on('payment.failed', function (response) {
                        reject(new Error(response?.error?.description || 'Payment failed. Please try again.'));
                    });

                    razorpayInstance.open();
                }).catch(reject);
            });
        }

        function openOrderSuccessModal(orderData, paymentLabel) {
            if (!orderSuccessModal) return;
            const orderTotal = Number(orderData?.total_price || 0)
                + Number(orderData?.shipping_cost || shippingCost || 0)
                + Number(orderData?.tax_amount || taxAmount || 0);
            if (orderSuccessOrderId) orderSuccessOrderId.textContent = 'Order ID: ' + String(orderData?.id || '--');
            if (orderSuccessQuantity) orderSuccessQuantity.textContent = 'Quantity: ' + String(orderData?.quantity || quantity);
            if (orderSuccessPayment) orderSuccessPayment.textContent = 'Payment Method: ' + paymentLabel;
            if (orderSuccessTotal) orderSuccessTotal.textContent = 'Total: ' + formatMoneyValue(orderTotal || pageTotal);
            orderSuccessModal.classList.remove('hidden');
            orderSuccessModal.classList.add('flex');
        }

        function closeOrderSuccessModal() {
            if (!orderSuccessModal) return;
            orderSuccessModal.classList.add('hidden');
            orderSuccessModal.classList.remove('flex');
        }

        function updateReviewRatingStars(rating) {
            const numericRating = Math.max(0, Math.min(Number(rating || 0), 5));
            if (orderReviewRating) {
                orderReviewRating.value = String(numericRating);
            }
            if (orderReviewRatingLabel) {
                const labels = {
                    0: 'Select rating',
                    1: '1 - Poor',
                    2: '2 - Fair',
                    3: '3 - Good',
                    4: '4 - Very Good',
                    5: '5 - Excellent'
                };
                orderReviewRatingLabel.textContent = labels[numericRating] || 'Select rating';
            }
            orderReviewRatingStars.forEach(function (button) {
                const starValue = Number(button.getAttribute('data-review-rating-star') || 0);
                const isActive = starValue <= numericRating;
                button.classList.toggle('border-amber-300', isActive);
                button.classList.toggle('bg-amber-50', isActive);
                button.classList.toggle('text-amber-400', isActive);
                button.classList.toggle('text-slate-300', !isActive);
            });
        }

        function openOrderReviewModal() {
            if (!orderReviewModal) return;
            closeOrderSuccessModal();
            orderReviewModal.classList.remove('hidden');
            orderReviewModal.classList.add('flex');
            document.body.classList.add('overflow-hidden');
            updateReviewRatingStars(orderReviewRating ? orderReviewRating.value : 0);
            window.setTimeout(function () {
                if (orderReviewDescription) {
                    orderReviewDescription.focus();
                }
            }, 50);
        }

        function closeOrderReviewModal() {
            if (!orderReviewModal) return;
            orderReviewModal.classList.add('hidden');
            orderReviewModal.classList.remove('flex');
            document.body.classList.remove('overflow-hidden');
        }

        function renderAddress(container, address) {
            if (!container) return;
            if (!address) {
                container.innerHTML = '<div class="rounded-[1rem] border border-dashed border-sky-200 bg-white/90 px-4 py-5 text-sm text-slate-500">Address not available.</div>';
                return;
            }

            const fullName = [address.first_name, address.last_name].filter(Boolean).join(' ');
            const locationLine = [address.city, address.state, address.zip_code].filter(Boolean).join(', ');
            const addressLines = [address.address_line, locationLine, address.country].filter(Boolean);

            container.innerHTML = ''
                + '<div class="rounded-[1rem] border border-sky-100 bg-[linear-gradient(180deg,#ffffff_0%,#f8fbff_100%)] p-4 shadow-[0_12px_28px_rgba(148,163,184,0.10)]">'
                + '<div class="flex flex-wrap items-start justify-between gap-3">'
                + '<div class="flex min-w-0 flex-1 items-start gap-3">'
                + '<div class="flex h-11 w-11 items-center justify-center rounded-full bg-sky-50 text-sky-600 ring-1 ring-sky-100">'
                + '<i class="fas fa-location-dot text-sm"></i>'
                + '</div>'
                + '<div class="min-w-0 flex-1 break-words">'
                + '<p class="text-[11px] font-bold uppercase tracking-[0.18em] text-sky-600">Contact</p>'
                + '<p class="mt-1 text-sm font-semibold text-slate-900">' + (fullName || 'Customer') + '</p>'
                + (address.phone ? '<p class="mt-1 text-xs font-medium text-slate-600">' + address.phone + '</p>' : '')
                + '</div>'
                + '</div>'
                + '<span class="shrink-0 rounded-full bg-sky-50 px-3 py-1 text-[11px] font-semibold text-sky-700 ring-1 ring-sky-100">' + (address.type === 'billing' ? 'Billing' : 'Shipping') + '</span>'
                + '</div>'
                + '<div class="mt-4 rounded-[0.95rem] border border-sky-100 bg-sky-50/70 px-3.5 py-3 break-words">'
                + '<p class="text-[11px] font-bold uppercase tracking-[0.18em] text-sky-600">Address</p>'
                + '<div class="mt-2 space-y-1.5 text-sm leading-6 text-slate-600">'
                + addressLines.map(function (line) {
                    return '<p>' + line + '</p>';
                }).join('')
                + '</div>'
                + '</div>'
                + '</div>';
        }

        function syncPaymentMethodSelection() {
            document.querySelectorAll('.payment-method-option').forEach(function (option) {
                const radio = option.querySelector('input[name="cartCheckoutPaymentMethod"]');
                const isActive = !!(radio && radio.checked);
                option.classList.toggle('border-sky-400', isActive);
                option.classList.toggle('bg-sky-50', isActive);
            });
        }

        if (!hasCustomerSession()) {
            window.location.replace('/auth/customer/signin?redirect=' + encodeURIComponent(checkoutPath));
            return;
        }

        let checkoutState = null;
        try {
            checkoutState = JSON.parse(sessionStorage.getItem('checkoutState') || 'null');
        } catch (error) {
            checkoutState = null;
        }

        if (!checkoutState || String(checkoutState.productId || '') !== productId || Number(checkoutState.qty || 0) !== quantity) {
            showMessage('Saved address details were not found. Please enter your address again.', true);
            window.setTimeout(function () {
                window.location.href = '/products/address?id=' + encodeURIComponent(productId) + '&qty=' + encodeURIComponent(String(quantity));
            }, 1200);
            return;
        }

        renderAddress(shippingCard, checkoutState.shippingAddress);
        renderAddress(billingCard, checkoutState.billingAddress);

        paymentMethodInputs.forEach(function (input) {
            input.addEventListener('change', syncPaymentMethodSelection);
        });
        syncPaymentMethodSelection();

        if (closeOrderSuccessModalBtn) {
            closeOrderSuccessModalBtn.addEventListener('click', closeOrderSuccessModal);
        }
        if (openOrderReviewModalBtn) {
            openOrderReviewModalBtn.addEventListener('click', openOrderReviewModal);
        }
        if (closeOrderReviewModalBtn) {
            closeOrderReviewModalBtn.addEventListener('click', closeOrderReviewModal);
        }
        if (cancelOrderReviewBtn) {
            cancelOrderReviewBtn.addEventListener('click', closeOrderReviewModal);
        }
        orderReviewRatingStars.forEach(function (button) {
            button.addEventListener('click', function () {
                updateReviewRatingStars(button.getAttribute('data-review-rating-star') || '5');
            });
        });
        if (modalDoneBtn) {
            modalDoneBtn.addEventListener('click', function () {
                closeOrderSuccessModal();
                window.location.href = '/orders';
            });
        }
        if (orderReviewModal) {
            orderReviewModal.addEventListener('click', function (event) {
                if (event.target === orderReviewModal) {
                    closeOrderReviewModal();
                }
            });
        }
        if (submitOrderReviewBtn) {
            submitOrderReviewBtn.addEventListener('click', async function () {
                const ratingValue = String(orderReviewRating ? orderReviewRating.value : '').trim();
                const reviewText = String(orderReviewDescription ? orderReviewDescription.value : '').trim();
                if (!ratingValue) {
                    showMessage('Please select a rating.', true);
                    if (orderReviewRating) orderReviewRating.focus();
                    return;
                }
                if (!reviewText) {
                    showMessage('Please enter review description.', true);
                    if (orderReviewDescription) orderReviewDescription.focus();
                    return;
                }
                const auth = getCustomerAuth();
                const normalizedProductId = Number(productId);

                if (!normalizedProductId || Number.isNaN(normalizedProductId)) {
                    showMessage('Invalid product selected for review.', true);
                    return;
                }

                submitOrderReviewBtn.disabled = true;
                submitOrderReviewBtn.textContent = 'Saving...';

                try {
                    const result = await createReview({
                        product_id: normalizedProductId,
                        rating: Number(ratingValue),
                        comment: reviewText
                    }, auth);

                    showMessage(result?.message || 'Review saved successfully.', false);
                    updateReviewRatingStars(0);
                    if (orderReviewDescription) {
                        orderReviewDescription.value = '';
                    }
                    closeOrderReviewModal();
                    window.setTimeout(function () {
                        window.location.href = '/orders';
                    }, 900);
                } catch (error) {
                    showMessage(error?.message || 'Unable to save review.', true);
                } finally {
                    submitOrderReviewBtn.disabled = false;
                    submitOrderReviewBtn.textContent = 'Submit Review';
                }
            });
        }
        if (orderSuccessModal) {
            orderSuccessModal.addEventListener('click', function (event) {
                if (event.target === orderSuccessModal) {
                    closeOrderSuccessModal();
                }
            });
        }

        if (confirmOrderBtn) {
            confirmOrderBtn.addEventListener('click', async function () {
                const selectedPaymentMethod = paymentMethodInputs.find(function (input) {
                    return input.checked;
                });
                const auth = getCustomerAuth();
                const paymentLabel = selectedPaymentMethod && selectedPaymentMethod.value === 'online'
                    ? 'Online Payment'
                    : 'Cash on Delivery';
                const normalizedProductId = Number(productId);

                if (!normalizedProductId || Number.isNaN(normalizedProductId)) {
                    showMessage('Invalid product selected for checkout.', true);
                    return;
                }
                if (!Number(quantity) || Number.isNaN(Number(quantity))) {
                    showMessage('Invalid quantity selected for checkout.', true);
                    return;
                }

                if (!auth.token) {
                    window.location.replace('/auth/customer/signin?redirect=' + encodeURIComponent(checkoutPath));
                    return;
                }

                const originalBtnText = confirmOrderBtn.innerHTML;
                confirmOrderBtn.disabled = true;
                confirmOrderBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2 text-xs"></i> Placing Order';
                showMessage('Placing your order...', false);

                try {
                    const result = await createOrder({
                        product_id: normalizedProductId,
                        quantity: Number(quantity),
                        payment_method: selectedPaymentMethod ? selectedPaymentMethod.value : 'cod'
                    }, auth);

                    if (selectedPaymentMethod && selectedPaymentMethod.value === 'online') {
                        await openRazorpayCheckout(result, paymentLabel);
                    }

                    try {
                        sessionStorage.removeItem('checkoutState');
                    } catch (storageError) {
                        console.warn('Unable to clear checkout state:', storageError);
                    }
                    showMessage(selectedPaymentMethod && selectedPaymentMethod.value === 'online'
                        ? 'Payment completed successfully.'
                        : (result?.message || 'Order placed successfully.'), false);
                    openOrderSuccessModal(result?.data || {}, paymentLabel);
                } catch (error) {
                    console.error('Order create error:', error);
                    showMessage(error.message || 'Unable to place order. Please try again.', true);
                } finally {
                    confirmOrderBtn.disabled = false;
                    confirmOrderBtn.innerHTML = originalBtnText;
                }
            });
        }
    }) ();
    </script>
    `; %>

    <%- include('../layout/app', { title: title || 'Checkout' , body }) %>
<% } %>
