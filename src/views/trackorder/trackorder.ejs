<% const body=`
<section class="px-3 pt-2 pb-16 sm:px-4 md:px-6">
    <div class="mx-auto max-w-2xl text-center">
        <p class="text-[11px] font-bold uppercase tracking-[0.28em] text-sky-600 mb-2">Delivery Status</p>
        <h1 class="text-2xl font-bold tracking-tight text-slate-900 sm:text-3xl">Track Your Order</h1>
        <p class="mt-3 text-sm leading-6 text-slate-600 sm:text-base">
            Enter your order ID or tracking number below to get real-time updates on your delivery status.
        </p>

        <div class="mt-8 rounded-[1.4rem] border border-sky-100 bg-white p-6 md:p-8 shadow-[0_12px_30px_rgba(148,163,184,0.10)] relative overflow-hidden">
            <!-- Background Glow -->
            <div class="absolute -top-16 -left-16 h-32 w-32 rounded-full bg-sky-400 opacity-10 blur-3xl"></div>
            <div class="absolute -bottom-16 -right-16 h-32 w-32 rounded-full bg-blue-400 opacity-10 blur-3xl"></div>

            <form id="trackOrderForm" class="relative z-10 flex flex-col sm:flex-row gap-3 items-center justify-center">
                <div class="w-full sm:w-8/12">
                    <label for="orderId" class="sr-only">Order ID or Tracking Number</label>
                    <input type="text" id="orderId" name="orderId"
                        placeholder="Enter Order ID (e.g., ORD0001)" required
                        class="w-full rounded-[0.8rem] border border-sky-100 bg-sky-50/30 px-4 py-3 text-sm text-slate-700 outline-none transition-all placeholder:text-slate-400 focus:border-sky-400 focus:bg-white focus:ring-1 focus:ring-sky-200">
                </div>
                <button type="submit" id="trackSubmitBtn"
                    class="w-full sm:w-auto inline-flex items-center justify-center rounded-[0.8rem] bg-gradient-to-r from-sky-500 to-blue-500 px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:from-sky-600 hover:to-blue-600 hover:shadow disabled:opacity-70 disabled:cursor-not-allowed">
                    <i class="fa-solid fa-location-crosshairs mr-2"></i> <span>Track Now</span>
                </button>
            </form>

            <div id="errorMessageContainer" class="hidden relative z-10 mt-6 p-4 rounded-xl border border-red-200 bg-red-50 text-red-800 text-sm font-medium animate-fade-in-up text-left flex items-start gap-3">
                <i class="fa-solid fa-circle-exclamation mt-1 text-red-600"></i>
                <span id="errorMessageText"></span>
            </div>
        </div>

        <div id="resultsContainer">
            <!-- Default placeholders -->
            <div id="defaultPlaceholders" class="mt-8 grid gap-4 md:grid-cols-3 max-w-3xl mx-auto text-left">
                <div class="rounded-[1.1rem] border border-slate-100 bg-white p-5 shadow-sm transition hover:shadow-md">
                    <div class="mb-3 flex h-9 w-9 items-center justify-center rounded-full bg-sky-50 text-sky-600">
                        <i class="fas fa-box-open text-sm"></i>
                    </div>
                    <h3 class="text-sm font-semibold text-slate-900">Processing</h3>
                    <p class="mt-1 text-xs leading-5 text-slate-500">Your order is being prepared in our warehouse.</p>
                </div>
                <div class="rounded-[1.1rem] border border-slate-100 bg-white p-5 shadow-sm transition hover:shadow-md">
                    <div class="mb-3 flex h-9 w-9 items-center justify-center rounded-full bg-blue-50 text-blue-600">
                        <i class="fas fa-truck-fast text-sm"></i>
                    </div>
                    <h3 class="text-sm font-semibold text-slate-900">Shipped</h3>
                    <p class="mt-1 text-xs leading-5 text-slate-500">Your package is currently in transit to your location.</p>
                </div>
                <div class="rounded-[1.1rem] border border-slate-100 bg-white p-5 shadow-sm transition hover:shadow-md">
                    <div class="mb-3 flex h-9 w-9 items-center justify-center rounded-full bg-green-50 text-green-600">
                        <i class="fas fa-house-chimney text-sm"></i>
                    </div>
                    <h3 class="text-sm font-semibold text-slate-900">Delivered</h3>
                    <p class="mt-1 text-xs leading-5 text-slate-500">Your order has been successfully delivered to you.</p>
                </div>
            </div>
            
            <!-- Dynamic data container. It's hidden initially -->
            <div id="dynamicOrderData" class="hidden mt-8 grid gap-6 md:grid-cols-2 max-w-4xl mx-auto text-left">
                <!-- Rendered conditionally in JS -->
            </div>
        </div>
    </div>
</section>

<div id="cancelOrderModal" class="fixed inset-0 z-[1700] hidden items-center justify-center bg-slate-950/50 px-4 py-6 backdrop-blur-sm">
    <div class="w-full max-w-lg overflow-hidden rounded-[1.4rem] border border-rose-100 bg-white shadow-[0_24px_80px_rgba(15,23,42,0.22)]">
        <div class="flex items-start justify-between border-b border-rose-100 px-5 py-4 sm:px-6">
            <div>
                <p class="text-[11px] font-bold uppercase tracking-[0.2em] text-rose-600">Cancel Order</p>
                <h2 id="cancelOrderTitle" class="mt-1 text-xl font-bold text-slate-900">Cancel order</h2>
            </div>
            <button id="cancelOrderCloseBtn" type="button" class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-500 transition hover:bg-slate-50 hover:text-slate-700" aria-label="Close cancel order dialog">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        <div class="px-5 py-5 sm:px-6">
            <p id="cancelOrderSubtitle" class="text-sm text-slate-500">Please add a reason before canceling this order.</p>
            <label for="cancelOrderReason" class="mt-4 block text-sm font-semibold text-slate-700">Cancel reason</label>
            <textarea id="cancelOrderReason" rows="4" maxlength="500" placeholder="Tell us why you want to cancel this order..."
                class="mt-2 w-full rounded-[1rem] border border-slate-200 bg-white px-4 py-3 text-sm text-slate-700 outline-none transition placeholder:text-slate-400 focus:border-rose-300 focus:ring-1 focus:ring-rose-200"></textarea>
            <div id="cancelOrderMessage" class="mt-3 hidden rounded-[1rem] px-4 py-3 text-sm"></div>
            <div class="mt-5 flex flex-col-reverse gap-3 sm:flex-row sm:justify-end">
                <button id="cancelOrderDismissBtn" type="button" class="inline-flex items-center justify-center rounded-[0.95rem] border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">
                    Keep order
                </button>
                <button id="cancelOrderSubmitBtn" type="button" class="inline-flex items-center justify-center rounded-[0.95rem] bg-gradient-to-r from-rose-500 to-red-500 px-5 py-3 text-sm font-semibold text-white shadow-[0_14px_28px_rgba(244,63,94,0.22)] transition hover:from-rose-600 hover:to-red-600 disabled:cursor-not-allowed disabled:opacity-70">
                    Cancel Order
                </button>
            </div>
        </div>
    </div>
</div>

<div id="cancelSuccessModal" class="fixed inset-0 z-[1800] hidden items-center justify-center bg-slate-950/55 px-4 py-6 backdrop-blur-sm">
    <div class="w-full max-w-md overflow-hidden rounded-[1.4rem] border border-emerald-100 bg-white shadow-[0_28px_80px_rgba(15,23,42,0.22)]">
        <div class="border-b border-emerald-100 px-5 py-4 sm:px-6">
            <p class="text-[11px] font-bold uppercase tracking-[0.2em] text-emerald-600">Order Canceled</p>
            <h2 class="mt-1 text-xl font-bold text-slate-900">Successfully canceled order</h2>
        </div>
        <div class="px-5 py-6 sm:px-6">
            <div class="flex items-start gap-3 rounded-[1rem] border border-emerald-100 bg-emerald-50/70 px-4 py-4">
                <div class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-emerald-500 text-white">
                    <i class="fa-solid fa-circle-check text-sm"></i>
                </div>
                <div class="min-w-0">
                    <p id="cancelSuccessMessage" class="text-sm font-semibold text-emerald-800">Order canceled successfully.</p>
                    <p class="mt-1 text-sm text-emerald-700/80">Your order has been canceled and the update has been saved.</p>
                </div>
            </div>
            <div class="mt-5 flex justify-end">
                <button id="cancelSuccessOkBtn" type="button" class="inline-flex items-center justify-center rounded-[0.95rem] bg-gradient-to-r from-emerald-500 to-green-500 px-5 py-3 text-sm font-semibold text-white shadow-[0_14px_28px_rgba(16,185,129,0.22)] transition hover:from-emerald-600 hover:to-green-600">
                    Okay
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const form = document.getElementById('trackOrderForm');
        const submitBtn = document.getElementById('trackSubmitBtn');
        const submitBtnText = submitBtn.querySelector('span');
        const errorMessageContainer = document.getElementById('errorMessageContainer');
        const errorMessageText = document.getElementById('errorMessageText');
        const defaultPlaceholders = document.getElementById('defaultPlaceholders');
        const dynamicOrderData = document.getElementById('dynamicOrderData');
        const cancelOrderModal = document.getElementById('cancelOrderModal');
        const cancelOrderTitle = document.getElementById('cancelOrderTitle');
        const cancelOrderSubtitle = document.getElementById('cancelOrderSubtitle');
        const cancelOrderReason = document.getElementById('cancelOrderReason');
        const cancelOrderMessage = document.getElementById('cancelOrderMessage');
        const cancelOrderSubmitBtn = document.getElementById('cancelOrderSubmitBtn');
        const cancelOrderCloseBtn = document.getElementById('cancelOrderCloseBtn');
        const cancelOrderDismissBtn = document.getElementById('cancelOrderDismissBtn');
        const cancelSuccessModal = document.getElementById('cancelSuccessModal');
        const cancelSuccessMessage = document.getElementById('cancelSuccessMessage');
        const cancelSuccessOkBtn = document.getElementById('cancelSuccessOkBtn');
        const apiBase = 'https://aerthh.newhopeindia17.com/api/';
        let activeOrder = null;

        function showCancelMessage(text, isError) {
            if (!cancelOrderMessage) return;
            cancelOrderMessage.textContent = text;
            cancelOrderMessage.className = 'mt-3 rounded-[1rem] px-4 py-3 text-sm ' + (isError
                ? 'border border-rose-200 bg-rose-50 text-rose-600'
                : 'border border-emerald-200 bg-emerald-50 text-emerald-700');
            cancelOrderMessage.classList.remove('hidden');
        }

        function getCustomerAuth() {
            try {
                return {
                    token: localStorage.getItem('customerToken') || '',
                    tokenType: localStorage.getItem('tokenType') || 'Bearer'
                };
            } catch (error) {
                return { token: '', tokenType: 'Bearer' };
            }
        }

        function getCustomerData() {
            try {
                const rawCustomerData = localStorage.getItem('customerData') || localStorage.getItem('userData') || localStorage.getItem('authData') || '{}';
                const parsed = JSON.parse(rawCustomerData);
                return parsed?.customer || parsed?.data || parsed || {};
            } catch (error) {
                return {};
            }
        }

        function canCancelOrder(status) {
            const value = String(status || '').toLowerCase();
            return !['canceled', 'cancelled', 'delivered', 'completed', 'complete', 'returned'].includes(value);
        }

        function openCancelModal(orderData) {
            if (!cancelOrderModal || !cancelOrderTitle || !cancelOrderSubtitle || !cancelOrderReason || !cancelOrderMessage) return;
            activeOrder = orderData || null;
            const orderNo = orderData?.order_no || orderData?.id || '--';
            cancelOrderTitle.textContent = 'Cancel order #' + orderNo;
            cancelOrderSubtitle.textContent = 'You are canceling this order. Please share a reason so we can process it.';
            cancelOrderReason.value = '';
            cancelOrderMessage.classList.add('hidden');
            cancelOrderModal.classList.remove('hidden');
            cancelOrderModal.classList.add('flex');
            document.body.classList.add('overflow-hidden');
            setTimeout(() => cancelOrderReason && cancelOrderReason.focus(), 50);
        }

        function closeCancelModal() {
            if (!cancelOrderModal) return;
            activeOrder = null;
            cancelOrderModal.classList.add('hidden');
            cancelOrderModal.classList.remove('flex');
            document.body.classList.remove('overflow-hidden');
        }

        function openCancelSuccessModal(message) {
            if (!cancelSuccessModal) return;
            if (cancelSuccessMessage) {
                cancelSuccessMessage.textContent = message || 'Order canceled successfully.';
            }
            cancelSuccessModal.classList.remove('hidden');
            cancelSuccessModal.classList.add('flex');
            document.body.classList.add('overflow-hidden');
        }

        function closeCancelSuccessModal() {
            if (!cancelSuccessModal) return;
            cancelSuccessModal.classList.add('hidden');
            cancelSuccessModal.classList.remove('flex');
            document.body.classList.remove('overflow-hidden');
        }

        async function cancelActiveOrder() {
            if (!activeOrder) return;

            const auth = getCustomerAuth();
            if (!auth.token) {
                window.location.href = '/auth/customer/signin?redirect=' + encodeURIComponent('/trackorder');
                return;
            }

            const orderId = String(activeOrder.id || '').trim();
            const cancelReason = String(cancelOrderReason?.value || '').trim();
            const customerData = getCustomerData();
            if (!orderId) {
                showCancelMessage('Order id is missing.', true);
                return;
            }

            if (!cancelReason) {
                showCancelMessage('Please enter a cancel reason.', true);
                return;
            }

            if (cancelOrderSubmitBtn) {
                cancelOrderSubmitBtn.disabled = true;
                cancelOrderSubmitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2 text-xs"></i> Canceling';
            }

            try {
                const response = await fetch(apiBase + 'orders/' + encodeURIComponent(orderId) + '/cancel', {
                    method: 'PATCH',
                    headers: {
                        'Accept': 'application/json',
                        'Content-Type': 'application/json',
                        'Authorization': (auth.tokenType || 'Bearer') + ' ' + auth.token
                    },
                    body: JSON.stringify({
                        cancel_reason: cancelReason,
                        customer_id: customerData?.id || activeOrder?.customer_id || null
                    })
                });

                const result = await response.json();

                if (!response.ok || !result?.status) {
                    throw new Error(result?.message || 'Unable to cancel order.');
                }

                showCancelMessage(result?.message || 'Order canceled successfully.', false);
                activeOrder.status = 'canceled';
                setTimeout(() => {
                    closeCancelModal();
                    openCancelSuccessModal(result?.message || 'Order canceled successfully.');
                }, 700);
            } catch (error) {
                console.error('Order cancel error:', error);
                showCancelMessage(error.message || 'Unable to cancel order.', true);
            } finally {
                if (cancelOrderSubmitBtn) {
                    cancelOrderSubmitBtn.disabled = false;
                    cancelOrderSubmitBtn.textContent = 'Cancel Order';
                }
            }
        }

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const orderIdData = document.getElementById('orderId').value.trim();
            if (!orderIdData) return;

            // Reset UI states
            errorMessageContainer.classList.add('hidden');
            defaultPlaceholders.style.display = 'grid';
            dynamicOrderData.classList.add('hidden');
            dynamicOrderData.innerHTML = '';
            
            // Set loading state
            submitBtn.disabled = true;
            submitBtnText.textContent = 'Tracking...';
            
            try {
                const token = localStorage.getItem('customerToken');
                const headersConfig = {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json'
                };
                if (token) {
                    headersConfig['Authorization'] = 'Bearer ' + token;
                }

                const response = await fetch('https://aerthh.newhopeindia17.com/api/track-order', {
                    method: 'POST',
                    headers: headersConfig,
                    body: JSON.stringify({ order_no: orderIdData })
                });
                
                let result;
                try {
                    result = await response.json();
                } catch (jsonError) {
                    throw new Error('Server returned an invalid response (not JSON). Code: ' + response.status);
                }
                
                if (result.status && result.data) {
                    const orderData = result.data;
                    const p = orderData.product;
                    activeOrder = orderData;
                    
                    // Format dates safely
                    const orderDate = orderData.created_at ? new Date(orderData.created_at).toLocaleDateString() : 'N/A';
                    
                    // Parse description safely directly inside template string without breaking html
                    const descStr = p.description ? String(p.description).replace(/<[^>]*>?/gm, '') : '';
                    
                    const discountAmt = parseFloat(p.discount) || 0;
                    const unitPrice = parseFloat(p.unit_price) || 0;
                    const originalPriceHtml = discountAmt > 0 ? 
                        '<span class="text-xs text-slate-400 line-through ml-2">₹' + (unitPrice + discountAmt).toFixed(2) + '</span>' 
                        : '';

                    const allStatuses = ['pending', 'confirmed', 'packaging', 'out for delivery', 'delivered'];
                    const errorStatuses = ['returned', 'failed to deliver', 'canceled'];
                    
                    const currentStatus = (orderData.status || '').toLowerCase();
                    let isErrorState = errorStatuses.includes(currentStatus);
                    let currentIndex = allStatuses.indexOf(currentStatus);
                    
                    // Fallback
                    if (currentIndex === -1 && !isErrorState) {
                         currentIndex = 0; 
                    }

                    // Start of Progress Bar HTML
                    let progressBarHtml = '<div class="w-full relative mt-4 mb-8 col-span-1 md:col-span-2 bg-white p-6 sm:p-8 rounded-[1.1rem] border border-slate-100 shadow-sm animate-fade-in-up flex flex-col items-center overflow-hidden">';
                    progressBarHtml += '<h3 class="w-full text-lg font-bold text-slate-900 border-b border-slate-100 pb-3 mb-8">Tracking Progress</h3>';
                    
                    if (isErrorState) {
                        let errorIcon = currentStatus === 'canceled' ? 'fa-times text-white' : 
                                        currentStatus === 'returned' ? 'fa-undo text-white' : 
                                        'fa-exclamation text-white';
                        let errorColor = currentStatus === 'canceled' ? 'bg-rose-500 border-rose-500' : 
                                         currentStatus === 'returned' ? 'bg-orange-500 border-orange-500' : 
                                         'bg-rose-500 border-rose-500';
                                         
                        progressBarHtml += \`
                            <div class="flex flex-col items-center justify-center py-6 w-full">
                                <div class="w-16 h-16 rounded-full \${errorColor} shadow-md flex items-center justify-center mb-4">
                                    <i class="fas \${errorIcon} text-2xl"></i>
                                </div>
                                <h4 class="text-xl font-bold text-slate-900 capitalize">\${currentStatus}</h4>
                                <p class="text-sm text-slate-500 mt-2 text-center max-w-sm">This order's progress has halted due to being \${currentStatus}. If you need assistance, please contact support.</p>
                            </div>
                        \`;
                    } else {
                        const stepConfig = [
                            { name: 'Pending', icon: 'fa-clock', color: 'bg-amber-400', border: 'border-amber-400' },
                            { name: 'Confirmed', icon: 'fa-check', color: 'bg-blue-400', border: 'border-blue-400' },
                            { name: 'Packaging', icon: 'fa-box', color: 'bg-purple-400', border: 'border-purple-400' },
                            { name: 'Out for delivery', icon: 'fa-truck-fast', color: 'bg-indigo-400', border: 'border-indigo-400' },
                            { name: 'Delivered', icon: 'fa-box-open', color: 'bg-emerald-400', border: 'border-emerald-400' }
                        ];
                        
                        progressBarHtml += '<div class="flex items-center w-full max-w-4xl mx-auto z-10 px-0 sm:px-2">';
                        
                        progressBarHtml += stepConfig.map((step, idx) => {
                            const isPast = idx <= currentIndex;
                            const isCurrent = idx === currentIndex;
                            
                            // Line preceding icon (skipped for first step)
                            const lineHtml = idx === 0 ? '' : \`
                                <div class="flex-1 h-1 \${isPast ? step.color : 'bg-slate-100'} transition-colors duration-500 rounded-full mx-1 sm:mx-2 lg:mx-4 hidden sm:block"></div>
                                <div class="w-2 h-10 border-l-2 \${isPast ? 'border-' + step.color.split('-')[1] + '-400' : 'border-slate-100'} mx-auto block sm:hidden"></div>
                            \`;
                            
                            const iconStyle = isPast ? \`\${step.color} text-white \${step.border} shadow-sm\` : 'bg-white text-slate-300 border-slate-200';
                            const ringStyle = isCurrent && idx < stepConfig.length - 1 ? 'ring-4 ring-sky-50' : '';
                            const textColor = isPast ? 'text-slate-800' : 'text-slate-400';
                            
                            // Mobile wraps stacked differently so we can flex horizontally or display lines vertically if wrapped. 
                            // Using horizontal flex that scales nicely
                            return \`\${idx !== 0 ? \`<div class="flex-1 h-1 \${isPast ? step.color : 'bg-slate-100'} rounded-full mx-0.5 sm:mx-2 transition-colors duration-500"></div>\` : ''}
                            <div class="flex flex-col items-center relative gap-2 shrink-0 w-14 sm:w-20">
                                <div class="w-8 h-8 sm:w-10 sm:h-10 rounded-full flex items-center justify-center transition-all duration-500 border-2 \${iconStyle} \${ringStyle} z-10">
                                    <i class="fas \${step.icon} text-[10px] sm:text-sm"></i>
                                </div>
                                <span class="text-[9px] sm:text-[11px] font-bold \${textColor} text-center uppercase tracking-wider">\${step.name}</span>
                            </div>\`;
                        }).join('');
                        
                        progressBarHtml += '</div>';
                    }
                    
                    progressBarHtml += '</div>';

                    dynamicOrderData.innerHTML = progressBarHtml + \`
                        <div class="rounded-[1.4rem] border border-slate-100 bg-white p-6 sm:p-8 shadow-[0_8px_30px_rgb(0,0,0,0.04)] relative overflow-hidden animate-fade-in-up col-span-1 md:col-span-2" style="animation-delay: 50ms;">
                            <div class="flex items-center justify-between border-b border-slate-100 pb-4 mb-5">
                                <h3 class="text-lg font-bold text-slate-900">Order Information</h3>
                                <span class="bg-slate-50 border border-slate-100 px-3 py-1 rounded-md text-slate-600 font-bold text-sm">#\${orderData.order_no}</span>
                            </div>

                            <!-- Product Summary -->
                            <div class="flex flex-col sm:flex-row gap-5 items-start w-full">
                                <div class="shrink-0 w-24 h-24 sm:w-28 sm:h-28 overflow-hidden rounded-[0.8rem] border border-slate-100 shadow-sm bg-slate-50">
                                    <img src="\${p.image}" alt="\${p.product_name}" class="w-full h-full object-cover">
                                </div>
                                <div class="flex flex-col w-full h-full">
                                    <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-2">
                                        <div>
                                            <h4 class="text-base font-bold text-slate-900 mb-1">\${p.product_name}</h4>
                                            <p class="text-[11px] text-sky-600 font-semibold uppercase tracking-wider mb-1">SKU: \${p.sku}</p>
                                        </div>
                                        <div class="flex flex-col sm:items-end">
                                            <div class="flex gap-2 items-center">
                                                <span class="text-lg font-extrabold text-slate-900">₹\${p.unit_price}</span>
                                                \${originalPriceHtml}
                                            </div>
                                            <span class="text-xs text-slate-500 mt-1 font-medium bg-slate-100 px-2 py-0.5 rounded">Qty: \${orderData.quantity}</span>
                                        </div>
                                    </div>
                                    <div class="text-sm text-slate-600 line-clamp-2 leading-relaxed mt-3">\${descStr}</div>
                                </div>
                            </div>
                            
                            <!-- Order Data Details -->
                            <div class="mt-6 pt-5 border-t border-slate-100 bg-slate-50/60 rounded-xl p-5 sm:p-6">
                                <ul class="grid grid-cols-2 sm:grid-cols-4 gap-y-5 gap-x-6 text-sm text-slate-600 relative z-10 w-full">
                                    <li class="flex flex-col">
                                        <span class="font-medium text-slate-400 text-[10px] sm:text-[11px] uppercase tracking-widest mb-1.5">Status</span>
                                        <span class="inline-flex w-fit items-center rounded-md bg-sky-50 px-2 py-0.5 text-xs font-semibold text-sky-700 ring-1 ring-inset ring-sky-600/20 capitalize">\${orderData.status || 'Processing'}</span>
                                    </li>
                                    <li class="flex flex-col">
                                        <span class="font-medium text-slate-400 text-[10px] sm:text-[11px] uppercase tracking-widest mb-1.5">Order Date</span>
                                        <span class="text-slate-800 font-medium">\${orderDate}</span>
                                    </li>
                                    <li class="flex flex-col">
                                        <span class="font-medium text-slate-400 text-[10px] sm:text-[11px] uppercase tracking-widest mb-1.5">Payment Method</span>
                                        <span class="capitalize text-slate-800 font-medium">\${orderData.payment_status} <span class="text-slate-400 font-normal">(\${orderData.payment_method})</span></span>
                                    </li>
                                    <li class="flex flex-col">
                                        <span class="font-medium text-slate-400 text-[10px] sm:text-[11px] uppercase tracking-widest mb-1.5">Shipping Cost</span>
                                        <span class="text-slate-800 font-medium">₹\${orderData.shipping_cost}</span>
                                    </li>
                                </ul>

                                <div class="mt-5 pt-5 border-t border-slate-200/60 flex justify-between items-center">
                                    <span class="font-bold text-slate-700">Total Amount Payable</span>
                                    <span class="text-xl sm:text-2xl text-sky-600 font-extrabold bg-sky-50 px-3 py-1 rounded-lg">₹\${(parseFloat(orderData.total_price || 0) + parseFloat(orderData.shipping_cost || 0)).toFixed(2)}</span>
                                </div>
                            </div>
                        </div>
                    \`;
                    
                    // Show dynamic section containing result
                    defaultPlaceholders.style.display = 'none';
                    dynamicOrderData.classList.remove('hidden');

                } else {
                    // Show custom message
                    errorMessageText.textContent = result.message || 'Order not found. Please try a different Order ID.';
                    errorMessageContainer.classList.remove('hidden');
                }
            } catch (error) {
                console.error("API Error:", error);
                errorMessageText.textContent = 'Error tracking order. Please try again later.';
                errorMessageContainer.classList.remove('hidden');
            } finally {
                // Remove loading state
                submitBtn.disabled = false;
                submitBtnText.textContent = 'Track Now';
            }
        });

        if (cancelOrderModal) {
            cancelOrderModal.addEventListener('click', (event) => {
                if (event.target === cancelOrderModal) {
                    closeCancelModal();
                }
            });
        }

        if (cancelOrderCloseBtn) {
            cancelOrderCloseBtn.addEventListener('click', closeCancelModal);
        }

        if (cancelOrderDismissBtn) {
            cancelOrderDismissBtn.addEventListener('click', closeCancelModal);
        }

        if (cancelOrderSubmitBtn) {
            cancelOrderSubmitBtn.addEventListener('click', cancelActiveOrder);
        }

        if (cancelSuccessModal) {
            cancelSuccessModal.addEventListener('click', (event) => {
                if (event.target === cancelSuccessModal) {
                    closeCancelSuccessModal();
                }
            });
        }

        if (cancelSuccessOkBtn) {
            cancelSuccessOkBtn.addEventListener('click', closeCancelSuccessModal);
        }

        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape') {
                closeCancelModal();
                closeCancelSuccessModal();
            }
        });
    });
</script>
`; %>

<%- include('../layout/app', { title: title || 'Track Order' , body }) %>
