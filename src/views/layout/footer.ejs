<!-- Chat Support Modal -->
<div id="supportModal"
  class="hidden fixed bottom-24 right-4 sm:bottom-[100px] sm:right-6 z-[3000] w-[340px] h-[400px] sm:h-[500px] max-h-[calc(100vh-120px)] max-w-[calc(100vw-2rem)] origin-bottom-right transition-all duration-300 shadow-[0_12px_40px_-5px_rgba(0,0,0,0.2)] rounded-2xl bg-white overflow-hidden flex flex-col border border-sky-100">
  <div class="bg-gradient-to-r from-sky-500 to-blue-500 p-4 shrink-0 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <div class="flex h-10 w-10 items-center justify-center rounded-full bg-white/20 text-white">
        <i class="fa-solid fa-headset text-lg"></i>
      </div>
      <div>
        <h3 class="font-bold text-white text-base">Support Center</h3>
        <p class="text-xs text-sky-100" id="supportStatus">Loading...</p>
      </div>
    </div>
    <button onclick="document.getElementById('supportModal').classList.add('hidden')"
      class="flex h-8 w-8 items-center justify-center rounded-full bg-white/10 text-white transition-colors hover:bg-white/20">
      <i class="fa-solid fa-times"></i>
    </button>
  </div>

  <div class="p-4 bg-[linear-gradient(180deg,#f8fcff_0%,#eef7ff_100%)] flex-1 space-y-3 overflow-y-auto"
    id="chatMessages">
    <!-- Messages will be injected here -->
  </div>

  <!-- Chat Input -->
  <div class="border-t border-sky-100 bg-white p-3 shrink-0">
    <div id="chatLoginNotice" class="hidden text-center text-xs text-slate-500 py-1 mb-2">
      <i class="fa-solid fa-lock mr-1 text-sky-400"></i> Please <a href="/signin"
        class="font-semibold text-sky-600 hover:underline">login</a> to send messages.
    </div>
    <form id="chatForm" class="flex items-center gap-2" onsubmit="handleChatSend(event)">
      <input id="chatInput" type="text" placeholder="Type your message..."
        class="flex-1 rounded-full border border-slate-200 bg-slate-50 px-4 py-2 text-sm text-slate-700 outline-none transition-all focus:border-sky-400 focus:bg-white focus:ring-2 focus:ring-sky-100">
      <button type="submit" id="chatSendBtn"
        class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-gradient-to-r from-sky-500 to-blue-500 text-white shadow-md transition-transform hover:-translate-y-0.5 hover:shadow-lg focus:outline-none focus:ring-2 focus:ring-sky-400 focus:ring-offset-2">
        <i class="fa-solid fa-paper-plane text-sm"></i>
      </button>
    </form>
  </div>
</div>

<script>
  const CHAT_API_BASE = 'https://aerthh.newhopeindia17.com/api';

  function getChatToken() {
    try {
      return localStorage.getItem('customerToken') || '';
    } catch (error) {
      return '';
    }
  }

  function appendMessage(msg) {
    const container = document.getElementById('chatMessages');
    const isCustomer = msg.sender_type === 'customer';

    const time = new Date(msg.created_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

    const wrapper = document.createElement('div');
    wrapper.className = isCustomer ? 'flex justify-end gap-2' : 'flex gap-2.5';

    if (!isCustomer) {
      wrapper.innerHTML = `
        <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-sky-500 to-blue-500 text-white shadow-sm mt-1">
          <i class="fa-solid fa-headset text-[10px]"></i>
        </div>
      `;
    }

    const bubble = document.createElement('div');
    bubble.className = isCustomer
      ? 'bg-gradient-to-br from-sky-500 to-blue-500 text-white p-3 rounded-2xl rounded-tr-sm shadow-sm text-sm max-w-[80%] leading-relaxed'
      : 'bg-white p-3 rounded-2xl rounded-tl-sm border border-sky-100 shadow-sm text-sm text-slate-700 max-w-[80%] leading-relaxed';

    bubble.innerHTML = `<p>${msg.message}</p><span class="block text-[10px] mt-1 ${isCustomer ? 'text-sky-100' : 'text-slate-400'} text-right">${time}</span>`;

    wrapper.appendChild(bubble);
    container.appendChild(wrapper);
    container.scrollTop = container.scrollHeight;
  }

  function appendSystemMessage(text) {
    const container = document.getElementById('chatMessages');
    const div = document.createElement('div');
    div.className = 'text-center text-xs text-slate-400 py-1';
    div.textContent = text;
    container.appendChild(div);
    container.scrollTop = container.scrollHeight;
  }

  function appendSupportGreeting() {
    const container = document.getElementById('chatMessages');
    const wrapper = document.createElement('div');
    wrapper.className = 'flex gap-2.5';
    wrapper.innerHTML = `
      <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-sky-500 to-blue-500 text-white shadow-sm mt-1">
        <i class="fa-solid fa-headset text-[10px]"></i>
      </div>
      <div class="bg-white p-3 rounded-2xl rounded-tl-sm border border-sky-100 shadow-sm text-sm text-slate-700 max-w-[80%] leading-relaxed">
        Hi there! 👋<br/>How can we help you today?
      </div>
    `;
    container.appendChild(wrapper);
    container.scrollTop = container.scrollHeight;
  }

  async function loadChatHistory() {
    const token = getChatToken();
    const status = document.getElementById('supportStatus');
    if (!token) {
      status.textContent = 'Please login to chat';
      document.getElementById('chatLoginNotice').classList.remove('hidden');
      document.getElementById('chatInput').disabled = true;
      document.getElementById('chatSendBtn').disabled = true;
      appendSupportGreeting();
      return;
    }

    status.textContent = 'Loading history...';
    try {
      const res = await fetch(`${CHAT_API_BASE}/chat/history`, {
        headers: { 'Authorization': `Bearer ${token}`, 'Accept': 'application/json' }
      });
      const data = await res.json();
      const container = document.getElementById('chatMessages');
      container.innerHTML = '';

      // Support ki side se by default greeting humesha sabse pehle dikhega
      appendSupportGreeting();

      if (data.success && data.data && data.data.length > 0) {
        data.data.forEach(appendMessage);
        status.textContent = 'We\'re here to help';
      } else {
        status.textContent = 'Typically replies in minutes';
      }
    } catch (e) {
      const container = document.getElementById('chatMessages');
      container.innerHTML = '';
      appendSupportGreeting();
      status.textContent = 'Typically replies in minutes';
    }
  }

  async function handleChatSend(e) {
    e.preventDefault();
    const input = document.getElementById('chatInput');
    const btn = document.getElementById('chatSendBtn');
    const message = input.value.trim();
    if (!message) return;

    const token = getChatToken();
    if (!token) {
      document.getElementById('chatLoginNotice').classList.remove('hidden');
      return;
    }

    // Optimistically show message
    appendMessage({ sender_type: 'customer', message, created_at: new Date().toISOString() });
    input.value = '';
    btn.disabled = true;
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin text-sm"></i>';

    try {
      const res = await fetch(`${CHAT_API_BASE}/chat/send`, {
        method: 'POST',
        headers: {
          'Authorization': `Bearer ${token}`,
          'Accept': 'application/json',
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ message })
      });
      const data = await res.json();
      console.log('Chat API Response:', res.status, data);
      if (!res.ok || !data.success) {
        const errMsg = data.message || data.error || JSON.stringify(data.errors) || 'Failed to send';
        appendSystemMessage(`⚠️ ${errMsg}`);
      }
    } catch (err) {
      console.error('Chat send error:', err);
      appendSystemMessage('⚠️ Network error. Please check your connection.');
    } finally {
      btn.disabled = false;
      btn.innerHTML = '<i class="fa-solid fa-paper-plane text-sm"></i>';
    }
  }

  // Open modal and load history
  document.querySelector('[onclick*="supportModal"]').addEventListener('click', function () {
    const container = document.getElementById('chatMessages');
    if (container.children.length === 0) {
      loadChatHistory();
    }
  });
</script>