  <script src="https://cdn.jsdelivr.net/npm/alpinejs@2.8.2/dist/alpine.min.js" defer></script>
  <script>
    (function () {
      const avatarEl = document.getElementById('headerUserAvatar');
      const iconEl = document.getElementById('headerUserIcon');
      const signInLink = document.getElementById('headerSignInLink');
      const signUpLink = document.getElementById('headerSignUpLink');
      const ordersLink = document.getElementById('headerOrdersLink');
      const logoutButton = document.getElementById('headerLogoutButton');
      const headerCartTotal = document.getElementById('headerCartTotal');
      const headerCartDropdownContent = document.getElementById('headerCartDropdownContent');
      const headerWishlistCount = document.getElementById('headerWishlistCount');
      let currentHeaderCartItems = [];
      let currentHeaderWishlistItems = [];
      let removingHeaderProductId = '';

      if (!avatarEl || !iconEl || !signInLink || !signUpLink || !ordersLink || !logoutButton || !headerCartTotal || !headerCartDropdownContent || !headerWishlistCount) return;

      function getImageFromUserData() {
        const storageKeys = ['userData', 'customerData', 'authData'];

        for (const key of storageKeys) {
          const rawValue = localStorage.getItem(key);
          if (!rawValue) continue;

          try {
            const parsed = JSON.parse(rawValue);
            const candidates = [
              parsed?.profile_image,
              parsed?.image,
              parsed?.avatar,
              parsed?.profile_image_url,
              parsed?.customer?.profile_image,
              parsed?.customer?.image,
              parsed?.customer?.avatar,
              parsed?.data?.profile_image,
              parsed?.data?.image,
              parsed?.data?.avatar
            ];

            const matchedImage = candidates.find((value) => typeof value === 'string' && value.trim());
            if (matchedImage) return matchedImage;
          } catch (error) {
            console.error('Unable to parse stored user data:', error);
          }
        }

        return '';
      }

      function setLoggedInState(profileImage) {
        signInLink.classList.add('hidden');
        signUpLink.classList.add('hidden');
        ordersLink.classList.remove('hidden');
        logoutButton.classList.remove('hidden');

        if (profileImage) {
          avatarEl.src = profileImage;
          avatarEl.classList.remove('hidden');
          iconEl.classList.add('hidden');
        } else {
          avatarEl.classList.add('hidden');
          iconEl.classList.remove('hidden');
        }
      }

      function setLoggedOutState() {
        avatarEl.src = '';
        avatarEl.classList.add('hidden');
        iconEl.classList.remove('hidden');
        signInLink.classList.remove('hidden');
        signUpLink.classList.remove('hidden');
        ordersLink.classList.add('hidden');
        logoutButton.classList.add('hidden');
      }

      function getCustomerAuth() {
        try {
          return {
            token: localStorage.getItem('customerToken') || '',
            tokenType: localStorage.getItem('tokenType') || 'Bearer'
          };
        } catch (error) {
          return { token: '', tokenType: 'Bearer' };
        }
      }

      function getClearedCartItemIds() {
        try {
          const parsed = JSON.parse(localStorage.getItem('clearedCartItemIds') || '[]');
          return Array.isArray(parsed) ? parsed.map(function (value) { return String(value); }) : [];
        } catch (error) {
          return [];
        }
      }

      function getVisibleCartItems(items) {
        const clearedIds = getClearedCartItemIds();
        if (!clearedIds.length) return Array.isArray(items) ? items : [];
        return (Array.isArray(items) ? items : []).filter(function (item) {
          const cartItemId = String(item?.id || '');
          const productId = String(item?.product?.id || item?.product_id || '');
          return !clearedIds.includes(cartItemId) && !clearedIds.includes(productId);
        });
      }

      function setClearedCartItem(productId) {
        if (!productId) return;

        try {
          const existing = getClearedCartItemIds();
          const normalizedId = String(productId);
          if (existing.includes(normalizedId)) return;
          localStorage.setItem('clearedCartItemIds', JSON.stringify(existing.concat(normalizedId)));
        } catch (error) {
          console.warn('Unable to update cleared cart item ids:', error);
        }
      }

      function escapeHtml(value) {
        return String(value || '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      }

      function formatMoney(value) {
        return new Intl.NumberFormat('en-IN', {
          style: 'currency',
          currency: 'INR',
          minimumFractionDigits: 2,
          maximumFractionDigits: 2
        }).format(Number(value || 0));
      }

      function calculateLineTotal(item) {
        const product = item?.product || {};
        const quantity = Number(item?.quantity || 0);
        const unitPrice = Number(product?.unit_price || 0);
        const discountValue = Number(product?.discount || 0);
        const discountType = product?.discount_type || '';
        const shippingCost = Number(product?.shipping_cost || 0);
        const taxAmount = Number(product?.tax_amount || 0);
        const finalUnitPrice = discountValue > 0
          ? (discountType === 'percent'
            ? unitPrice - ((unitPrice * discountValue) / 100)
            : Math.max(unitPrice - discountValue, 0))
          : unitPrice;

        return ((finalUnitPrice + taxAmount + shippingCost) * quantity);
      }

      function renderHeaderCart(items) {
        currentHeaderCartItems = getVisibleCartItems(items);
        const visibleItems = currentHeaderCartItems;

        if (!visibleItems.length) {
          headerCartTotal.textContent = '0.00';
          headerCartDropdownContent.innerHTML = ''
            + '<div class="text-center py-4">'
            + '<i class="fas fa-shopping-bag text-gray-300 text-4xl mb-2"></i>'
            + '<p class="text-gray-500 text-sm">Your cart is empty</p>'
            + '<a href="/products" class="inline-block mt-3 px-4 py-2 bg-sky-500 text-white text-sm rounded-lg hover:bg-sky-600 transition-colors duration-200">Start Shopping</a>'
            + '</div>';
          return;
        }

        const cartTotal = visibleItems.reduce(function (sum, item) {
          return sum + calculateLineTotal(item);
        }, 0);

        headerCartTotal.textContent = formatMoney(cartTotal);
        headerCartDropdownContent.innerHTML = ''
          + '<div class="space-y-3">'
          + visibleItems.slice(0, 3).map(function (item) {
            const product = item?.product || {};
            const productId = product?.id || item?.product_id || '';
            const image = product?.image || 'https://via.placeholder.com/80x80/eef7ff/64748b?text=Item';
            const title = product?.product_name || 'Product';
            const quantity = Number(item?.quantity || 0);
            const isRemoving = String(removingHeaderProductId) === String(productId);
            return ''
              + '<div class="flex items-center gap-2 rounded-xl border border-sky-100 bg-sky-50/40 p-2">'
              + '<a href="/products/buy?id=' + encodeURIComponent(String(productId)) + '" class="flex min-w-0 flex-1 items-center gap-3 transition hover:opacity-90">'
              + '<img src="' + escapeHtml(image) + '" alt="' + escapeHtml(title) + '" class="h-12 w-12 rounded-lg object-contain bg-white ring-1 ring-sky-100">'
              + '<div class="min-w-0 flex-1">'
              + '<p class="truncate text-sm font-semibold text-slate-800">' + escapeHtml(title) + '</p>'
              + '<p class="mt-1 text-xs text-slate-500">Qty: ' + quantity + '</p>'
              + '</div>'
              + '</a>'
              + '<button type="button" class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-lg border border-rose-200 bg-white text-rose-500 transition hover:bg-rose-50 disabled:cursor-not-allowed disabled:opacity-60" data-header-remove-cart-item="' + escapeHtml(productId) + '" aria-label="Remove item from cart" title="Remove" ' + (isRemoving ? 'disabled' : '') + '>'
              + '<i class="fas ' + (isRemoving ? 'fa-spinner fa-spin' : 'fa-trash-alt') + ' text-sm"></i>'
              + '</button>'
              + '</div>';
          }).join('')
          + '<a href="/cart" class="inline-flex w-full items-center justify-center rounded-lg bg-sky-500 px-4 py-2 text-sm font-semibold text-white transition hover:bg-sky-600">View Cart</a>'
          + '</div>';
      }

      function renderHeaderWishlist(items) {
        currentHeaderWishlistItems = Array.isArray(items) ? items : [];
        headerWishlistCount.textContent = String(currentHeaderWishlistItems.length);
      }

      async function removeHeaderCartItem(productId) {
        const normalizedProductId = String(productId || '').trim();
        if (!normalizedProductId || removingHeaderProductId) return;

        const auth = getCustomerAuth();
        if (!auth.token) {
          window.location.href = '/auth/customer/signin?redirect=' + encodeURIComponent('/cart');
          return;
        }

        removingHeaderProductId = normalizedProductId;
        renderHeaderCart(currentHeaderCartItems);

        try {
          const response = await fetch('https://aerthh.newhopeindia17.com/api/cart/remove/' + encodeURIComponent(normalizedProductId), {
            method: 'DELETE',
            headers: {
              'Accept': 'application/json',
              'Authorization': (auth.tokenType || 'Bearer') + ' ' + auth.token
            }
          });

          const result = await response.json();
          if (!response.ok || !result?.status) {
            throw new Error(result?.message || 'Unable to remove product from cart.');
          }

          setClearedCartItem(normalizedProductId);
          currentHeaderCartItems = currentHeaderCartItems.filter(function (item) {
            const itemProductId = item?.product?.id || item?.product_id || '';
            return String(itemProductId) !== normalizedProductId;
          });
          removingHeaderProductId = '';
          renderHeaderCart(currentHeaderCartItems);
          window.dispatchEvent(new CustomEvent('cart:updated', {
            detail: {
              items: currentHeaderCartItems
            }
          }));
        } catch (error) {
          removingHeaderProductId = '';
          renderHeaderCart(currentHeaderCartItems);
          console.error('Header cart remove error:', error);
        }
      }

      async function loadHeaderCart() {
        const auth = getCustomerAuth();
        if (!auth.token) {
          renderHeaderCart([]);
          return;
        }

        try {
          const response = await fetch('https://aerthh.newhopeindia17.com/api/cart', {
            method: 'GET',
            headers: {
              'Accept': 'application/json',
              'Authorization': (auth.tokenType || 'Bearer') + ' ' + auth.token
            }
          });

          const result = await response.json();
          if (!response.ok || !result?.status) {
            throw new Error(result?.message || 'Unable to fetch cart.');
          }

          renderHeaderCart(Array.isArray(result?.data) ? result.data : []);
        } catch (error) {
          console.error('Header cart fetch error:', error);
          renderHeaderCart([]);
        }
      }

      async function loadHeaderWishlist() {
        const auth = getCustomerAuth();
        if (!auth.token) {
          renderHeaderWishlist([]);
          return;
        }

        try {
          const response = await fetch('https://aerthh.newhopeindia17.com/api/wishlist', {
            method: 'GET',
            headers: {
              'Accept': 'application/json',
              'Authorization': (auth.tokenType || 'Bearer') + ' ' + auth.token
            }
          });

          const result = await response.json();
          if (!response.ok || !result?.status) {
            throw new Error(result?.message || 'Unable to fetch wishlist.');
          }

          renderHeaderWishlist(Array.isArray(result?.data) ? result.data : []);
        } catch (error) {
          console.error('Header wishlist fetch error:', error);
          renderHeaderWishlist([]);
        }
      }

      window.addEventListener('cart:updated', function (event) {
        const items = event?.detail?.items;
        if (Array.isArray(items)) {
          renderHeaderCart(items);
          return;
        }

        loadHeaderCart();
      });

      window.addEventListener('wishlist:updated', function () {
        loadHeaderWishlist();
      });

      const hasStoredSession = !!(localStorage.getItem('userData') || localStorage.getItem('customerData') || localStorage.getItem('authData'));
      const profileImage = getImageFromUserData();

      if (hasStoredSession) {
        setLoggedInState(profileImage);
      } else {
        setLoggedOutState();
      }

      loadHeaderCart();
      loadHeaderWishlist();

      headerCartDropdownContent.addEventListener('click', function (event) {
        const removeButton = event.target.closest('[data-header-remove-cart-item]');
        if (!removeButton) return;

        event.preventDefault();
        event.stopPropagation();
        const productId = removeButton.getAttribute('data-header-remove-cart-item') || '';
        removeHeaderCartItem(productId);
      });

      logoutButton.addEventListener('click', function () {
        localStorage.removeItem('userData');
        localStorage.removeItem('customerData');
        localStorage.removeItem('authData');
        localStorage.removeItem('customerToken');
        localStorage.removeItem('tokenType');
        localStorage.removeItem('clearedCartItemIds');
        setLoggedOutState();
        renderHeaderCart([]);
        window.location.href = '/';
      });
    })();
  </script>
</div>
