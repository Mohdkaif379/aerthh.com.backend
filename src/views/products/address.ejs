  <script>
    (function () {
      const sameAsShippingCheckbox = document.getElementById('sameAsShippingCheckbox');
      const billingAddressFields = document.getElementById('billingAddressFields');
      const billingRequiredFields = Array.from(document.querySelectorAll('[data-billing-required="true"]'));
      const checkoutAddressForm = document.getElementById('checkoutAddressForm');
      const checkoutPath = window.location.pathname + window.location.search;
      const productId = ${JSON.stringify(String(item?.id || ''))};
      const quantity = ${JSON.stringify(quantity)};
      const submitBtn = document.querySelector('button[form="checkoutAddressForm"]');
      const messageBox = document.getElementById('addressFormMessage');
      const savedAddressesSection = document.getElementById('savedAddressesSection');
      const savedAddressesList = document.getElementById('savedAddressesList');
      const manualAddressFields = document.getElementById('manualAddressFields');
      const manualAddressHeader = document.getElementById('manualAddressHeader');
      const showNewAddressFormBtn = document.getElementById('showNewAddressFormBtn');
      const backToSavedAddressesBtn = document.getElementById('backToSavedAddressesBtn');
      const manualAddressInputs = Array.from(document.querySelectorAll('#manualAddressFields input'));
      let savedAddresses = [];
      let selectedSavedAddressId = null;
      let isManualEntryMode = false;

      function hasCustomerSession() {
        try {
          return !!(
            localStorage.getItem('customerToken') ||
            localStorage.getItem('authData') ||
            localStorage.getItem('customerData') ||
            localStorage.getItem('userData')
          );
        } catch (error) {
          return false;
        }
      }

      if (!hasCustomerSession()) {
        window.location.replace('/auth/customer/signin?redirect=' + encodeURIComponent(checkoutPath));
        return;
      }

      if (!sameAsShippingCheckbox || !billingAddressFields || !checkoutAddressForm) return;

      function showMessage(text, isError) {
        if (!messageBox) return;
        messageBox.textContent = text;
        messageBox.className = 'rounded-xl px-4 py-3 text-sm ' + (isError
          ? 'border border-rose-200 bg-rose-50 text-rose-600'
          : 'border border-sky-200 bg-sky-50 text-sky-700');
        messageBox.classList.remove('hidden');
      }

      function getCustomerAuth() {
        try {
          const token = localStorage.getItem('customerToken') || '';
          const tokenType = localStorage.getItem('tokenType') || 'Bearer';
          const customerData = JSON.parse(localStorage.getItem('customerData') || localStorage.getItem('userData') || '{}');
          return {
            token,
            tokenType,
            customerData
          };
        } catch (error) {
          return {
            token: '',
            tokenType: 'Bearer',
            customerData: {}
          };
        }
      }

      function getAddressPayload(prefix) {
        return {
          type: prefix,
          first_name: document.getElementById(prefix + 'FirstName').value.trim(),
          last_name: document.getElementById(prefix + 'LastName').value.trim(),
          email: document.getElementById(prefix + 'Email').value.trim(),
          phone: document.getElementById(prefix + 'Phone').value.trim(),
          address_line: document.getElementById(prefix + 'AddressLine').value.trim(),
          city: document.getElementById(prefix + 'City').value.trim(),
          state: document.getElementById(prefix + 'State').value.trim(),
          zip_code: document.getElementById(prefix + 'ZipCode').value.trim(),
          country: document.getElementById(prefix + 'Country').value.trim() || 'India'
        };
      }

      async function createAddress(payload, auth) {
        const response = await fetch('https://aerthh.newhopeindia17.com/api/address/create', {
          method: 'POST',
          headers: {
            'Accept': 'application/json',
            'Content-Type': 'application/json',
            'Authorization': (auth.tokenType || 'Bearer') + ' ' + auth.token
          },
          body: JSON.stringify(payload)
        });

        const result = await response.json();

        if (!response.ok || !result?.status) {
          throw new Error(result?.message || result?.error || 'Unable to save address.');
        }

        return result;
      }

      async function fetchSavedAddresses(auth) {
        const response = await fetch('https://aerthh.newhopeindia17.com/api/addresses', {
          method: 'GET',
          headers: {
            'Accept': 'application/json',
            'Authorization': (auth.tokenType || 'Bearer') + ' ' + auth.token
          }
        });

        const result = await response.json();

        if (!response.ok || !result?.status) {
          throw new Error(result?.message || result?.error || 'Unable to load saved addresses.');
        }

        return Array.isArray(result?.data) ? result.data : [];
      }

      async function deleteSavedAddress(addressId, auth) {
        const response = await fetch('https://aerthh.newhopeindia17.com/api/address/' + encodeURIComponent(String(addressId)), {
          method: 'DELETE',
          headers: {
            'Accept': 'application/json',
            'Authorization': (auth.tokenType || 'Bearer') + ' ' + auth.token
          }
        });

        const result = await response.json();

        if (!response.ok || !result?.status) {
          throw new Error(result?.message || result?.error || 'Unable to delete address.');
        }

        return result;
      }

      function renderSavedAddresses(addresses) {
        if (!savedAddressesList) return;

        savedAddressesList.innerHTML = addresses.map(function (address, index) {
          const fullName = [address.first_name, address.last_name].filter(Boolean).join(' ');
          const cityStateZip = [address.city, address.state, address.zip_code].filter(Boolean).join(', ');
          return ''
            + '<div class="saved-address-option group rounded-[0.95rem] border border-sky-200 bg-white px-4 py-4 transition hover:border-sky-300 hover:bg-sky-50/60">'
            +   '<div class="flex items-start gap-3">'
            +   '<input type="radio" name="selectedSavedAddress" value="' + String(address.id || '') + '" ' + (index === 0 ? 'checked' : '') + ' class="mt-1 h-4 w-4 border-sky-300 text-sky-500 focus:ring-sky-400">'
            +   '<div class="min-w-0 flex-1">'
            +     '<div class="flex flex-wrap items-center justify-between gap-2">'
            +       '<p class="text-sm font-semibold text-slate-900">' + (fullName || 'Address') + '</p>'
            +       '<div class="flex items-center gap-2">'
            +         '<span class="rounded-full bg-sky-50 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.14em] text-sky-700 ring-1 ring-sky-100">' + String(address.type || 'shipping') + '</span>'
            +         '<button type="button" data-address-delete="' + String(address.id || '') + '" class="opacity-0 pointer-events-none rounded-full bg-rose-50 p-2 text-xs text-rose-600 ring-1 ring-rose-100 transition group-hover:opacity-100 group-hover:pointer-events-auto hover:bg-rose-100" aria-label="Delete address">'
            +           '<i class="fas fa-trash-alt"></i>'
            +         '</button>'
            +       '</div>'
            +     '</div>'
            +     (address.phone ? '<p class="mt-1 text-xs font-medium text-slate-600">' + address.phone + '</p>' : '')
            +     '<div class="mt-2 text-sm leading-6 text-slate-600">'
            +       '<p>' + (address.address_line || '') + '</p>'
            +       (cityStateZip ? '<p>' + cityStateZip + '</p>' : '')
            +       (address.country ? '<p>' + address.country + '</p>' : '')
            +     '</div>'
            +   '</div>'
            +   '</div>'
            + '</div>';
        }).join('');

        selectedSavedAddressId = addresses[0] ? Number(addresses[0].id) : null;
        Array.from(document.querySelectorAll('input[name="selectedSavedAddress"]')).forEach(function (input) {
          input.addEventListener('change', function () {
            selectedSavedAddressId = Number(this.value);
            syncSavedAddressSelection();
          });
        });
        Array.from(document.querySelectorAll('[data-address-delete]')).forEach(function (button) {
          button.addEventListener('click', async function (event) {
            event.preventDefault();
            event.stopPropagation();

            const addressId = Number(this.getAttribute('data-address-delete'));
            const auth = getCustomerAuth();
            if (!addressId || !auth.token) return;

            const originalText = this.textContent;
            this.disabled = true;
            this.textContent = 'Deleting...';

            try {
              await deleteSavedAddress(addressId, auth);
              savedAddresses = savedAddresses.filter(function (address) {
                return Number(address.id) !== addressId;
              });

              if (savedAddresses.length > 0) {
                toggleAddressMode(true, false);
                renderSavedAddresses(savedAddresses);
                showMessage('Address deleted successfully.', false);
              } else {
                selectedSavedAddressId = null;
                toggleAddressMode(false, true);
                showMessage('Address deleted successfully. Please add a new address to continue.', false);
              }
            } catch (error) {
              console.error('Delete address error:', error);
              showMessage(error.message || 'Unable to delete address. Please try again.', true);
              this.disabled = false;
              this.textContent = originalText;
            }
          });
        });
        syncSavedAddressSelection();
      }

      function syncSavedAddressSelection() {
        document.querySelectorAll('.saved-address-option').forEach(function (option) {
          const radio = option.querySelector('input[name="selectedSavedAddress"]');
          const isActive = !!(radio && radio.checked);
          option.classList.toggle('border-sky-400', isActive);
          option.classList.toggle('bg-sky-50', isActive);
        });
      }

      function toggleAddressMode(hasSavedAddresses, showManualEntry) {
        const useManualEntry = !hasSavedAddresses || !!showManualEntry;
        if (savedAddressesSection) {
          savedAddressesSection.classList.toggle('hidden', !hasSavedAddresses || useManualEntry);
        }
        if (manualAddressFields) {
          manualAddressFields.classList.toggle('hidden', hasSavedAddresses && !useManualEntry);
        }
        if (manualAddressHeader) {
          manualAddressHeader.classList.toggle('hidden', !hasSavedAddresses || !useManualEntry);
          manualAddressHeader.classList.toggle('flex', hasSavedAddresses && useManualEntry);
        }
        manualAddressInputs.forEach(function (input) {
          if (hasSavedAddresses && !useManualEntry) {
            input.dataset.wasRequired = input.required ? 'true' : 'false';
            input.required = false;
          } else if (input.dataset.wasRequired === 'true') {
            input.required = true;
          }
        });
        isManualEntryMode = useManualEntry;
      }

      function syncBillingVisibility() {
        billingAddressFields.classList.toggle('hidden', sameAsShippingCheckbox.checked);
        billingRequiredFields.forEach(function (field) {
          field.required = !sameAsShippingCheckbox.checked;
          if (sameAsShippingCheckbox.checked) {
            field.setCustomValidity('');
          }
        });
      }

      sameAsShippingCheckbox.addEventListener('change', syncBillingVisibility);
      if (showNewAddressFormBtn) {
        showNewAddressFormBtn.addEventListener('click', function () {
          toggleAddressMode(savedAddresses.length > 0, true);
          showMessage('Enter a new address to continue.', false);
        });
      }
      if (backToSavedAddressesBtn) {
        backToSavedAddressesBtn.addEventListener('click', function () {
          toggleAddressMode(savedAddresses.length > 0, false);
          showMessage('Select a saved address to continue.', false);
        });
      }
      checkoutAddressForm.addEventListener('submit', async function (event) {
        event.preventDefault();

        const auth = getCustomerAuth();
        if (!auth.token) {
          window.location.replace('/auth/customer/signin?redirect=' + encodeURIComponent(checkoutPath));
          return;
        }

        if (savedAddresses.length > 0 && !isManualEntryMode) {
          const selectedAddress = savedAddresses.find(function (address) {
            return Number(address.id) === Number(selectedSavedAddressId);
          });

          if (!selectedAddress) {
            showMessage('Please select an address to continue.', true);
            return;
          }

          sessionStorage.setItem('checkoutState', JSON.stringify({
            productId,
            qty: quantity,
            customerId: auth.customerData?.id || selectedAddress?.customer_id || null,
            shippingAddress: { ...selectedAddress, type: 'shipping' },
            billingAddress: { ...selectedAddress, type: 'billing' },
            sameAsShipping: true
          }));

          showMessage('Saved address selected. Redirecting to checkout...', false);
          window.location.href = '/checkout?id=' + encodeURIComponent(productId) + '&qty=' + encodeURIComponent(String(quantity));
          return;
        }

        if (!checkoutAddressForm.checkValidity()) {
          checkoutAddressForm.reportValidity();
          return;
        }

        const originalBtnText = submitBtn ? submitBtn.innerHTML : '';
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2 text-xs"></i> Saving Address';
        }

        try {
          const shippingResult = await createAddress({
            ...getAddressPayload('shipping'),
            type: 'shipping'
          }, auth);

          let billingResult = null;
          if (!sameAsShippingCheckbox.checked) {
            billingResult = await createAddress({
              ...getAddressPayload('billing'),
              type: 'billing'
            }, auth);
          }

          sessionStorage.setItem('checkoutState', JSON.stringify({
            productId,
            qty: quantity,
            customerId: auth.customerData?.id || shippingResult?.data?.customer_id || null,
            shippingAddress: shippingResult?.data || null,
            billingAddress: sameAsShippingCheckbox.checked
              ? (shippingResult?.data ? { ...shippingResult.data, type: 'billing' } : null)
              : (billingResult?.data || null),
            sameAsShipping: sameAsShippingCheckbox.checked
          }));

          showMessage(shippingResult?.message || 'Address saved successfully. Redirecting to checkout...', false);
          window.location.href = '/checkout?id=' + encodeURIComponent(productId) + '&qty=' + encodeURIComponent(String(quantity));
        } catch (error) {
          console.error('Address save error:', error);
          showMessage(error.message || 'Unable to save address. Please try again.', true);
        } finally {
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalBtnText;
          }
        }
      });
      syncBillingVisibility();

      (async function initSavedAddresses() {
        const auth = getCustomerAuth();
        if (!auth.token) return;

        try {
          savedAddresses = await fetchSavedAddresses(auth);
          if (savedAddresses.length > 0) {
            toggleAddressMode(true, false);
            renderSavedAddresses(savedAddresses);
            showMessage('Saved addresses found. Select one to continue to checkout.', false);
          } else {
            toggleAddressMode(false, true);
          }
        } catch (error) {
          console.error('Saved addresses fetch error:', error);
          toggleAddressMode(false, true);
        }
      })();
    })();
  </script>
  `; %>

<%- include('../layout/app', { title: title || 'Address', body }) %>
