<%
  const item = typeof product !== 'undefined' ? product : null;
  const requestedProductId = String(typeof selectedProductId !== 'undefined' ? selectedProductId : '');
  const error = typeof errorMessage !== 'undefined' ? errorMessage : '';
  const relatedItems = typeof similarProducts !== 'undefined' && Array.isArray(similarProducts) ? similarProducts : [];

  const titleText = item?.product_name || 'Product';
  const mainImage = item?.image || '';
  const brandName = item?.brand?.name || 'Brand';
  const brandImage = item?.brand?.image
    ? (String(item.brand.image).startsWith('http') ? item.brand.image : `https://aerthh.newhopeindia17.com/public/brand/${item.brand.image}`)
    : 'https://aerthh.com/storage/app/public/company/2025-03-26-67e3da8f9b411.webp';
  const vendorDetails = typeof vendor !== 'undefined' && vendor ? vendor : null;
  const vendorId = String(vendorDetails?.id || vendorDetails?.vendor_id || item?.vendor_id || item?.vendor?.id || item?.vendor?.vendor_id || '').trim();
  const vendorName = vendorDetails?.name || item?.vendor?.name || 'Vendor';
  const vendorImage = vendorDetails?.image
    ? (String(vendorDetails.image).startsWith('http') ? vendorDetails.image : `https://aerthh.newhopeindia17.com/storage/app/public/vendors/images/${vendorDetails.image}`)
    : (item?.vendor?.image || 'https://via.placeholder.com/300x300/eef7ff/0369a1?text=Vendor');
  const vendorLocation = [vendorDetails?.city || item?.vendor?.city || '', vendorDetails?.state || item?.vendor?.state || ''].filter(Boolean).join(', ');
  const vendorStatus = vendorDetails?.status ? 'Active Seller' : 'Seller';
  const vendorBadge = vendorDetails?.status ? 'Verified' : 'Pending';
  const rawDescription = item?.description || '';
  const cleanDescription = String(rawDescription)
    .replace(/<br\s*\/?>/gi, '\n')
    .replace(/<\/p>\s*<p>/gi, '\n\n')
    .replace(/<[^>]*>/g, '')
    .replace(/\n{3,}/g, '\n\n')
    .trim();
  const additionalImages = Array.isArray(item?.additional_image)
    ? item.additional_image.filter(Boolean)
    : typeof item?.additional_image === 'string'
      ? (() => {
          try {
            const parsed = JSON.parse(item.additional_image);
            return Array.isArray(parsed) ? parsed.filter(Boolean) : [];
          } catch (error) {
            return item.additional_image ? [item.additional_image] : [];
          }
        })()
      : [];
  const galleryImages = [mainImage].concat(additionalImages).filter(Boolean);

  const unitPriceNumber = Number(item?.unit_price || 0);
  const discountValue = Number(item?.discount || 0);
  const taxAmountNumber = Number(item?.tax_amount || 0);
  const discountType = item?.discount_type || '';
  const finalPriceNumber = discountValue > 0
    ? (discountType === 'percent'
        ? unitPriceNumber - ((unitPriceNumber * discountValue) / 100)
        : Math.max(unitPriceNumber - discountValue, 0))
    : unitPriceNumber;
  const totalWithTaxNumber = finalPriceNumber + taxAmountNumber;
  const formatMoney = (value) => new Intl.NumberFormat('en-IN', {
    style: 'currency',
    currency: 'INR',
    minimumFractionDigits: 2,
    maximumFractionDigits: 2
  }).format(Number(value || 0));
  const escapeHtml = (value) => String(value || '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
  const discountDisplay = discountValue > 0
    ? (discountType === 'percent' ? discountValue + '%' : formatMoney(discountValue))
    : '';
  const reviews = Array.isArray(item?.reviews) ? item.reviews : [];
  const reviewCount = reviews.length;
  const reviewAverage = reviewCount
    ? reviews.reduce(function(total, review) {
        return total + Number(review?.rating || 0);
      }, 0) / reviewCount
    : 0;
  const reviewAverageLabel = reviewCount ? reviewAverage.toFixed(1) : '0.0';
  const reviewStarsHtml = function(value) {
    const numericRating = Math.max(0, Math.min(Number(value || 0), 5));
    return Array.from({ length: 5 }, function(_, index) {
      const starNumber = index + 1;
      return `<i class="fas fa-star ${starNumber <= numericRating ? 'text-amber-400' : 'text-slate-300'} text-[12px]"></i>`;
    }).join('');
  };
  const reviewListHtml = reviewCount
    ? reviews.map(function(review) {
        const reviewRating = Number(review?.rating || 0);
        const reviewComment = String(review?.comment || '');
        const reviewDate = review?.created_at
          ? new Date(review.created_at).toLocaleDateString('en-IN', {
              day: 'numeric',
              month: 'short',
              year: 'numeric'
            })
          : '';
        return `
          <div class="border-b border-sky-100 py-4 last:border-b-0 last:pb-0 first:pt-0">
            <div class="flex items-center gap-1 text-amber-400">
              ${reviewStarsHtml(reviewRating)}
            </div>
            <p class="mt-3 text-sm leading-6 text-slate-600">${escapeHtml(reviewComment || 'No comment provided.')}</p>
            ${reviewDate ? `<p class="mt-2 text-[11px] font-medium text-slate-400">${escapeHtml(reviewDate)}</p>` : ''}
          </div>
        `;
      }).join('')
    : '';
  const similarProductsHtml = relatedItems.length
    ? relatedItems.map(function(relatedItem) {
        const relatedTitle = relatedItem?.product_name || relatedItem?.name || 'Product';
        const relatedImage = relatedItem?.image || '';
        const relatedUnitPrice = Number(relatedItem?.unit_price || relatedItem?.price || 0);
        const relatedDiscount = Number(relatedItem?.discount || 0);
        const relatedDiscountType = relatedItem?.discount_type || '';
        const hasRelatedDiscount = relatedDiscount > 0;
        const relatedFinalPrice = relatedDiscount > 0
          ? (relatedDiscountType === 'percent'
              ? relatedUnitPrice - ((relatedUnitPrice * relatedDiscount) / 100)
              : Math.max(relatedUnitPrice - relatedDiscount, 0))
          : relatedUnitPrice;
        const relatedDiscountLabel = hasRelatedDiscount
          ? (relatedDiscountType === 'percent' ? '-' + relatedDiscount + '%' : '-' + formatMoney(relatedDiscount))
          : '';
        const relatedDiscountDisplay = hasRelatedDiscount
          ? (relatedDiscountType === 'percent' ? 'Percent' : 'Flat') + '-' + relatedDiscountLabel.replace(/^-/, '')
          : '';

        return ''
          + '<a href="/products/buy?id=' + (relatedItem?.id || '') + '" class="featured-card block rounded-3xl border border-sky-100 bg-[linear-gradient(180deg,#ffffff_0%,#f8fbff_100%)] p-2.5 shadow-[0_10px_24px_rgba(148,163,184,0.10)] transition-transform duration-200 hover:-translate-y-1 hover:border-sky-200 hover:shadow-[0_16px_30px_rgba(125,211,252,0.16)]">'
          +   '<div class="relative h-[165px] sm:h-[185px] lg:h-[195px] w-full overflow-hidden rounded-2xl bg-[linear-gradient(180deg,#f8fcff_0%,#eef7ff_100%)] ring-1 ring-sky-100">'
          +     (relatedDiscountDisplay ? '<span class="absolute left-2.5 top-2.5 z-10 rounded-md bg-sky-500 px-2 py-1 text-[11px] font-bold text-white">' + relatedDiscountDisplay + '</span>' : '')
          +     '<img src="' + relatedImage + '" alt="' + relatedTitle + '" class="h-full w-full object-contain">'
          +   '</div>'
          +   '<div class="px-1.5 pt-2.5">'
          +     '<h3 class="truncate text-[14px] lg:text-[13px] font-semibold leading-tight text-gray-900">' + relatedTitle + '</h3>'
          +     '<div class="mt-1 flex items-end gap-1.5">'
          +       (hasRelatedDiscount ? '<span class="text-[11px] text-gray-400 line-through">' + formatMoney(relatedUnitPrice) + '</span>' : '')
          +       '<span class="text-[14px] lg:text-[13px] font-bold text-slate-700">' + formatMoney(relatedFinalPrice) + '</span>'
          +     '</div>'
          +   '</div>'
          + '</a>';
      }).join('')
    : '';

  const body = `
  <style>
    .buy-thumb::-webkit-scrollbar { width: 0; height: 0; }
    .buy-thumb { scrollbar-width: none; }
  </style>
  <section class="px-3 pt-5 pb-8 sm:px-4 md:px-6 md:pt-5 md:pb-10">
    <div class="mx-auto max-w-[1280px]">
      ${error ? `
        <div class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-600">${error}</div>
      ` : item ? `
        <div class="mx-0 sm:mx-1 md:mx-4 lg:mx-8 xl:mx-12 grid gap-5 lg:gap-6 xl:grid-cols-[0.95fr_1.45fr_0.8fr]">
          <div>
            <div class="group overflow-hidden rounded-[1rem] border border-sky-100 bg-[linear-gradient(180deg,#ffffff_0%,#f8fbff_100%)] shadow-[0_12px_28px_rgba(148,163,184,0.10)]">
              <div class="relative flex min-h-[250px] sm:min-h-[300px] items-center justify-center bg-[radial-gradient(circle_at_top,#dbeafe,transparent_58%),linear-gradient(180deg,#f8fcff_0%,#eef7ff_100%)] p-3 md:min-h-[330px]">
                <button type="button" class="buy-wishlist-btn absolute right-3 top-3 z-10 inline-flex h-10 w-10 items-center justify-center rounded-full border border-sky-200 bg-white/95 text-sky-600 shadow-sm transition hover:border-sky-300 hover:text-sky-700 sm:opacity-0 sm:pointer-events-none sm:group-hover:opacity-100 sm:group-hover:pointer-events-auto" aria-label="Add to wishlist">
                  <i class="far fa-heart text-[15px]"></i>
                </button>
                <img id="buyMainImage" src="${galleryImages[0] || ''}" alt="${titleText}" class="max-h-[230px] sm:max-h-[300px] w-full object-contain">
              </div>
            </div>
            <div class="buy-thumb mt-3 flex gap-2.5 overflow-x-auto pb-1">
              ${galleryImages.map(function(image, index) {
                const activeClass = index === 0 ? 'border-sky-400 ring-2 ring-sky-100' : 'border-slate-200';
                return '<button type="button" class="buy-gallery-thumb flex h-[56px] w-[56px] sm:h-[60px] sm:w-[60px] flex-shrink-0 items-center justify-center overflow-hidden rounded-[0.65rem] border bg-[linear-gradient(180deg,#ffffff_0%,#f8fbff_100%)] p-1 transition ' + activeClass + '" data-image-src="' + image + '"><img src="' + image + '" alt="${titleText} thumbnail" class="h-full w-full object-contain"></button>';
              }).join('')}
            </div>
          </div>

          <div class="pt-1 sm:pt-3 md:pt-5">
            <p class="text-xs font-bold uppercase tracking-[0.22em] text-sky-600">Product Details</p>
            <h1 class="text-[22px] sm:text-[24px] font-bold leading-tight text-slate-900">${titleText}</h1>
            <div class="mt-2.5 flex flex-wrap items-center gap-x-3 gap-y-2 text-[12px] text-slate-600">
              <div class="flex items-center gap-1 text-orange-400">
                ${reviewStarsHtml(Math.round(reviewAverage))}
              </div>
              <span class="font-semibold text-slate-500">(${reviewAverageLabel})</span>
              <span class="font-medium text-slate-700">${reviewCount} Review${reviewCount === 1 ? '' : 's'}</span>
              <span>|</span>
              <span class="font-medium text-slate-700">0 Orders</span>
              <span>|</span>
              <span class="font-medium text-slate-700">0 Wish Listed</span>
            </div>

            <div class="mt-4 flex flex-wrap items-end gap-2.5">
              ${discountValue > 0 ? `<span class="text-[17px] font-medium text-slate-400 line-through">${formatMoney(unitPriceNumber)}</span>` : ''}
              <span class="text-[20px] font-bold text-slate-700">${formatMoney(totalWithTaxNumber)}</span>
            </div>
            <div class="mt-2 space-y-1 text-[13px] text-slate-600">
              <p><span class="font-semibold text-slate-800">SKU:</span> ${item?.sku || '--'}</p>
              ${discountValue > 0 ? `<p><span class="font-semibold text-slate-800">Discount:</span> ${discountDisplay}</p>` : ''}
            </div>

            <div class="mt-8 flex flex-wrap items-center gap-3">
              <span class="text-[15px] font-semibold text-slate-800">Quantity :</span>
              <div class="flex items-center overflow-hidden rounded-[0.55rem] border border-sky-200 bg-[linear-gradient(180deg,#ffffff_0%,#f8fbff_100%)]">
                <button type="button" class="buy-qty-btn flex h-[38px] w-[38px] items-center justify-center text-[16px] text-sky-700 transition hover:bg-sky-50" data-direction="decrement">-</button>
                <div id="buyQtyValue" class="flex h-[38px] min-w-[46px] items-center justify-center border-x border-sky-100 text-[16px] text-slate-700">1</div>
                <button type="button" class="buy-qty-btn flex h-[38px] w-[38px] items-center justify-center text-[16px] text-sky-700 transition hover:bg-sky-50" data-direction="increment">+</button>
              </div>
            </div>

            <div class="mt-4 text-[15px] font-semibold text-slate-800">
              Total Price :
              <span id="buyTotalPrice" class="font-bold text-slate-700">${formatMoney(totalWithTaxNumber)}</span>
              <span class="ml-1 text-[12px] font-medium text-slate-500">(Tax incl.)</span>
            </div>

            <div class="mt-5 flex flex-wrap items-center gap-3">
              <button type="button" id="buyNowBtn" class="inline-flex min-w-[116px] flex-1 sm:flex-none items-center justify-center rounded-[0.45rem] bg-gradient-to-r from-sky-500 to-blue-500 px-5 py-2.5 text-[15px] font-medium text-white transition hover:from-sky-600 hover:to-blue-600">Buy now</button>
              <button type="button" id="buyAddToCartBtn" class="inline-flex min-w-[132px] flex-1 sm:flex-none items-center justify-center rounded-[0.45rem] border border-sky-200 bg-sky-50 px-5 py-2.5 text-[15px] font-medium text-sky-700 transition hover:border-sky-300 hover:bg-sky-100">Add to cart</button>
            </div>
          </div>

          <div class="space-y-4">
            <div class="overflow-hidden rounded-[0.9rem] border border-sky-100 bg-[linear-gradient(180deg,#ffffff_0%,#f8fbff_100%)] shadow-[0_12px_28px_rgba(148,163,184,0.10)]">
              <div class="flex items-center gap-3 border-b border-sky-100 px-4 py-4 text-[14px] text-slate-700">
                <span class="flex h-7 w-7 items-center justify-center rounded-full border border-sky-200 bg-sky-50 text-[12px] text-sky-500"><i class="fas fa-truck"></i></span>
                <span>Fast Delivery all across the country</span>
              </div>
              <div class="flex items-center gap-3 border-b border-sky-100 px-4 py-4 text-[14px] text-slate-700">
                <span class="flex h-7 w-7 items-center justify-center rounded-full border border-sky-200 bg-sky-50 text-[12px] text-sky-500"><i class="far fa-credit-card"></i></span>
                <span>Safe Payment</span>
              </div>
              <div class="flex items-center gap-3 border-b border-sky-100 px-4 py-4 text-[14px] text-slate-700">
                <span class="flex h-7 w-7 items-center justify-center rounded-full border border-sky-200 bg-sky-50 text-[12px] text-sky-500"><i class="fas fa-rotate-left"></i></span>
                <span>7 Days Return Policy</span>
              </div>
              <div class="flex items-center gap-3 px-4 py-4 text-[14px] text-slate-700">
                <span class="flex h-7 w-7 items-center justify-center rounded-full border border-sky-200 bg-sky-50 text-[12px] text-sky-500"><i class="fas fa-shield-heart"></i></span>
                <span>100% Authentic Products</span>
              </div>
            </div>

            <div class="rounded-[0.9rem] border border-sky-100 bg-[linear-gradient(180deg,#ffffff_0%,#f8fbff_100%)] p-5 sm:p-6 shadow-[0_12px_28px_rgba(148,163,184,0.10)]">
              <img src="${brandImage}" alt="${brandName}" class="h-14 w-14 rounded-full object-cover ring-2 ring-sky-100">
              <h2 class="mt-5 text-left text-[16px] font-bold leading-8 text-slate-900">${brandName}</h2>
            </div>
          </div>
        </div>

        <div class="mx-0 sm:mx-1 md:mx-4 lg:mx-8 xl:mx-12 mt-7 rounded-[0.95rem] border border-sky-100 bg-[linear-gradient(180deg,#ffffff_0%,#f8fbff_100%)] p-4 sm:p-5 shadow-[0_12px_28px_rgba(148,163,184,0.10)]">
          <div class="flex flex-wrap items-center justify-center gap-6 sm:gap-10 border-b border-sky-100 pb-3">
            <button type="button" class="buy-detail-tab border-b-2 border-sky-500 px-1 pb-2 text-[14px] font-semibold text-sky-600" data-tab="description">Description</button>
            <button type="button" class="buy-detail-tab border-b-2 border-transparent px-1 pb-2 text-[14px] font-semibold text-slate-500" data-tab="reviews">Reviews</button>
          </div>
          <div class="pt-4">
            <div id="buyDescriptionCard" class="rounded-[0.9rem] border border-sky-100 bg-[linear-gradient(180deg,#ffffff_0%,#f8fbff_100%)] p-4 sm:p-5 shadow-[0_12px_28px_rgba(148,163,184,0.10)]">
              <div id="buyDescriptionPanel" class="text-[14px] leading-6 text-slate-600 whitespace-pre-line">
                ${cleanDescription || 'Description unavailable'}
              </div>
            </div>
            <div id="buyReviewsPanel" class="hidden bg-white px-2 pt-4 text-[14px] leading-6 text-slate-600 sm:px-4 md:px-6">
              ${reviewCount ? `
                <div class="space-y-0">
                  ${reviewListHtml}
                </div>
              ` : `
                <div class="rounded-[0.95rem] border border-dashed border-sky-200 bg-white p-5 text-sm text-slate-500">
                  <p class="text-base font-semibold text-slate-900">No reviews yet</p>
                  <p class="mt-1 text-sm text-slate-500">Be the first to share your experience with this product.</p>
                </div>
              `}
            </div>
          </div>
        </div>

        ${relatedItems.length ? `
          <div class="mx-0 sm:mx-1 md:mx-4 lg:mx-8 xl:mx-12 mt-7 rounded-[0.95rem] border border-sky-100 bg-[linear-gradient(180deg,#ffffff_0%,#f8fbff_100%)] p-4 sm:p-5 shadow-[0_12px_28px_rgba(148,163,184,0.10)]">
            <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
              <h2 class="text-[18px] font-bold text-slate-900">Similar Products</h2>
              <span class="text-[12px] font-medium uppercase tracking-[0.16em] text-sky-600">Recommended for you</span>
            </div>
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
              ${similarProductsHtml}
            </div>
          </div>
        ` : ''}

        <script>
          (function() {
            const mainImage = document.getElementById('buyMainImage');
            const qtyValueEl = document.getElementById('buyQtyValue');
            const totalPriceEl = document.getElementById('buyTotalPrice');
            const buyNowBtn = document.getElementById('buyNowBtn');
            const buyAddToCartBtn = document.getElementById('buyAddToCartBtn');
            const descriptionCard = document.getElementById('buyDescriptionCard');
            const descriptionPanel = document.getElementById('buyDescriptionPanel');
            const reviewsPanel = document.getElementById('buyReviewsPanel');
            const wishlistButton = document.querySelector('.buy-wishlist-btn');
            const unitPrice = ${JSON.stringify(finalPriceNumber)};
            const taxAmount = ${JSON.stringify(taxAmountNumber)};
            const productId = ${JSON.stringify(String(requestedProductId || item?.id || item?.product_id || item?._id || item?.slug || ''))};
            const cartAddEndpoint = 'https://aerthh.newhopeindia17.com/api/cart/add';
            const wishlistAddEndpoint = 'https://aerthh.newhopeindia17.com/api/wishlist/add';

            function hasCustomerSession() {
              try {
                return !!(
                  localStorage.getItem('customerToken') ||
                  localStorage.getItem('authData') ||
                  localStorage.getItem('customerData') ||
                  localStorage.getItem('userData')
                );
              } catch (error) {
                return false;
              }
            }

            function getCustomerAuth() {
              try {
                return {
                  token: localStorage.getItem('customerToken') || '',
                  tokenType: localStorage.getItem('tokenType') || 'Bearer'
                };
              } catch (error) {
                return { token: '', tokenType: 'Bearer' };
              }
            }

            function openCartSuccessModal(message) {
              const buyCartSuccessModal = document.getElementById('buyCartSuccessModal');
              const buyCartSuccessMessage = document.getElementById('buyCartSuccessMessage');
              if (!buyCartSuccessModal || !buyCartSuccessMessage) return;
              buyCartSuccessMessage.textContent = message || 'Product added to cart successfully.';
              buyCartSuccessModal.classList.remove('hidden');
              buyCartSuccessModal.classList.add('flex');
              document.body.classList.add('overflow-hidden');
            }

            function closeCartSuccessModal() {
              const buyCartSuccessModal = document.getElementById('buyCartSuccessModal');
              if (!buyCartSuccessModal) return;
              buyCartSuccessModal.classList.add('hidden');
              buyCartSuccessModal.classList.remove('flex');
              document.body.classList.remove('overflow-hidden');
            }

            function openWishlistSuccessModal(message) {
              const buyWishlistSuccessModal = document.getElementById('buyWishlistSuccessModal');
              const buyWishlistSuccessMessage = document.getElementById('buyWishlistSuccessMessage');
              if (!buyWishlistSuccessModal || !buyWishlistSuccessMessage) return;
              buyWishlistSuccessMessage.textContent = message || 'Product added to wishlist successfully.';
              buyWishlistSuccessModal.classList.remove('hidden');
              buyWishlistSuccessModal.classList.add('flex');
              document.body.classList.add('overflow-hidden');
            }

            function closeWishlistSuccessModal() {
              const buyWishlistSuccessModal = document.getElementById('buyWishlistSuccessModal');
              if (!buyWishlistSuccessModal) return;
              buyWishlistSuccessModal.classList.add('hidden');
              buyWishlistSuccessModal.classList.remove('flex');
              document.body.classList.remove('overflow-hidden');
            }

            function clearClearedCartItem(productId) {
              try {
                const normalizedId = String(productId || '').trim();
                if (!normalizedId) return;
                const parsed = JSON.parse(localStorage.getItem('clearedCartItemIds') || '[]');
                if (!Array.isArray(parsed) || !parsed.length) return;
                const nextIds = parsed
                  .map(function (value) { return String(value); })
                  .filter(function (value) { return value !== normalizedId; });
                localStorage.setItem('clearedCartItemIds', JSON.stringify(nextIds));
              } catch (error) {
                console.warn('Unable to update cleared cart item ids:', error);
              }
            }

            async function addToCart(quantity) {
              const auth = getCustomerAuth();
              if (!auth.token) {
                const redirectTarget = '/products/buy?id=' + encodeURIComponent(productId);
                window.location.href = '/auth/customer/signin?redirect=' + encodeURIComponent(redirectTarget);
                return;
              }

              const response = await fetch(cartAddEndpoint, {
                method: 'POST',
                headers: {
                  'Accept': 'application/json',
                  'Content-Type': 'application/json',
                  'Authorization': (auth.tokenType || 'Bearer') + ' ' + auth.token
                },
                body: JSON.stringify({
                  product_id: Number(productId),
                  quantity: quantity
                })
              });

              const result = await response.json();

              if (!response.ok || !result?.status) {
                throw new Error(result?.message || 'Unable to add product to cart.');
              }

              clearClearedCartItem(productId);
              window.dispatchEvent(new CustomEvent('cart:updated'));
              openCartSuccessModal(result?.message || 'Product added to cart successfully.');
            }

            async function addToWishlist() {
              const auth = getCustomerAuth();
              if (!auth.token) {
                const redirectTarget = '/products/buy?id=' + encodeURIComponent(productId);
                window.location.href = '/auth/customer/signin?redirect=' + encodeURIComponent(redirectTarget);
                return;
              }

              const response = await fetch(wishlistAddEndpoint, {
                method: 'POST',
                headers: {
                  'Accept': 'application/json',
                  'Content-Type': 'application/json',
                  'Authorization': (auth.tokenType || 'Bearer') + ' ' + auth.token
                },
                body: JSON.stringify({
                  product_id: Number(productId)
                })
              });

              const result = await response.json();

              if (!response.ok || !result?.status) {
                throw new Error(result?.message || 'Unable to add product to wishlist.');
              }

              window.dispatchEvent(new CustomEvent('wishlist:updated'));
              openWishlistSuccessModal(result?.message || 'Product added to wishlist successfully.');
            }

            document.querySelectorAll('.buy-gallery-thumb').forEach(function(button) {
              button.addEventListener('click', function() {
                if (!mainImage) return;
                const nextImage = this.dataset.imageSrc || '';
                if (!nextImage) return;

                mainImage.src = nextImage;
                document.querySelectorAll('.buy-gallery-thumb').forEach(function(thumb) {
                  thumb.classList.remove('border-sky-400', 'ring-2', 'ring-sky-100');
                  thumb.classList.add('border-slate-200');
                });

                this.classList.remove('border-slate-200');
                this.classList.add('border-sky-400', 'ring-2', 'ring-sky-100');
              });
            });

            document.querySelectorAll('.buy-qty-btn').forEach(function(button) {
              button.addEventListener('click', function() {
                if (!qtyValueEl || !totalPriceEl) return;
                const currentQty = Number(qtyValueEl.textContent || 1);
                const nextQty = this.dataset.direction === 'increment' ? currentQty + 1 : Math.max(currentQty - 1, 1);
                qtyValueEl.textContent = String(nextQty);
                totalPriceEl.textContent = new Intl.NumberFormat('en-IN', {
                  style: 'currency',
                  currency: 'INR',
                  minimumFractionDigits: 2,
                  maximumFractionDigits: 2
                }).format((unitPrice * nextQty) + taxAmount);
              });
            });

            document.querySelectorAll('.buy-detail-tab').forEach(function(tab) {
              tab.addEventListener('click', function() {
                const selectedTab = this.dataset.tab || 'description';
                const isDescription = selectedTab === 'description';

                if (descriptionCard) descriptionCard.classList.toggle('hidden', !isDescription);
                if (descriptionPanel) descriptionPanel.classList.toggle('hidden', !isDescription);
                if (reviewsPanel) reviewsPanel.classList.toggle('hidden', isDescription);

                document.querySelectorAll('.buy-detail-tab').forEach(function(item) {
                  const isActive = item.dataset.tab === selectedTab;
                  item.classList.toggle('border-sky-500', isActive);
                  item.classList.toggle('text-sky-600', isActive);
                  item.classList.toggle('border-transparent', !isActive);
                  item.classList.toggle('text-slate-500', !isActive);
                });
              });
            });

            if (buyNowBtn) {
              buyNowBtn.addEventListener('click', function() {
                const qty = Math.max(Number(qtyValueEl ? qtyValueEl.textContent : 1), 1);
                const params = new URLSearchParams({
                  id: productId,
                  qty: String(qty)
                });
                const checkoutUrl = '/products/address?' + params.toString();
                if (!hasCustomerSession()) {
                  window.location.href = '/auth/customer/signin?redirect=' + encodeURIComponent(checkoutUrl);
                  return;
                }
                window.location.href = checkoutUrl;
              });
            }

            if (buyAddToCartBtn) {
              buyAddToCartBtn.addEventListener('click', async function() {
                const qty = Math.max(Number(qtyValueEl ? qtyValueEl.textContent : 1), 1);
                const originalText = buyAddToCartBtn.innerHTML;

                buyAddToCartBtn.disabled = true;
                buyAddToCartBtn.innerHTML = 'Adding...';

                try {
                  await addToCart(qty);
                } catch (error) {
                  console.error('Add to cart error:', error);
                  window.alert(error.message || 'Unable to add product to cart.');
                } finally {
                  buyAddToCartBtn.disabled = false;
                  buyAddToCartBtn.innerHTML = originalText;
                }
              });
            }

            if (wishlistButton) {
              wishlistButton.addEventListener('click', async function() {
                const originalText = wishlistButton.innerHTML;
                wishlistButton.disabled = true;
                wishlistButton.innerHTML = '<i class="fas fa-spinner fa-spin text-[15px]"></i>';

                try {
                  await addToWishlist();
                } catch (error) {
                  console.error('Add to wishlist error:', error);
                  window.alert(error.message || 'Unable to add product to wishlist.');
                } finally {
                  wishlistButton.disabled = false;
                  wishlistButton.innerHTML = originalText;
                }
              });
            }

            const buyCartSuccessModal = document.getElementById('buyCartSuccessModal');
            const buyWishlistSuccessModal = document.getElementById('buyWishlistSuccessModal');

            if (buyCartSuccessModal) {
              buyCartSuccessModal.addEventListener('click', function(event) {
                if (event.target === buyCartSuccessModal) {
                  closeCartSuccessModal();
                }
              });
            }

            if (buyWishlistSuccessModal) {
              buyWishlistSuccessModal.addEventListener('click', function(event) {
                if (event.target === buyWishlistSuccessModal) {
                  closeWishlistSuccessModal();
                }
              });
            }

            document.addEventListener('click', function(event) {
              if (event.target && event.target.id === 'buyCartSuccessCloseBtn') {
                closeCartSuccessModal();
              }
              if (event.target && event.target.id === 'buyWishlistSuccessCloseBtn') {
                closeWishlistSuccessModal();
              }
            });
          })();
        </script>
      ` : `
        <div class="rounded-2xl border border-sky-100 bg-[linear-gradient(180deg,#f8fcff_0%,#eef7ff_100%)] px-4 py-3 text-sm text-slate-600">Product not found.</div>
      `}
    </div>
  </section>
  <div id="buyCartSuccessModal" class="fixed inset-0 z-[1600] hidden items-center justify-center bg-slate-900/55 px-4 py-6 backdrop-blur-sm">
    <div class="w-full max-w-sm rounded-[1.2rem] bg-white p-6 shadow-2xl ring-1 ring-sky-100">
      <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-sky-50 text-sky-600 ring-1 ring-sky-100">
        <i class="fas fa-check text-xl"></i>
      </div>
      <h3 class="mt-4 text-center text-xl font-bold text-slate-900">Added to Cart</h3>
      <p id="buyCartSuccessMessage" class="mt-2 text-center text-sm text-slate-600">Product added to cart successfully.</p>
      <div class="mt-5 flex justify-center">
        <button id="buyCartSuccessCloseBtn" type="button" class="inline-flex items-center justify-center rounded-[0.85rem] bg-gradient-to-r from-sky-500 to-blue-500 px-5 py-2.5 text-sm font-semibold text-white transition hover:from-sky-600 hover:to-blue-600">OK</button>
      </div>
    </div>
  </div>

  <div id="buyWishlistSuccessModal" class="fixed inset-0 z-[1600] hidden items-center justify-center bg-slate-900/55 px-4 py-6 backdrop-blur-sm">
    <div class="w-full max-w-sm rounded-[1.2rem] bg-white p-6 shadow-2xl ring-1 ring-sky-100">
      <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-rose-50 text-rose-600 ring-1 ring-rose-100">
        <i class="fas fa-heart text-xl"></i>
      </div>
      <h3 class="mt-4 text-center text-xl font-bold text-slate-900">Added to Wishlist</h3>
      <p id="buyWishlistSuccessMessage" class="mt-2 text-center text-sm text-slate-600">Product added to wishlist successfully.</p>
      <div class="mt-5 flex justify-center">
        <button id="buyWishlistSuccessCloseBtn" type="button" class="inline-flex items-center justify-center rounded-[0.85rem] bg-gradient-to-r from-sky-500 to-blue-500 px-5 py-2.5 text-sm font-semibold text-white transition hover:from-sky-600 hover:to-blue-600">OK</button>
      </div>
    </div>
  </div>
  `; %>

<%- include('../layout/app', { title: title || 'Buy', body }) %>
