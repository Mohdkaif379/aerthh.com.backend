<%
  const items = Array.isArray(products) ? products : [];
  const error = typeof errorMessage !== 'undefined' ? errorMessage : '';
  const activeCategoryName = typeof selectedCategoryName !== 'undefined' ? selectedCategoryName : '';
  const activeBrandName = typeof selectedBrandName !== 'undefined' ? selectedBrandName : '';
  const pageTitle = activeCategoryName || activeBrandName || 'All Products';
  const pageLabel = activeCategoryName || activeBrandName ? 'Filtered Products' : 'Catalogue';
  const highestPrice = items.length
    ? items.reduce(function(max, item) {
        const unitPrice = Number(item?.unit_price || item?.price || 0);
        const discountValue = Number(item?.discount || 0);
        const discountType = item?.discount_type || '';
        const finalPrice = discountValue > 0
          ? (discountType === 'percent'
              ? unitPrice - ((unitPrice * discountValue) / 100)
              : Math.max(unitPrice - discountValue, 0))
          : unitPrice;
        return Math.max(max, finalPrice);
      }, 0)
    : 0;
  const maxFilterPrice = Math.ceil(highestPrice || 1000);

  function formatPrice(value) {
    return Number(value || 0).toFixed(2);
  }

  function formatMoney(value) {
    return new Intl.NumberFormat('en-IN', {
      style: 'currency',
      currency: 'INR',
      minimumFractionDigits: 2,
      maximumFractionDigits: 2
    }).format(Number(value || 0));
  }

  const productCards = items.map(function(item) {
    const productIdentifier = item.id || item.product_id || item.slug || '';
    const title = item.product_name || item.name || 'Product';
    const image = item.image || '';
    const unitPrice = Number(item.unit_price || item.price || 0);
    const discountValue = Number(item.discount || 0);
    const discountType = item.discount_type || '';
    const finalPrice = discountValue > 0
      ? (discountType === 'percent'
          ? unitPrice - ((unitPrice * discountValue) / 100)
          : Math.max(unitPrice - discountValue, 0))
      : unitPrice;
    const hasDiscount = discountValue > 0;
    const discountDisplay = hasDiscount
      ? (discountType === 'percent' ? discountValue + '% OFF' : formatMoney(discountValue) + ' OFF')
      : '';

    return `
      <article class="product-card group overflow-hidden rounded-[1.1rem] border border-sky-100 bg-[linear-gradient(180deg,#ffffff_0%,#f8fbff_100%)] shadow-[0_10px_26px_rgba(148,163,184,0.10)] transition duration-300 hover:-translate-y-1 hover:border-sky-200 hover:shadow-[0_18px_34px_rgba(125,211,252,0.16)]" data-price="${finalPrice}" data-title="${String(title).toLowerCase()}" data-product-id="${String(productIdentifier)}">
        <div class="relative overflow-hidden bg-[radial-gradient(circle_at_top,#dbeafe,transparent_56%),linear-gradient(180deg,#f8fcff_0%,#eef7ff_100%)] p-1.5">
          ${hasDiscount ? `<span class="absolute left-2.5 top-2.5 z-10 rounded-full bg-sky-500 px-2.5 py-1 text-[9px] font-bold uppercase tracking-[0.12em] text-white shadow-sm">${discountDisplay}</span>` : ''}
          <a href="/products/buy?id=${encodeURIComponent(String(productIdentifier))}" class="block overflow-hidden rounded-[0.8rem] bg-white/90 p-1.5 ring-1 ring-slate-100">
            <img src="${image}" alt="${title}" class="h-[140px] sm:h-[150px] lg:h-[102px] w-full object-contain transition duration-300 group-hover:scale-[1.04]">
          </a>
        </div>
        <div class="p-3 sm:p-3.5 lg:p-2.5">
          <div class="flex items-start justify-between gap-2.5">
            <h2 class="line-clamp-2 text-[13px] sm:text-[14px] lg:text-[12px] font-semibold leading-5 lg:leading-4 text-slate-900">${title}</h2>
            <button type="button" class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full border border-sky-100 bg-sky-50 text-sky-600 transition hover:border-sky-200 hover:bg-sky-100 hover:text-sky-700">
              <i class="far fa-heart text-[11px]"></i>
            </button>
          </div>
          <div class="mt-1 flex items-end gap-1.5">
            ${hasDiscount ? `<span class="text-[11px] sm:text-[12px] lg:text-[11px] font-medium text-slate-400 line-through">${formatMoney(unitPrice)}</span>` : ''}
            <span class="text-[15px] sm:text-[16px] lg:text-[14px] font-bold text-slate-800">${formatMoney(finalPrice)}</span>
          </div>
          <div class="mt-3 flex items-center justify-between gap-2">
            <a href="/products/buy?id=${encodeURIComponent(String(productIdentifier))}" class="inline-flex min-w-[92px] items-center justify-center rounded-[0.75rem] bg-gradient-to-r from-sky-500 to-blue-500 px-3 py-1.5 text-[11px] lg:px-2.5 lg:py-1 lg:text-[10px] font-semibold text-white transition hover:from-sky-600 hover:to-blue-600">Buy Now</a>
            <button type="button" class="product-add-to-cart-btn inline-flex min-w-[72px] items-center justify-center rounded-[0.75rem] border border-sky-200 bg-sky-50 px-3 py-1.5 text-[11px] lg:px-2.5 lg:py-1 lg:text-[10px] font-semibold text-sky-700 transition hover:bg-sky-100">Add</button>
          </div>
        </div>
      </article>
    `;
  }).join('');

  const body = `
  <section class="px-3 pt-4 pb-8 sm:px-4 md:px-6 md:pt-5 md:pb-10">
    <div class="mx-auto max-w-7xl">
      <div class="mt-2 overflow-hidden rounded-[1.4rem] sm:rounded-[2rem] bg-[radial-gradient(circle_at_top_left,#dbeafe,transparent_30%),radial-gradient(circle_at_top_right,#e0f2fe,transparent_24%),linear-gradient(135deg,#f8fcff_0%,#ffffff_58%,#eef7ff_100%)] p-4 sm:p-6 shadow-[0_20px_70px_rgba(148,163,184,0.12)] ring-1 ring-sky-100 md:p-8">
        <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
          <div class="max-w-2xl">
            <p class="text-xs font-bold uppercase tracking-[0.28em] text-sky-600">${pageLabel}</p>
            <h1 class="mt-3 text-[28px] sm:text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">${pageTitle}</h1>
            <p class="mt-3 max-w-xl text-sm leading-6 text-slate-600">Refined picks for everyday shopping, arranged in a cleaner storefront with live filtering and quick sorting.</p>
            ${(activeCategoryName || activeBrandName) ? `
              <div class="mt-4 flex flex-wrap gap-2">
                ${activeCategoryName ? `<span class="inline-flex items-center rounded-full bg-white/90 px-4 py-1.5 text-xs font-semibold text-sky-700 ring-1 ring-sky-200">Category: ${activeCategoryName}</span>` : ''}
                ${activeBrandName ? `<span class="inline-flex items-center rounded-full bg-white/90 px-4 py-1.5 text-xs font-semibold text-blue-700 ring-1 ring-blue-200">Brand: ${activeBrandName}</span>` : ''}
              </div>
            ` : ''}
          </div>
          ${items.length ? `
            <div class="w-full max-w-full sm:max-w-[230px]">
              <label for="productsSort" class="mb-2 block text-xs font-bold uppercase tracking-[0.2em] text-slate-500">Sort By</label>
              <select id="productsSort" class="w-full rounded-2xl border border-sky-100 bg-white px-4 py-3 text-sm font-medium text-slate-700 shadow-sm outline-none transition focus:border-sky-400 focus:ring-2 focus:ring-sky-100">
                <option value="default">Default Order</option>
                <option value="price_asc">Lowest Price</option>
                <option value="price_desc">Highest Price</option>
                <option value="title_asc">A to Z</option>
                <option value="title_desc">Z to A</option>
              </select>
            </div>
          ` : ''}
        </div>
      </div>

      ${error ? `
        <div class="mt-8 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-600">${error}</div>
      ` : items.length ? `
        <div class="mt-8 grid gap-5 sm:gap-7 lg:grid-cols-[290px_minmax(0,1fr)]">
          <aside class="h-fit rounded-[1.25rem] sm:rounded-[1.7rem] bg-[linear-gradient(180deg,#ffffff_0%,#f8fbff_100%)] p-4 sm:p-5 shadow-[0_14px_45px_rgba(148,163,184,0.12)] ring-1 ring-sky-100">
            <div class="flex items-center justify-between gap-3 border-b border-sky-100 pb-4">
              <div>
                <p class="text-xs font-bold uppercase tracking-[0.18em] text-sky-600">Narrow Results</p>
                <h2 class="mt-1 text-lg font-bold text-slate-900">Filters</h2>
              </div>
              <button id="clearPriceFilter" type="button" class="text-xs font-bold uppercase tracking-[0.14em] text-sky-600">Reset</button>
            </div>
            <div class="mt-5 rounded-[1.3rem] bg-[linear-gradient(180deg,#f8fcff_0%,#eef7ff_100%)] p-4 ring-1 ring-sky-100">
              <div class="flex items-center justify-between gap-3">
                <h3 class="text-sm font-bold uppercase tracking-[0.18em] text-slate-700">Price Range</h3>
                <span id="priceFilterValue" class="text-sm font-bold text-sky-700">${formatMoney(maxFilterPrice)}</span>
              </div>
              <div class="mt-5">
                <input id="priceFilterRange" type="range" min="0" max="${maxFilterPrice}" value="${maxFilterPrice}" step="1" class="w-full accent-sky-600">
              </div>
              <div class="mt-3 flex items-center justify-between text-xs font-medium text-slate-500">
                <span>${formatMoney(0)}</span>
                <span>${formatMoney(maxFilterPrice)}</span>
              </div>
            </div>
          </aside>

          <div>
            <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
              <p id="productsCountLabel" class="text-sm font-medium text-slate-600">Showing ${items.length} products</p>
            </div>
            <div id="productsGrid" class="grid grid-cols-1 gap-4 sm:gap-5 sm:grid-cols-2 xl:grid-cols-4">
              ${productCards}
            </div>
          </div>
        </div>
      ` : `
        <div class="mt-8 rounded-2xl border border-sky-100 bg-[linear-gradient(180deg,#f8fcff_0%,#eef7ff_100%)] px-4 py-3 text-sm text-slate-600">${activeCategoryName ? 'No products found in this category.' : activeBrandName ? 'No products found for this brand.' : 'Products unavailable.'}</div>
      `}
    </div>
  </section>
  <div id="productsCartSuccessModal" class="fixed inset-0 z-[1600] hidden items-center justify-center bg-slate-900/55 px-4 py-6 backdrop-blur-sm">
    <div class="w-full max-w-sm rounded-[1.2rem] bg-white p-6 shadow-2xl ring-1 ring-sky-100">
      <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-sky-50 text-sky-600 ring-1 ring-sky-100">
        <i class="fas fa-check text-xl"></i>
      </div>
      <h3 class="mt-4 text-center text-xl font-bold text-slate-900">Added to Cart</h3>
      <p id="productsCartSuccessMessage" class="mt-2 text-center text-sm text-slate-600">Product added to cart successfully.</p>
      <div class="mt-5 flex justify-center">
        <button id="productsCartSuccessCloseBtn" type="button" class="inline-flex items-center justify-center rounded-[0.85rem] bg-gradient-to-r from-sky-500 to-blue-500 px-5 py-2.5 text-sm font-semibold text-white transition hover:from-sky-600 hover:to-blue-600">OK</button>
      </div>
    </div>
  </div>

  ${!error && items.length ? `
    <script>
      (function() {
        const priceRange = document.getElementById('priceFilterRange');
        const priceValue = document.getElementById('priceFilterValue');
        const clearButton = document.getElementById('clearPriceFilter');
        const countLabel = document.getElementById('productsCountLabel');
        const sortSelect = document.getElementById('productsSort');
        const productsGrid = document.getElementById('productsGrid');
        const productCards = Array.from(document.querySelectorAll('.product-card'));
        const maxPrice = ${JSON.stringify(maxFilterPrice)};
        const cartAddEndpoint = 'https://aerthh.newhopeindia17.com/api/cart/add';

        function getCustomerAuth() {
          try {
            return {
              token: localStorage.getItem('customerToken') || '',
              tokenType: localStorage.getItem('tokenType') || 'Bearer'
            };
          } catch (error) {
            return { token: '', tokenType: 'Bearer' };
          }
        }

        function openCartSuccessModal(message) {
          const productsCartSuccessModal = document.getElementById('productsCartSuccessModal');
          const productsCartSuccessMessage = document.getElementById('productsCartSuccessMessage');
          if (!productsCartSuccessModal || !productsCartSuccessMessage) return;
          productsCartSuccessMessage.textContent = message || 'Product added to cart successfully.';
          productsCartSuccessModal.classList.remove('hidden');
          productsCartSuccessModal.classList.add('flex');
          document.body.classList.add('overflow-hidden');
        }

        function closeCartSuccessModal() {
          const productsCartSuccessModal = document.getElementById('productsCartSuccessModal');
          if (!productsCartSuccessModal) return;
          productsCartSuccessModal.classList.add('hidden');
          productsCartSuccessModal.classList.remove('flex');
          document.body.classList.remove('overflow-hidden');
        }

        function clearClearedCartItem(productId) {
          try {
            const normalizedId = String(productId || '').trim();
            if (!normalizedId) return;
            const parsed = JSON.parse(localStorage.getItem('clearedCartItemIds') || '[]');
            if (!Array.isArray(parsed) || !parsed.length) return;
            const nextIds = parsed
              .map(function (value) { return String(value); })
              .filter(function (value) { return value !== normalizedId; });
            localStorage.setItem('clearedCartItemIds', JSON.stringify(nextIds));
          } catch (error) {
            console.warn('Unable to update cleared cart item ids:', error);
          }
        }

        async function addProductToCart(productId, quantity) {
          const auth = getCustomerAuth();
          if (!auth.token) {
            window.location.href = '/auth/customer/signin?redirect=' + encodeURIComponent('/products');
            return;
          }

          const response = await fetch(cartAddEndpoint, {
            method: 'POST',
            headers: {
              'Accept': 'application/json',
              'Content-Type': 'application/json',
              'Authorization': (auth.tokenType || 'Bearer') + ' ' + auth.token
            },
            body: JSON.stringify({
              product_id: Number(productId),
              quantity: quantity
            })
          });

          const result = await response.json();

          if (!response.ok || !result?.status) {
            throw new Error(result?.message || 'Unable to add product to cart.');
          }

          clearClearedCartItem(productId);
          window.dispatchEvent(new CustomEvent('cart:updated'));
          openCartSuccessModal(result?.message || 'Product added to cart successfully.');
        }

        function sortProducts(sortType) {
          if (!productsGrid) return;
          const sortedCards = [...productCards].sort(function(a, b) {
            const aPrice = Number(a.dataset.price || 0);
            const bPrice = Number(b.dataset.price || 0);
            const aTitle = a.dataset.title || '';
            const bTitle = b.dataset.title || '';

            if (sortType === 'price_asc') return aPrice - bPrice;
            if (sortType === 'price_desc') return bPrice - aPrice;
            if (sortType === 'title_asc') return aTitle.localeCompare(bTitle);
            if (sortType === 'title_desc') return bTitle.localeCompare(aTitle);
            return 0;
          });

          sortedCards.forEach(function(card) {
            productsGrid.appendChild(card);
          });
        }

        function applyPriceFilter(value) {
          const numericValue = Math.max(0, Math.min(Number(value || maxPrice), maxPrice));
          let visibleCount = 0;

          productCards.forEach(function(card) {
            const cardPrice = Number(card.dataset.price || 0);
            const isVisible = cardPrice <= numericValue;
            card.style.display = isVisible ? '' : 'none';
            if (isVisible) visibleCount += 1;
          });

          if (priceValue) {
            priceValue.textContent = new Intl.NumberFormat('en-IN', {
              style: 'currency',
              currency: 'INR',
              minimumFractionDigits: 2,
              maximumFractionDigits: 2
            }).format(numericValue);
          }

          if (priceRange && String(priceRange.value) !== String(numericValue)) {
            priceRange.value = String(numericValue);
          }

          if (countLabel) {
            countLabel.textContent = 'Showing ' + visibleCount + ' products';
          }
        }

        if (priceRange) {
          priceRange.addEventListener('input', function() {
            applyPriceFilter(this.value);
          });
        }

        if (sortSelect) {
          sortSelect.addEventListener('change', function() {
            sortProducts(this.value);
          });
        }

        if (clearButton && priceRange) {
          clearButton.addEventListener('click', function() {
            priceRange.value = String(maxPrice);
            applyPriceFilter(maxPrice);
          });
        }

        productCards.forEach(function(card) {
          const addButton = card.querySelector('.product-add-to-cart-btn');
          const productId = card.dataset.productId || '';

          if (!addButton || !productId) return;

          addButton.addEventListener('click', async function() {
            const originalText = addButton.innerHTML;
            addButton.disabled = true;
            addButton.innerHTML = 'Adding...';

            try {
              await addProductToCart(productId, 1);
            } catch (error) {
              console.error('Add to cart error:', error);
              window.alert(error.message || 'Unable to add product to cart.');
            } finally {
              addButton.disabled = false;
              addButton.innerHTML = originalText;
            }
          });
        });

        const productsCartSuccessModal = document.getElementById('productsCartSuccessModal');

        if (productsCartSuccessModal) {
          productsCartSuccessModal.addEventListener('click', function(event) {
            if (event.target === productsCartSuccessModal) {
              closeCartSuccessModal();
            }
          });
        }

        document.addEventListener('click', function(event) {
          if (event.target && event.target.closest && event.target.closest('#productsCartSuccessCloseBtn')) {
            closeCartSuccessModal();
          }
        });

        applyPriceFilter(maxPrice);
      })();
    </script>
  ` : ''}
  `; %>

<%- include('../layout/app', { title: title || 'Products' , body }) %>
