<%
  const pageData = typeof vendorsPage !== 'undefined' && vendorsPage ? vendorsPage : {};
  const vendorList = Array.isArray(vendors)
    ? vendors
    : Array.isArray(pageData.data)
      ? pageData.data
      : [];
  const selected = typeof selectedVendor !== 'undefined' && selectedVendor ? selectedVendor : null;
  const detailProducts = Array.isArray(vendorProducts) ? vendorProducts : [];
  const currentPageNumber = Number(pageData.current_page || currentPage || 1);
  const lastPageNumber = Number(pageData.last_page || lastPage || 1);
  const totalCount = Number(pageData.total || total || vendorList.length || detailProducts.length || 0);
  const activeVendorCount = vendorList.filter(function (vendor) {
    return !!vendor?.status;
  }).length;
  const fromCount = Number(pageData.from || (vendorList.length ? ((currentPageNumber - 1) * Number(pageData.per_page || vendorList.length)) + 1 : 0));
  const toCount = Number(pageData.to || (vendorList.length ? fromCount + vendorList.length - 1 : 0));
  const errorText = typeof errorMessage === 'string' ? errorMessage : '';
  const safeTitle = typeof title !== 'undefined' && title ? title : 'Vendors';

  function escapeHtml(value) {
    return String(value == null ? '' : value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function formatMoney(value) {
    return new Intl.NumberFormat('en-IN', {
      style: 'currency',
      currency: 'INR',
      minimumFractionDigits: 2,
      maximumFractionDigits: 2
    }).format(Number(value || 0));
  }

  function imageForVendor(vendor) {
    return vendor?.image || 'https://via.placeholder.com/1200x800/eaf5ff/0f172a?text=Vendor';
  }

  function imageForProduct(product) {
    return product?.image || product?.thumbnail || product?.featured_image || 'https://via.placeholder.com/1200x800/eaf5ff/0f172a?text=Product';
  }

  function vendorIdOf(vendor) {
    return String(vendor?.id || vendor?.vendor_id || '').trim();
  }

  function renderVendorCard(vendor) {
    const vendorName = escapeHtml(vendor?.name || 'Vendor');
    const vendorImage = escapeHtml(imageForVendor(vendor));
    const vendorStatus = vendor?.status ? 'Active Seller' : 'Inactive Seller';
    const vendorBadge = vendor?.status ? 'Verified' : 'Pending';
    const totalSold = Number(vendor?.total_sold || 0);
    const totalOrders = Number(vendor?.total_orders || 0);
    const rawVendorId = vendorIdOf(vendor);
    const targetHref = rawVendorId ? `/vendors/${encodeURIComponent(rawVendorId)}` : '/vendors';
    const searchableText = [
      vendorName,
      vendorStatus,
      vendor?.city || '',
      vendor?.state || ''
    ].join(' ').toLowerCase();

    return `
      <a href="${targetHref}" data-vendor-card data-search="${escapeHtml(searchableText)}" class="group block w-full max-w-[290px] overflow-hidden rounded-[1.15rem] bg-white shadow-[0_10px_24px_rgba(148,163,184,0.10)] ring-1 ring-sky-100 transition duration-300 hover:-translate-y-1 hover:shadow-[0_16px_34px_rgba(125,211,252,0.14)]">
        <div class="relative h-32 w-full overflow-hidden bg-[radial-gradient(circle_at_top,#dbeafe,transparent_52%),linear-gradient(180deg,#f8fcff_0%,#eef7ff_100%)]">
          <img src="${vendorImage}" alt="${vendorName}" class="h-full w-full object-contain object-center transition duration-300 group-hover:scale-[1.01]">
          <div class="absolute left-3 top-3 rounded-full bg-slate-950/70 px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.16em] text-white shadow-sm backdrop-blur-sm">
            ${vendorStatus}
          </div>
          <div class="absolute right-3 top-3 rounded-full bg-white/90 px-3 py-1 text-[10px] font-bold uppercase tracking-[0.16em] text-sky-700 shadow-sm backdrop-blur-sm">
            ${vendorBadge}
          </div>
        </div>
        <div class="p-3 sm:p-3.5">
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0">
              <h3 class="truncate text-[15px] font-semibold text-slate-900">${vendorName}</h3>
              <p class="mt-1 text-[10px] font-medium uppercase tracking-[0.16em] text-sky-600">Vendor Profile</p>
            </div>
            <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-sky-50 text-sky-600 ring-1 ring-sky-100 transition duration-300 group-hover:bg-sky-100">
              <i class="fas fa-arrow-right text-[11px] transition-transform duration-300 group-hover:translate-x-0.5"></i>
            </span>
          </div>
          <div class="mt-2.5 grid grid-cols-2 gap-1.5">
            <div class="rounded-[0.8rem] bg-[linear-gradient(180deg,#f8fcff_0%,#eef7ff_100%)] px-2 py-1.75 ring-1 ring-sky-100">
              <p class="text-[8px] font-semibold uppercase tracking-[0.14em] text-slate-400">Sold Qty</p>
              <div class="mt-1 flex items-center gap-1">
                <span class="flex h-5 w-5 items-center justify-center rounded-full bg-white text-sky-600 ring-1 ring-sky-100"><i class="fas fa-box-open text-[9px]"></i></span>
                <span class="text-[13px] font-bold text-slate-900">${totalSold}</span>
              </div>
            </div>
            <div class="rounded-[0.8rem] bg-[linear-gradient(180deg,#f8fcff_0%,#eef7ff_100%)] px-2 py-1.75 ring-1 ring-sky-100">
              <p class="text-[8px] font-semibold uppercase tracking-[0.14em] text-slate-400">Orders Count</p>
              <div class="mt-1 flex items-center gap-1">
                <span class="flex h-5 w-5 items-center justify-center rounded-full bg-white text-sky-600 ring-1 ring-sky-100"><i class="fas fa-receipt text-[9px]"></i></span>
                <span class="text-[13px] font-bold text-slate-900">${totalOrders}</span>
              </div>
            </div>
          </div>
        </div>
      </a>
    `;
  }

  function renderProductCard(product) {
    const productName = escapeHtml(product?.product_name || product?.name || product?.title || 'Product');
    const productImage = escapeHtml(imageForProduct(product));
    const productId = encodeURIComponent(String(product?.id || product?.product_id || product?.slug || ''));
    const unitPrice = Number(product?.unit_price || product?.price || product?.sale_price || product?.base_price || 0);
    const discountValue = Number(product?.discount || 0);
    const discountType = product?.discount_type || '';
    const hasDiscount = discountValue > 0;
    const finalPrice = hasDiscount
      ? (discountType === 'percent'
          ? unitPrice - ((unitPrice * discountValue) / 100)
          : Math.max(unitPrice - discountValue, 0))
      : unitPrice;

    return `
      <article class="group overflow-hidden rounded-[1.2rem] bg-white shadow-[0_10px_26px_rgba(148,163,184,0.10)] ring-1 ring-sky-100 transition duration-300 hover:-translate-y-1 hover:shadow-[0_18px_34px_rgba(125,211,252,0.16)]">
        <div class="relative overflow-hidden bg-[radial-gradient(circle_at_top,#dbeafe,transparent_56%),linear-gradient(180deg,#f8fcff_0%,#eef7ff_100%)] p-1.5">
          ${hasDiscount ? `<span class="absolute left-2.5 top-2.5 z-10 rounded-full bg-sky-500 px-2.5 py-1 text-[9px] font-bold uppercase tracking-[0.12em] text-white shadow-sm">${discountType === 'percent' ? `${discountValue}% OFF` : `${formatMoney(discountValue)} OFF`}</span>` : ''}
          <a href="/products/buy?id=${productId}" class="block overflow-hidden rounded-[0.8rem] bg-white/90 p-1.5">
            <img src="${productImage}" alt="${productName}" class="h-[140px] sm:h-[150px] w-full object-contain transition duration-300 group-hover:scale-[1.04]">
          </a>
        </div>
        <div class="p-3 sm:p-3.5">
          <h3 class="line-clamp-2 text-[13px] sm:text-[14px] font-semibold leading-5 text-slate-900">${productName}</h3>
          <div class="mt-1 flex items-end gap-1.5">
            ${hasDiscount ? `<span class="text-[11px] font-medium text-slate-400 line-through">${formatMoney(unitPrice)}</span>` : ''}
            <span class="text-[15px] sm:text-[16px] font-bold text-slate-800">${formatMoney(finalPrice)}</span>
          </div>
          <a href="/products/buy?id=${productId}" class="mt-3 inline-flex w-full items-center justify-center rounded-[0.8rem] bg-gradient-to-r from-sky-500 to-blue-500 px-3 py-2 text-[11px] font-semibold text-white transition hover:from-sky-600 hover:to-blue-600">Buy Now</a>
        </div>
      </article>
    `;
  }

  const vendorCards = vendorList.map(renderVendorCard).join('');
  const selectedVendorName = escapeHtml(selected?.name || 'Vendor');
  const selectedVendorImage = escapeHtml(imageForVendor(selected || {}));
  const selectedVendorStatus = selected?.status ? 'Active Seller' : 'Inactive Seller';
  const selectedVendorBadge = selected?.status ? 'Verified' : 'Pending';
  const selectedVendorSold = Number(selected?.total_sold || 0);
  const selectedVendorOrders = Number(selected?.total_orders || 0);
  const selectedVendorId = vendorIdOf(selected || {});
  const backToList = '/vendors';
  const prevPageUrl = currentPageNumber > 1 ? `/vendors?page=${currentPageNumber - 1}` : '';
  const nextPageUrl = currentPageNumber < lastPageNumber ? `/vendors?page=${currentPageNumber + 1}` : '';
  const strictDetailProducts = selectedVendorId
    ? detailProducts.filter(function (product) {
        return String(product?.vendor_id || product?.vendorId || product?.vendor?.id || product?.vendor?.vendor_id || '').trim() === selectedVendorId;
      })
    : detailProducts;
  const productCards = strictDetailProducts.map(renderProductCard).join('');
%>

<%- include('../../layout/app', {
  title: safeTitle,
  body: `
    <section class="px-3 pt-4 pb-8 sm:px-4 md:px-6 md:pt-5 md:pb-10">
      <div class="mx-auto max-w-7xl">
        ${selected ? `
          <div class="mb-5 flex items-center justify-between gap-3">
            <a href="${backToList}" class="inline-flex items-center gap-2 text-sm font-semibold text-sky-700 transition hover:text-sky-900">
              <i class="fas fa-arrow-left text-[12px]"></i>
              Back to vendors
            </a>
          </div>

          <div class="overflow-hidden rounded-[1.4rem] sm:rounded-[2rem] bg-[radial-gradient(circle_at_top_left,#dbeafe,transparent_28%),radial-gradient(circle_at_top_right,#e0f2fe,transparent_24%),linear-gradient(135deg,#f8fcff_0%,#ffffff_58%,#eef7ff_100%)] p-4 sm:p-6 shadow-[0_20px_70px_rgba(148,163,184,0.12)] ring-1 ring-sky-100 md:p-8">
            <div class="grid gap-6 lg:grid-cols-[0.95fr_1.05fr]">
              <div class="overflow-hidden rounded-[1.25rem] bg-white shadow-[0_12px_28px_rgba(148,163,184,0.10)] ring-1 ring-sky-100">
                <div class="h-56 w-full bg-[linear-gradient(180deg,#f8fcff_0%,#eef7ff_100%)]">
                  <img src="${selectedVendorImage}" alt="${selectedVendorName}" class="h-full w-full object-cover object-center">
                </div>
              </div>
              <div>
                <p class="text-xs font-bold uppercase tracking-[0.28em] text-sky-600">Vendor Detail</p>
                <h1 class="mt-3 text-[28px] font-bold tracking-tight text-slate-900 sm:text-3xl md:text-4xl">${selectedVendorName}</h1>
                <p class="mt-3 text-sm leading-6 text-slate-600">Specific vendor profile with contact details and the products that belong to this vendor.</p>
                <div class="mt-4 flex flex-wrap gap-2">
                  <span class="inline-flex items-center rounded-full bg-white/90 px-4 py-1.5 text-xs font-semibold text-sky-700 ring-1 ring-sky-200">${selectedVendorStatus}</span>
                  <span class="inline-flex items-center rounded-full bg-white/90 px-4 py-1.5 text-xs font-semibold text-blue-700 ring-1 ring-blue-200">${selectedVendorBadge}</span>
                  <span class="inline-flex items-center rounded-full bg-white/90 px-4 py-1.5 text-xs font-semibold text-slate-700 ring-1 ring-slate-200">${strictDetailProducts.length} Products</span>
                  <span class="inline-flex items-center rounded-full bg-white/90 px-4 py-1.5 text-xs font-semibold text-sky-700 ring-1 ring-sky-200">Sold ${selectedVendorSold}</span>
                  <span class="inline-flex items-center rounded-full bg-white/90 px-4 py-1.5 text-xs font-semibold text-sky-700 ring-1 ring-sky-200">Orders ${selectedVendorOrders}</span>
                </div>
                <div class="mt-5 grid gap-3 sm:grid-cols-2">
                  <div class="rounded-[1rem] bg-[linear-gradient(180deg,#f8fcff_0%,#eef7ff_100%)] px-4 py-3 shadow-sm ring-1 ring-sky-100">
                    <div class="flex items-center justify-between gap-3">
                      <div>
                        <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-400">Total Sold</p>
                        <p class="mt-1 text-[28px] font-bold leading-none text-slate-900">${selectedVendorSold}</p>
                      </div>
                      <div class="flex h-11 w-11 items-center justify-center rounded-full bg-white text-sky-600 shadow-sm ring-1 ring-sky-100">
                        <i class="fas fa-box-open text-[15px]"></i>
                      </div>
                    </div>
                    <p class="mt-2 text-[11px] text-slate-500">Products sold by this vendor.</p>
                  </div>
                  <div class="rounded-[1rem] bg-[linear-gradient(180deg,#f8fcff_0%,#eef7ff_100%)] px-4 py-3 shadow-sm ring-1 ring-sky-100">
                    <div class="flex items-center justify-between gap-3">
                      <div>
                        <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-400">Total Orders</p>
                        <p class="mt-1 text-[28px] font-bold leading-none text-slate-900">${selectedVendorOrders}</p>
                      </div>
                      <div class="flex h-11 w-11 items-center justify-center rounded-full bg-white text-sky-600 shadow-sm ring-1 ring-sky-100">
                        <i class="fas fa-receipt text-[15px]"></i>
                      </div>
                    </div>
                    <p class="mt-2 text-[11px] text-slate-500">Completed orders linked to this vendor.</p>
                  </div>
                </div>
                <div class="mt-5 grid gap-3 sm:grid-cols-2">
                </div>
              </div>
            </div>
          </div>

          <div class="mt-8">
            <div class="mb-4 flex items-center justify-between gap-3">
              <div>
                <p class="text-xs font-bold uppercase tracking-[0.28em] text-sky-600">Vendor Products</p>
                <h2 class="mt-2 text-2xl font-bold text-slate-900">Products by ${selectedVendorName}</h2>
              </div>
              <a href="${backToList}" class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.2em] text-sky-700 transition hover:text-sky-900">
                <span>View All Vendors</span>
                <i class="fas fa-arrow-right text-[10px]"></i>
              </a>
            </div>

            ${strictDetailProducts.length ? `
              <div class="grid gap-5 sm:grid-cols-2 xl:grid-cols-4">
                ${productCards}
              </div>
            ` : `
              <div class="rounded-[1.25rem] border border-sky-100 bg-white px-6 py-10 text-center shadow-[0_12px_28px_rgba(148,163,184,0.08)]">
                <p class="text-lg font-semibold text-slate-900">No products found for this vendor</p>
              </div>
            `}
          </div>
        ` : `
          <div class="overflow-hidden rounded-[1.4rem] sm:rounded-[2rem] bg-[radial-gradient(circle_at_top_left,#dbeafe,transparent_28%),radial-gradient(circle_at_top_right,#e0f2fe,transparent_24%),linear-gradient(135deg,#f8fcff_0%,#ffffff_58%,#eef7ff_100%)] p-4 sm:p-6 shadow-[0_20px_70px_rgba(148,163,184,0.12)] ring-1 ring-sky-100 md:p-8">
            <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
              <div class="max-w-2xl">
                <p class="text-xs font-bold uppercase tracking-[0.28em] text-sky-600">Vendor Directory</p>
                <h1 class="mt-3 text-[28px] font-bold tracking-tight text-slate-900 sm:text-3xl md:text-4xl">All Vendors</h1>
                <p class="mt-3 max-w-xl text-sm leading-6 text-slate-600">Live vendor list pulled from the API. Click any vendor card to open the vendor profile and products.</p>
                <div class="mt-4 flex flex-wrap gap-2">
                  <span class="inline-flex items-center rounded-full bg-white/90 px-4 py-1.5 text-xs font-semibold text-sky-700 ring-1 ring-sky-200">Total: ${totalCount}</span>
                  <span class="inline-flex items-center rounded-full bg-white/90 px-4 py-1.5 text-xs font-semibold text-blue-700 ring-1 ring-blue-200">Active: ${activeVendorCount}</span>
                  <span class="inline-flex items-center rounded-full bg-white/90 px-4 py-1.5 text-xs font-semibold text-blue-700 ring-1 ring-blue-200">Page: ${currentPageNumber} of ${lastPageNumber}</span>
                </div>
              </div>
              <div class="w-full max-w-full sm:max-w-[320px]">
                <label for="vendorSearchInput" class="mb-2 block text-xs font-bold uppercase tracking-[0.18em] text-slate-500">Search Vendor</label>
                <div class="relative">
                  <i class="fas fa-search pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-[12px] text-slate-400"></i>
                  <input id="vendorSearchInput" type="search" placeholder="Search by name, email, or phone"
                    class="w-full rounded-2xl border border-sky-100 bg-white px-10 py-3 text-sm font-medium text-slate-700 shadow-sm outline-none transition placeholder:text-slate-400 focus:border-sky-400 focus:ring-2 focus:ring-sky-100">
                </div>
                <p class="mt-2 text-xs text-slate-500"><span id="vendorVisibleCount">${vendorList.length}</span> vendors visible</p>
              </div>
            </div>
          </div>

          ${errorText ? `
            <div class="mt-8 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-600">${errorText}</div>
          ` : ''}

          ${vendorList.length ? `
            <div id="vendorGrid" class="mt-8 grid justify-items-center gap-5 sm:grid-cols-2 xl:grid-cols-4">
              ${vendorCards}
            </div>
            <div id="vendorNoResults" class="mt-8 hidden rounded-[1.25rem] border border-sky-100 bg-white px-6 py-10 text-center shadow-[0_12px_28px_rgba(148,163,184,0.08)]">
              <p class="text-lg font-semibold text-slate-900">No vendors match your search</p>
              <p class="mt-2 text-sm text-slate-600">Try a different name or email.</p>
            </div>
            <div class="mt-8 flex flex-col gap-3 rounded-[1.25rem] bg-white/90 p-4 shadow-[0_12px_28px_rgba(148,163,184,0.10)] ring-1 ring-sky-100 sm:flex-row sm:items-center sm:justify-between">
              <p class="text-sm text-slate-600">Page ${currentPageNumber} of ${lastPageNumber}</p>
              <div class="flex items-center gap-2">
                <a href="${prevPageUrl || '#'}" class="inline-flex items-center justify-center rounded-[0.9rem] border border-sky-200 bg-sky-50 px-4 py-2 text-sm font-semibold text-sky-700 transition hover:bg-sky-100 ${prevPageUrl ? '' : 'pointer-events-none opacity-40'}">Previous</a>
                <a href="${nextPageUrl || '#'}" class="inline-flex items-center justify-center rounded-[0.9rem] bg-gradient-to-r from-sky-500 to-blue-500 px-4 py-2 text-sm font-semibold text-white transition hover:from-sky-600 hover:to-blue-600 ${nextPageUrl ? '' : 'pointer-events-none opacity-40'}">Next</a>
              </div>
            </div>
          ` : `
            <div class="mt-8 rounded-[1.25rem] border border-sky-100 bg-white px-6 py-10 text-center shadow-[0_12px_28px_rgba(148,163,184,0.08)]">
              <p class="text-lg font-semibold text-slate-900">No vendors found</p>
              <p class="mt-2 text-sm text-slate-600">The API returned an empty list for this page.</p>
            </div>
          `}
        `}
      </div>
    </section>
    <script>
      (function () {
        const input = document.getElementById('vendorSearchInput');
        const cards = Array.from(document.querySelectorAll('[data-vendor-card]'));
        const visibleCount = document.getElementById('vendorVisibleCount');
        const emptyState = document.getElementById('vendorNoResults');

        if (!input || !cards.length) return;

        function updateFilter() {
          const query = input.value.trim().toLowerCase();
          let count = 0;

          cards.forEach(function (card) {
            const haystack = String(card.getAttribute('data-search') || '');
            const isVisible = !query || haystack.indexOf(query) !== -1;
            card.classList.toggle('hidden', !isVisible);
            if (isVisible) count += 1;
          });

          if (visibleCount) {
            visibleCount.textContent = String(count);
          }

          if (emptyState) {
            emptyState.classList.toggle('hidden', count !== 0);
          }
        }

        input.addEventListener('input', updateFilter);
        updateFilter();
      })();
    </script>
  `
}) %>
