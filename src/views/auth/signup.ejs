<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up - Aerthh</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        .no-scrollbar,
        html,
        body {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }

        .no-scrollbar::-webkit-scrollbar,
        html::-webkit-scrollbar,
        body::-webkit-scrollbar {
            display: none;
        }

        .auth-background {
            background:
                radial-gradient(circle at top left, rgba(16, 185, 129, 0.18), transparent 35%),
                radial-gradient(circle at bottom right, rgba(20, 184, 166, 0.18), transparent 30%),
                linear-gradient(135deg, #f3fdf9 0%, #eef7f5 50%, #f7fbfa 100%);
        }

        .cube-field {
            position: absolute;
            inset: 0;
            overflow: hidden;
            pointer-events: none;
        }

        .cube {
            position: absolute;
            width: 70px;
            height: 70px;
            border: 1px solid rgba(16, 185, 129, 0.16);
            background: rgba(255, 255, 255, 0.18);
            transform: rotate(45deg);
            animation: floatCube 18s linear infinite;
            backdrop-filter: blur(2px);
        }

        .cube-sm {
            width: 42px;
            height: 42px;
            animation-duration: 14s;
        }

        .cube-lg {
            width: 96px;
            height: 96px;
            animation-duration: 22s;
        }

        @keyframes floatCube {
            0% {
                transform: translateY(40px) rotate(45deg);
                opacity: 0;
            }

            15% {
                opacity: 1;
            }

            85% {
                opacity: 0.55;
            }

            100% {
                transform: translateY(-110vh) rotate(405deg);
                opacity: 0;
            }
        }
    </style>
</head>

<body
    class="auth-background min-h-screen flex items-center justify-center px-6 py-4 sm:px-6 sm:py-4    md:px-6 md:py-4">
    <div class="cube-field">
        <span class="cube cube-sm left-[8%] top-[92%]" style="animation-delay: 0s;"></span>
        <span class="cube left-[18%] top-[100%]" style="animation-delay: 3s;"></span>
        <span class="cube cube-lg left-[34%] top-[95%]" style="animation-delay: 7s;"></span>
        <span class="cube cube-sm left-[52%] top-[102%]" style="animation-delay: 1.5s;"></span>
        <span class="cube left-[68%] top-[98%]" style="animation-delay: 9s;"></span>
        <span class="cube cube-lg left-[82%] top-[101%]" style="animation-delay: 5s;"></span>
        <span class="cube cube-sm left-[91%] top-[94%]" style="animation-delay: 11s;"></span>
    </div>

    <div
        class="relative z-10 max-w-[72rem] w-full bg-white/95 rounded-3xl shadow-2xl shadow-emerald-100/60 overflow-hidden flex flex-col md:flex-row border border-white/70">

        <!-- Left Side - Form -->
        <div class="md:w-1/2 p-4 sm:p-5 md:p-6 flex flex-col justify-center overflow-y-auto no-scrollbar">
            <!-- Logo -->
            <div class="mb-4">
                <img src="https://aerthh.com/storage/app/public/company/2025-03-26-67e3da8f9b411.webp" alt="Aerthh"
                    class="h-7 mb-2">
                <h1 class="text-xl md:text-2xl font-bold text-gray-800">Create Account</h1>
                <p class="text-sm text-gray-500 mt-1">Sign up to get started</p>
            </div>

            <!-- Form -->
            <form id="signupForm">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-2.5 mb-2.5">
                    <!-- First Name -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">First Name</label>
                        <input type="text" id="first_name" required
                            class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-lg focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 outline-none">
                    </div>

                    <!-- Last Name -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Last Name</label>
                        <input type="text" id="last_name" required
                            class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-lg focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 outline-none">
                    </div>

                    <!-- Email -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                        <input type="email" id="email" required
                            class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-lg focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 outline-none">
                    </div>

                    <!-- Phone -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
                        <input type="tel" id="phone" required
                            class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-lg focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 outline-none">
                    </div>

                    <!-- Password -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                        <div class="relative">
                            <input type="password" id="password" required
                                class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-lg focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 outline-none pr-9">
                            <button type="button" onclick="togglePassword('password', 'eyeIcon1')"
                                class="absolute right-2.5 top-1/2 -translate-y-1/2 text-gray-400 hover:text-emerald-600">
                                <i id="eyeIcon1" class="fas fa-eye text-sm"></i>
                            </button>
                        </div>
                    </div>

                    <!-- Confirm Password -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Confirm Password</label>
                        <div class="relative">
                            <input type="password" id="confirm_password" required
                                class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-lg focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 outline-none pr-9">
                            <button type="button" onclick="togglePassword('confirm_password', 'eyeIcon2')"
                                class="absolute right-2.5 top-1/2 -translate-y-1/2 text-gray-400 hover:text-emerald-600">
                                <i id="eyeIcon2" class="fas fa-eye text-sm"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Gender & DOB -->
                <div class="grid grid-cols-2 gap-2.5 mb-2.5">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Gender</label>
                        <select id="gender"
                            class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-lg focus:border-emerald-500 outline-none">
                            <option value="">Select</option>
                            <option value="male">Male</option>
                            <option value="female">Female</option>
                            <option value="other">Other</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Date of Birth</label>
                        <input type="date" id="dob"
                            class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-lg focus:border-emerald-500 outline-none">
                    </div>
                </div>

                <!-- Profile Image -->
                <div class="mb-2.5">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Profile Image</label>
                    <input type="file" id="profile_image" accept="image/*"
                        class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-lg focus:border-emerald-500 outline-none file:mr-3 file:border-0 file:bg-emerald-50 file:px-3 file:py-1 file:rounded file:text-emerald-700">
                    <p class="text-xs text-gray-500 mt-1">Optional image upload</p>
                </div>

                <!-- Terms -->
                <div class="mb-3 flex items-center gap-2">
                    <input type="checkbox" id="terms" required class="w-4 h-4">
                    <label class="text-xs text-gray-600">I agree to the <a href="#" class="text-emerald-600">Terms &
                            Conditions</a></label>
                </div>

                <!-- Submit Button -->
                <button type="submit" id="submitBtn"
                    class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-medium py-1.5 rounded-lg transition text-sm">
                    Sign Up
                </button>
            </form>

            <!-- Login Link -->
            <div class="mt-4 text-center text-sm">
                Already have an account?
                <a href="/auth/signin" class="text-emerald-600 font-semibold">Login</a>
            </div>
        </div>

        <!-- Right Side - Content -->
        <div
            class="md:w-1/2 bg-gradient-to-br from-emerald-600 to-teal-600 p-4 sm:p-5 md:p-6 text-white flex flex-col justify-center">
            <div>
                <div class="mb-5">
                    <i class="fas fa-leaf text-3xl mb-3"></i>
                    <h2 class="text-xl md:text-2xl font-bold mb-2">Welcome to Aerthh</h2>
                    <p class="text-emerald-100 text-sm">Join the sustainable shopping revolution</p>
                </div>

                <div class="space-y-3">
                    <div class="flex items-start gap-3">
                        <i class="fas fa-truck text-base mt-0.5"></i>
                        <div>
                            <h3 class="font-semibold">Free Shipping</h3>
                            <p class="text-sm text-emerald-100">On orders above ₹999</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-3">
                        <i class="fas fa-shield-alt text-base mt-0.5"></i>
                        <div>
                            <h3 class="font-semibold">Secure Payments</h3>
                            <p class="text-sm text-emerald-100">100% protected transactions</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-3">
                        <i class="fas fa-undo-alt text-base mt-0.5"></i>
                        <div>
                            <h3 class="font-semibold">Easy Returns</h3>
                            <p class="text-sm text-emerald-100">7-day return policy</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-3">
                        <i class="fas fa-gem text-base mt-0.5"></i>
                        <div>
                            <h3 class="font-semibold">Rewards Program</h3>
                            <p class="text-sm text-emerald-100">Eco-points on every purchase</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-5 pt-4 border-t border-emerald-500">
                <p class="text-sm text-emerald-100 text-center">
                    <i class="fas fa-users mr-1"></i> Join 10,000+ happy customers
                </p>
            </div>
        </div>
    </div>

    <script>
        const form = document.getElementById('signupForm');
        const submitBtn = document.getElementById('submitBtn');

        function formatDOB(dateStr) {
            if (!dateStr) return null;
            const d = new Date(dateStr);
            if (isNaN(d.getTime())) return null;
            return `${d.getUTCFullYear()}-${String(d.getUTCMonth() + 1).padStart(2, '0')}-${String(d.getUTCDate()).padStart(2, '0')}T00:00:00.000000Z`;
        }

        function showMessage(text, isError) {
            let msgDiv = document.getElementById('formMessage');
            if (!msgDiv) {
                msgDiv = document.createElement('div');
                msgDiv.id = 'formMessage';
                form.insertBefore(msgDiv, form.firstChild);
            }
            msgDiv.className = `mb-3 p-2 rounded text-sm ${isError ? 'bg-red-50 text-red-600' : 'bg-green-50 text-green-600'}`;
            msgDiv.innerHTML = text;
            setTimeout(() => msgDiv.remove(), 3000);
        }

        function togglePassword(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        }

        function fileToDataUrl(file) {
            return new Promise((resolve, reject) => {
                if (!file) return resolve('');
                const reader = new FileReader();
                reader.onload = () => resolve(typeof reader.result === 'string' ? reader.result : '');
                reader.onerror = () => reject(new Error('Unable to read selected image'));
                reader.readAsDataURL(file);
            });
        }

        function resolveProfileImage(data, fallbackImage) {
            const candidates = [
                data?.profile_image,
                data?.image,
                data?.avatar,
                data?.profile_image_url,
                data?.customer?.profile_image,
                data?.customer?.image,
                data?.customer?.avatar,
                data?.data?.profile_image,
                data?.data?.image,
                data?.data?.avatar
            ];

            return candidates.find((value) => typeof value === 'string' && value.trim()) || fallbackImage || '';
        }

        form.addEventListener('submit', async (e) => {
            e.preventDefault();

            const first_name = document.getElementById('first_name').value.trim();
            const last_name = document.getElementById('last_name').value.trim();
            const email = document.getElementById('email').value.trim();
            const phone = document.getElementById('phone').value.trim();
            const password = document.getElementById('password').value;
            const confirm_password = document.getElementById('confirm_password').value;
            const gender = document.getElementById('gender').value;
            const dob = formatDOB(document.getElementById('dob').value);
            const profileImage = document.getElementById('profile_image').files[0];
            const terms = document.getElementById('terms').checked;

            if (!first_name || !last_name || !email || !phone || !password || !confirm_password) {
                return showMessage('Please fill all required fields', true);
            }
            if (!email.match(/^\S+@\S+\.\S+$/)) {
                return showMessage('Please enter a valid email', true);
            }
            if (password.length < 8) {
                return showMessage('Password must be at least 8 characters', true);
            }
            if (password !== confirm_password) {
                return showMessage('Passwords do not match', true);
            }
            if (profileImage && !profileImage.type.startsWith('image/')) {
                return showMessage('Please upload a valid image file', true);
            }
            if (!terms) {
                return showMessage('Please accept Terms & Conditions', true);
            }

            const formData = new FormData();
            formData.append('first_name', first_name);
            formData.append('last_name', last_name);
            formData.append('email', email);
            formData.append('phone', phone);
            formData.append('terms_and_conditions', terms ? '1' : '0');
            formData.append('password', password);
            formData.append('password_confirmation', confirm_password);
            if (gender) formData.append('gender', gender);
            if (dob) formData.append('dob', dob);
            if (profileImage) {
                formData.append('profile_image', profileImage);
            }

            const originalText = submitBtn.innerHTML;
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Creating...';

            try {
                const response = await fetch('https://aerthh.newhopeindia17.com/api/customer/create', {
                    method: 'POST',
                    headers: {
                        'Accept': 'application/json'
                    },
                    body: formData
                });

                const data = await response.json();

                if (response.ok) {
                    const fallbackImage = await fileToDataUrl(profileImage);
                    const userPayload = {
                        ...data,
                        profile_image: resolveProfileImage(data, fallbackImage)
                    };
                    localStorage.setItem('userData', JSON.stringify(userPayload));
                    const name = data.first_name ? ` ${data.first_name}` : '';
                    showMessage(`🎉 Welcome${name}! Your account has been created successfully.`, false);
                    form.reset();
                    setTimeout(() => {
                        window.location.href = '/';
                    }, 1000);
                } else {
                    const errMsg = data.message || data.error || 'Unable to create account. Please try again.';
                    showMessage(errMsg, true);
                }
            } catch (error) {
                showMessage('Network error. Please check your connection and try again.', true);
                console.error('Signup error:', error);
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
            }
        });
    </script>
</body>

</html>
