<%
  const body = `
<style>
  .signin-shell {
    position: relative;
    min-height: calc(100vh - 240px);
    overflow: hidden;
  }

  .cube-background {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .cube {
    position: absolute;
    width: 12px;
    height: 12px;
    border: solid 1.2px rgba(6, 182, 212, 0.1);
    transform-origin: top left;
    transform: scale(0) rotate(0deg) translate(-50%, -50%);
    animation: cube-float 14s ease-in forwards infinite;
    background: rgba(6, 182, 212, 0.02);
    backdrop-filter: blur(1px);
  }

  .cube:nth-child(2n) {
    border-color: rgba(16, 185, 129, 0.1);
    background: rgba(16, 185, 129, 0.02);
  }

  .cube:nth-child(3n) {
    border-color: rgba(59, 130, 246, 0.1);
    background: rgba(59, 130, 246, 0.02);
  }

  @keyframes cube-float {
    0% { transform: scale(0) rotate(0deg) translate(-50%, -50%); opacity: 0; }
    10% { opacity: 0.5; }
    90% { opacity: 0.3; }
    100% { transform: scale(15) rotate(960deg) translate(-50%, -50%); opacity: 0; }
  }

  .cube1 { top: 15%; left: 10%; animation-delay: 0s; }
  .cube2 { top: 75%; left: 85%; animation-delay: 2s; }
  .cube3 { top: 35%; left: 92%; animation-delay: 3.5s; }
  .cube4 { top: 85%; left: 15%; animation-delay: 5.5s; }
  .cube5 { top: 45%; left: 45%; animation-delay: 1.2s; }
  .cube6 { top: 65%; left: 65%; animation-delay: 3s; }
  .cube7 { top: 92%; left: 35%; animation-delay: 4.2s; }
  .cube8 { top: 8%; left: 72%; animation-delay: 6s; }

  .captcha-container {
    background: linear-gradient(135deg, #ecfdf5 0%, #e0f2fe 100%);
    border: 1px solid #a5f3fc;
  }

  .captcha-text {
    font-family: 'Courier New', monospace;
    letter-spacing: 4px;
    text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.05);
    background: linear-gradient(135deg, #06b6d4 0%, #10b981 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .refresh-captcha:hover {
    transform: rotate(180deg);
  }

  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    10%, 30%, 50%, 70%, 90% { transform: translateX(-4px); }
    20%, 40%, 60%, 80% { transform: translateX(4px); }
  }

  .shake-animation {
    animation: shake 0.4s ease-in-out;
  }
</style>

<section class="signin-shell flex items-center justify-center p-3">
  <div class="cube-background">
    <div class="cube cube1"></div>
    <div class="cube cube2"></div>
    <div class="cube cube3"></div>
    <div class="cube cube4"></div>
    <div class="cube cube5"></div>
    <div class="cube cube6"></div>
    <div class="cube cube7"></div>
    <div class="cube cube8"></div>
  </div>

  <div class="relative z-10 min-h-[440px] w-full max-w-3xl overflow-hidden rounded-xl border border-white/40 bg-white/90 shadow-lg backdrop-blur-md md:flex">
    <div class="flex w-full flex-col justify-center bg-white/70 p-5 backdrop-blur-sm md:w-1/2 lg:p-6">
      <div class="mb-4">
        <h2 class="mb-0.5 text-xl font-bold text-gray-700 lg:text-2xl">Welcome Back! Customer</h2>
        <p class="text-xs text-gray-400">Sign in to your account</p>
      </div>

      <form id="loginForm" class="space-y-3">
        <input type="hidden" id="captchaVerified" value="0">

        <div class="space-y-0.5">
          <label for="email" class="block text-[11px] font-medium text-gray-500">
            <i class="far fa-envelope mr-1 text-cyan-400"></i> Email
          </label>
          <div class="relative">
            <i class="fas fa-envelope absolute left-2.5 top-1/2 -translate-y-1/2 text-xs text-cyan-400"></i>
            <input id="email" type="email" placeholder="john@example.com" required
              class="w-full rounded-lg border border-gray-100 bg-white/90 py-2 pl-8 pr-2.5 text-xs text-gray-600 transition-all duration-300 focus:border-cyan-300 focus:bg-white focus:outline-none focus:ring-1 focus:ring-cyan-100">
          </div>
        </div>

        <div class="space-y-0.5">
          <label for="password" class="block text-[11px] font-medium text-gray-500">
            <i class="far fa-lock mr-1 text-emerald-400"></i> Password
          </label>
          <div class="relative">
            <i class="fas fa-lock absolute left-2.5 top-1/2 -translate-y-1/2 text-xs text-emerald-400"></i>
            <input id="password" type="password" placeholder="........" required
              class="w-full rounded-lg border border-gray-100 bg-white/90 py-2 pl-8 pr-9 text-xs text-gray-600 transition-all duration-300 focus:border-emerald-300 focus:bg-white focus:outline-none focus:ring-1 focus:ring-emerald-100">
            <button id="togglePasswordBtn" type="button"
              class="absolute right-2.5 top-1/2 -translate-y-1/2 text-[11px] text-gray-300 transition hover:text-emerald-500">
              <i id="togglePasswordIcon" class="fas fa-eye"></i>
            </button>
          </div>
        </div>

        <div class="captcha-container space-y-0.5 rounded-lg p-2.5">
          <label class="block text-[11px] font-medium text-gray-500">
            <i class="fas fa-shield-alt mr-1 text-cyan-500"></i> Verify
          </label>

          <div class="flex items-center space-x-1.5">
            <div class="flex flex-shrink-0 items-center overflow-hidden rounded-lg border border-cyan-100 bg-white/80">
              <div class="bg-gradient-to-r from-cyan-50 to-emerald-50 px-2 py-1.5">
                <span id="captchaDisplay" class="captcha-text text-base font-bold">8A2F</span>
              </div>
              <button id="refreshCaptchaBtn" type="button"
                class="refresh-captcha border-l border-cyan-100 bg-white px-1.5 py-1.5 text-cyan-500 transition-all duration-300 hover:bg-cyan-50">
                <i class="fas fa-sync-alt text-[10px]"></i>
              </button>
            </div>

            <div class="relative flex-1">
              <i class="fas fa-pencil-alt absolute left-2 top-1/2 -translate-y-1/2 text-[10px] text-emerald-400"></i>
              <input id="captchaInput" type="text" placeholder="Code" required
                class="w-full rounded-lg border border-gray-100 bg-white/90 py-1.5 pl-7 pr-2 text-xs uppercase text-gray-600 transition-all duration-300 focus:border-emerald-300 focus:bg-white focus:outline-none focus:ring-1 focus:ring-emerald-100">
            </div>
          </div>

          <div id="captchaMessage" class="mt-0.5 hidden text-[10px]"></div>
        </div>

        <div class="mt-1 flex items-center justify-between">
          <label class="flex cursor-pointer items-center space-x-1.5">
            <input id="remember_me" type="checkbox" class="h-3 w-3 rounded border-gray-200 text-cyan-500 focus:ring-cyan-100">
            <span class="text-[10px] text-gray-500">
              <i class="far fa-check-square mr-0.5 text-[10px] text-cyan-400"></i> Remember me
            </span>
          </label>
          <a href="#" class="text-[10px] font-medium text-emerald-500 hover:text-emerald-600">
            <i class="far fa-question-circle mr-0.5"></i> Forgot Password?
          </a>
        </div>

        <button id="loginBtn" type="submit"
          class="w-full rounded-lg bg-gradient-to-r from-cyan-500 to-emerald-500 py-2 text-xs font-semibold text-white shadow-sm transition-all duration-300 hover:scale-[1.01] hover:from-cyan-600 hover:to-emerald-600">
          <i class="fas fa-sign-in-alt mr-1.5 text-xs"></i> Sign In
        </button>
      </form>

      <div id="signinMessage" class="mt-3 hidden rounded-lg px-3 py-2 text-xs"></div>
    </div>

    <div class="relative flex w-full items-center justify-center overflow-hidden bg-gradient-to-br from-cyan-50/80 via-white to-emerald-50/80 p-4 backdrop-blur-sm md:w-1/2">
      <div class="absolute right-3 top-3 h-12 w-12 rotate-12 animate-pulse border border-cyan-100/50"></div>
      <div class="absolute bottom-6 left-3 h-8 w-8 -rotate-12 animate-bounce border border-emerald-100/50" style="animation-duration: 3s;"></div>

      <div class="relative z-10 text-center">
        <div class="mb-3 flex justify-center">
          <div class="h-28 w-28 rounded-full p-1 shadow-lg">
            <div class="h-full w-full overflow-hidden rounded-full bg-white">
              <img src="https://aerthh.com/storage/app/public/company/2025-03-26-67e3da8f9b411.webp"
                alt="Aerthh Logo"
                class="h-full w-full object-cover"
                onerror="this.src='https://via.placeholder.com/150/06b6d4/ffffff?text=AERTH'">
            </div>
          </div>
        </div>

        <h1 class="mb-0.5 text-xl font-bold tracking-tight text-gray-600">
          <i class="fas fa-crown mr-1 text-sm text-yellow-200"></i>
          <span class="bg-gradient-to-r from-cyan-500 to-emerald-500 bg-clip-text text-transparent">AERTH</span>
        </h1>
        <p class="mx-auto max-w-xs text-[9px] text-gray-400">
          <i class="far fa-gem mr-0.5 text-[9px] text-cyan-400"></i>
          Averythink Technology
        </p>

        <div class="mt-2 flex justify-center space-x-1.5">
          <i class="fas fa-circle animate-pulse text-[4px] text-cyan-200"></i>
          <i class="fas fa-circle animate-pulse text-[4px] text-emerald-200 delay-150"></i>
          <i class="fas fa-circle animate-pulse text-[4px] text-teal-200 delay-300"></i>
        </div>

        <div class="mt-2 grid grid-cols-3 gap-1 text-[9px] text-gray-400">
          <div class="flex flex-col items-center">
            <i class="fas fa-truck mb-0.5 text-xs text-cyan-400"></i>
            <span class="text-gray-300">Free</span>
          </div>
          <div class="flex flex-col items-center">
            <i class="fas fa-shield-alt mb-0.5 text-xs text-emerald-400"></i>
            <span class="text-gray-300">Secure</span>
          </div>
          <div class="flex flex-col items-center">
            <i class="fas fa-undo-alt mb-0.5 text-xs text-teal-400"></i>
            <span class="text-gray-300">Returns</span>
          </div>
        </div>

        <div class="mt-2 flex justify-center space-x-3 text-[9px] text-gray-300">
          <i class="fab fa-cc-visa transition-colors hover:text-cyan-500"></i>
          <i class="fab fa-cc-mastercard transition-colors hover:text-emerald-500"></i>
          <i class="fab fa-cc-paypal transition-colors hover:text-cyan-500"></i>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    const form = document.getElementById('loginForm');
    const submitBtn = document.getElementById('loginBtn');
    const messageBox = document.getElementById('signinMessage');
    const passwordInput = document.getElementById('password');
    const toggleBtn = document.getElementById('togglePasswordBtn');
    const toggleIcon = document.getElementById('togglePasswordIcon');
    const captchaDisplay = document.getElementById('captchaDisplay');
    const captchaInput = document.getElementById('captchaInput');
    const captchaMessage = document.getElementById('captchaMessage');
    const captchaContainer = document.querySelector('.captcha-container');
    const captchaVerified = document.getElementById('captchaVerified');
    const refreshCaptchaBtn = document.getElementById('refreshCaptchaBtn');

    function showMessage(text, isError) {
      if (!messageBox) return;
      messageBox.textContent = text;
      messageBox.className = 'mt-3 rounded-lg px-3 py-2 text-xs ' + (isError
        ? 'border border-rose-200 bg-rose-50 text-rose-500'
        : 'border border-emerald-200 bg-emerald-50 text-emerald-600');
      messageBox.classList.remove('hidden');
    }

    function generateCaptcha() {
      const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ0123456789';
      let captcha = '';

      for (let i = 0; i < 4; i += 1) {
        captcha += chars[Math.floor(Math.random() * chars.length)];
      }

      captchaDisplay.textContent = captcha;
      captchaInput.value = '';
      captchaMessage.classList.add('hidden');
      captchaVerified.value = '0';
    }

    toggleBtn.addEventListener('click', function () {
      const isPassword = passwordInput.type === 'password';
      passwordInput.type = isPassword ? 'text' : 'password';
      toggleIcon.classList.toggle('fa-eye', !isPassword);
      toggleIcon.classList.toggle('fa-eye-slash', isPassword);
    });

    refreshCaptchaBtn.addEventListener('click', generateCaptcha);

    captchaInput.addEventListener('input', function () {
      this.value = this.value.toUpperCase();
    });

    form.addEventListener('submit', async function (event) {
      event.preventDefault();

      const email = document.getElementById('email').value.trim();
      const password = passwordInput.value;
      const enteredCaptcha = captchaInput.value.trim().toUpperCase();

      captchaContainer.classList.remove('shake-animation');

      if (!email || !password) {
        showMessage('Please enter email and password.', true);
        return;
      }

      if (enteredCaptcha !== captchaDisplay.textContent) {
        captchaContainer.classList.add('shake-animation');
        captchaMessage.className = 'mt-0.5 text-[10px] font-medium text-rose-500';
        captchaMessage.innerHTML = '<i class="fas fa-times-circle mr-0.5"></i> Invalid captcha!';
        captchaMessage.classList.remove('hidden');
        captchaVerified.value = '0';

        setTimeout(function () {
          captchaContainer.classList.remove('shake-animation');
        }, 400);

        generateCaptcha();
        return;
      }

      captchaMessage.className = 'mt-0.5 text-[10px] font-medium text-emerald-500';
      captchaMessage.innerHTML = '<i class="fas fa-check-circle mr-0.5"></i> Verified!';
      captchaMessage.classList.remove('hidden');
      captchaVerified.value = '1';

      const originalText = submitBtn.innerHTML;
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1.5 text-xs"></i> Signing In';

      try {
        const response = await fetch('https://aerthh.newhopeindia17.com/api/customer/login', {
          method: 'POST',
          headers: {
            'Accept': 'application/json',
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ email, password })
        });

        const data = await response.json();

        if (response.ok) {
          const customerData = data?.customer || {};
          localStorage.setItem('customerToken', data?.token || '');
          localStorage.setItem('tokenType', data?.token_type || 'Bearer');
          localStorage.setItem('customerData', JSON.stringify(customerData));
          localStorage.setItem('authData', JSON.stringify(data));
          localStorage.setItem('userData', JSON.stringify(customerData));
          showMessage(data?.message || 'Login successful. Redirecting...', false);
          setTimeout(function () {
            window.location.href = '/';
          }, 1200);
        } else {
          showMessage(data.message || data.error || 'Unable to sign in. Please try again.', true);
          generateCaptcha();
        }
      } catch (error) {
        console.error('Signin error:', error);
        showMessage('Network error. Please try again.', true);
        generateCaptcha();
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalText;
      }
    });

    generateCaptcha();
  })();
</script>
`; %>

<%- include('../layout/app', { title: title || 'Sign In', body }) %>
