<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up - Aerthh</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        .no-scrollbar,
        html,
        body {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }

        .no-scrollbar::-webkit-scrollbar,
        html::-webkit-scrollbar,
        body::-webkit-scrollbar {
            display: none;
        }

        .auth-background {
            background:
                radial-gradient(circle at top left, rgba(59, 130, 246, 0.18), transparent 35%),
                radial-gradient(circle at bottom right, rgba(14, 165, 233, 0.16), transparent 30%),
                linear-gradient(135deg, #f8fcff 0%, #eef7ff 50%, #f7fbff 100%);
        }

        .cube-field {
            position: absolute;
            inset: 0;
            overflow: hidden;
            pointer-events: none;
        }

        .cube {
            position: absolute;
            width: 70px;
            height: 70px;
            border: 1px solid rgba(59, 130, 246, 0.16);
            background: rgba(255, 255, 255, 0.18);
            transform: rotate(45deg);
            animation: floatCube 18s linear infinite;
            backdrop-filter: blur(2px);
        }

        .cube-sm {
            width: 42px;
            height: 42px;
            animation-duration: 14s;
        }

        .cube-lg {
            width: 96px;
            height: 96px;
            animation-duration: 22s;
        }

        @keyframes floatCube {
            0% {
                transform: translateY(40px) rotate(45deg);
                opacity: 0;
            }

            15% {
                opacity: 1;
            }

            85% {
                opacity: 0.55;
            }

            100% {
                transform: translateY(-110vh) rotate(405deg);
                opacity: 0;
            }
        }
    </style>
</head>

<body class="auth-background min-h-screen flex items-center justify-center px-6 py-4 sm:px-6 sm:py-4 md:px-6 md:py-4">
    <div class="cube-field">
        <span class="cube cube-sm left-[8%] top-[92%]" style="animation-delay: 0s;"></span>
        <span class="cube left-[18%] top-[100%]" style="animation-delay: 3s;"></span>
        <span class="cube cube-lg left-[34%] top-[95%]" style="animation-delay: 7s;"></span>
        <span class="cube cube-sm left-[52%] top-[102%]" style="animation-delay: 1.5s;"></span>
        <span class="cube left-[68%] top-[98%]" style="animation-delay: 9s;"></span>
        <span class="cube cube-lg left-[82%] top-[101%]" style="animation-delay: 5s;"></span>
        <span class="cube cube-sm left-[91%] top-[94%]" style="animation-delay: 11s;"></span>
    </div>

    <div class="relative z-10 flex w-full max-w-[72rem] flex-col overflow-hidden rounded-3xl border border-sky-100/80 bg-[linear-gradient(180deg,rgba(255,255,255,0.95)_0%,rgba(248,251,255,0.92)_100%)] shadow-2xl shadow-sky-100/60 md:flex-row">

        <div class="no-scrollbar flex flex-col justify-center overflow-y-auto p-4 sm:p-5 md:w-1/2 md:p-6">
            <div class="mb-4">
                <img src="https://aerthh.com/storage/app/public/company/2025-03-26-67e3da8f9b411.webp" alt="Aerthh"
                    class="mb-2 h-7">
                <p class="text-[11px] font-bold uppercase tracking-[0.24em] text-sky-600">Customer Access</p>
                <h1 class="text-xl font-bold text-slate-800 md:text-2xl">Create Account</h1>
                <p class="mt-1 text-sm text-slate-500">Sign up to get started</p>
            </div>

            <form id="signupForm">
                <div class="mb-2.5 grid grid-cols-1 gap-2.5 md:grid-cols-2">
                    <div>
                        <label class="mb-1 block text-sm font-medium text-slate-700">First Name</label>
                        <input type="text" id="first_name" required
                            class="w-full rounded-lg border border-sky-100 bg-white/90 px-3 py-1.5 text-sm text-slate-700 outline-none focus:border-sky-400 focus:ring-1 focus:ring-sky-100">
                    </div>

                    <div>
                        <label class="mb-1 block text-sm font-medium text-slate-700">Last Name</label>
                        <input type="text" id="last_name" required
                            class="w-full rounded-lg border border-sky-100 bg-white/90 px-3 py-1.5 text-sm text-slate-700 outline-none focus:border-sky-400 focus:ring-1 focus:ring-sky-100">
                    </div>

                    <div>
                        <label class="mb-1 block text-sm font-medium text-slate-700">Email</label>
                        <input type="email" id="email" required
                            class="w-full rounded-lg border border-sky-100 bg-white/90 px-3 py-1.5 text-sm text-slate-700 outline-none focus:border-sky-400 focus:ring-1 focus:ring-sky-100">
                    </div>

                    <div>
                        <label class="mb-1 block text-sm font-medium text-slate-700">Phone</label>
                        <input type="tel" id="phone" required
                            class="w-full rounded-lg border border-sky-100 bg-white/90 px-3 py-1.5 text-sm text-slate-700 outline-none focus:border-sky-400 focus:ring-1 focus:ring-sky-100">
                    </div>

                    <div>
                        <label class="mb-1 block text-sm font-medium text-slate-700">Password</label>
                        <div class="relative">
                            <input type="password" id="password" required
                                class="w-full rounded-lg border border-sky-100 bg-white/90 px-3 py-1.5 pr-9 text-sm text-slate-700 outline-none focus:border-sky-400 focus:ring-1 focus:ring-sky-100">
                            <button type="button" onclick="togglePassword('password', 'eyeIcon1')"
                                class="absolute right-2.5 top-1/2 -translate-y-1/2 text-slate-400 hover:text-sky-600">
                                <i id="eyeIcon1" class="fas fa-eye text-sm"></i>
                            </button>
                        </div>
                    </div>

                    <div>
                        <label class="mb-1 block text-sm font-medium text-slate-700">Confirm Password</label>
                        <div class="relative">
                            <input type="password" id="confirm_password" required
                                class="w-full rounded-lg border border-sky-100 bg-white/90 px-3 py-1.5 pr-9 text-sm text-slate-700 outline-none focus:border-sky-400 focus:ring-1 focus:ring-sky-100">
                            <button type="button" onclick="togglePassword('confirm_password', 'eyeIcon2')"
                                class="absolute right-2.5 top-1/2 -translate-y-1/2 text-slate-400 hover:text-sky-600">
                                <i id="eyeIcon2" class="fas fa-eye text-sm"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <div class="mb-2.5 grid grid-cols-2 gap-2.5">
                    <div>
                        <label class="mb-1 block text-sm font-medium text-slate-700">Gender</label>
                        <select id="gender"
                            class="w-full rounded-lg border border-sky-100 bg-white/90 px-3 py-1.5 text-sm text-slate-700 outline-none focus:border-sky-400">
                            <option value="">Select</option>
                            <option value="male">Male</option>
                            <option value="female">Female</option>
                            <option value="other">Other</option>
                        </select>
                    </div>
                    <div>
                        <label class="mb-1 block text-sm font-medium text-slate-700">Date of Birth</label>
                        <input type="date" id="dob"
                            class="w-full rounded-lg border border-sky-100 bg-white/90 px-3 py-1.5 text-sm text-slate-700 outline-none focus:border-sky-400">
                    </div>
                </div>

                <div class="mb-2.5">
                    <label class="mb-1 block text-sm font-medium text-slate-700">Profile Image</label>
                    <input type="file" id="profile_image" accept="image/*"
                        class="w-full rounded-lg border border-sky-100 bg-white/90 px-3 py-1.5 text-sm text-slate-700 outline-none focus:border-sky-400 file:mr-3 file:rounded file:border-0 file:bg-sky-50 file:px-3 file:py-1 file:text-sky-700">
                    <p class="mt-1 text-xs text-slate-500">Optional image upload</p>
                </div>

                <div class="mb-3 flex items-center gap-2">
                    <input type="checkbox" id="terms" required class="h-4 w-4 rounded border-sky-200 text-sky-500">
                    <label class="text-xs text-slate-600">I agree to the <a href="#" class="text-sky-600">Terms &
                            Conditions</a></label>
                </div>

                <button type="submit" id="submitBtn"
                    class="w-full rounded-lg bg-gradient-to-r from-sky-500 to-blue-500 py-1.5 text-sm font-medium text-white transition hover:from-sky-600 hover:to-blue-600">
                    Sign Up
                </button>
            </form>

            <div class="mt-4 text-center text-sm text-slate-600">
                Already have an account?
                <a href="/auth/customer/signin" class="font-semibold text-sky-600">Login</a>
            </div>
        </div>

        <div class="flex flex-col justify-center p-4 text-slate-700 sm:p-5 md:w-1/2 md:p-6 bg-[radial-gradient(circle_at_top,#ffffff,transparent_30%),linear-gradient(135deg,#eef7ff_0%,#dbeafe_52%,#bfdbfe_100%)]">
            <div>
                <div class="mb-5">
                    <i class="fas fa-gem mb-3 text-3xl text-sky-500"></i>
                    <h2 class="mb-2 text-xl font-bold md:text-2xl">Welcome to Aerthh</h2>
                    <p class="text-sm text-slate-500">Join the cleaner shopping experience built around trust and simplicity.</p>
                </div>

                <div class="space-y-3">
                    <div class="flex items-start gap-3">
                        <i class="fas fa-truck mt-0.5 text-base text-sky-500"></i>
                        <div>
                            <h3 class="font-semibold">Free Shipping</h3>
                            <p class="text-sm text-slate-500">On orders above Rs 999</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-3">
                        <i class="fas fa-shield-alt mt-0.5 text-base text-sky-500"></i>
                        <div>
                            <h3 class="font-semibold">Secure Payments</h3>
                            <p class="text-sm text-slate-500">100% protected transactions</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-3">
                        <i class="fas fa-undo-alt mt-0.5 text-base text-sky-500"></i>
                        <div>
                            <h3 class="font-semibold">Easy Returns</h3>
                            <p class="text-sm text-slate-500">7-day return policy</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-3">
                        <i class="fas fa-gem mt-0.5 text-base text-sky-500"></i>
                        <div>
                            <h3 class="font-semibold">Rewards Program</h3>
                            <p class="text-sm text-slate-500">Benefits on every purchase</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-5 border-t border-sky-200/80 pt-4">
                <p class="text-center text-sm text-slate-500">
                    <i class="fas fa-users mr-1"></i> Join 10,000+ happy customers
                </p>
            </div>
        </div>
    </div>

    <script>
        const form = document.getElementById('signupForm');
        const submitBtn = document.getElementById('submitBtn');

        function formatDOB(dateStr) {
            if (!dateStr) return null;
            const d = new Date(dateStr);
            if (isNaN(d.getTime())) return null;
            return `${d.getUTCFullYear()}-${String(d.getUTCMonth() + 1).padStart(2, '0')}-${String(d.getUTCDate()).padStart(2, '0')}T00:00:00.000000Z`;
        }

        function showMessage(text, isError) {
            let msgDiv = document.getElementById('formMessage');
            if (!msgDiv) {
                msgDiv = document.createElement('div');
                msgDiv.id = 'formMessage';
                form.insertBefore(msgDiv, form.firstChild);
            }
            msgDiv.className = `mb-3 rounded-lg border p-2 text-sm ${isError ? 'border-red-200 bg-red-50 text-red-600' : 'border-sky-200 bg-sky-50 text-sky-600'}`;
            msgDiv.innerHTML = text;
            setTimeout(() => msgDiv.remove(), 3000);
        }

        function togglePassword(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        }

        function fileToDataUrl(file) {
            return new Promise((resolve, reject) => {
                if (!file) return resolve('');
                const reader = new FileReader();
                reader.onload = () => resolve(typeof reader.result === 'string' ? reader.result : '');
                reader.onerror = () => reject(new Error('Unable to read selected image'));
                reader.readAsDataURL(file);
            });
        }

        function resolveProfileImage(data, fallbackImage) {
            const candidates = [
                data?.profile_image,
                data?.image,
                data?.avatar,
                data?.profile_image_url,
                data?.customer?.profile_image,
                data?.customer?.image,
                data?.customer?.avatar,
                data?.data?.profile_image,
                data?.data?.image,
                data?.data?.avatar
            ];

            return candidates.find((value) => typeof value === 'string' && value.trim()) || fallbackImage || '';
        }

        form.addEventListener('submit', async (e) => {
            e.preventDefault();

            const first_name = document.getElementById('first_name').value.trim();
            const last_name = document.getElementById('last_name').value.trim();
            const email = document.getElementById('email').value.trim();
            const phone = document.getElementById('phone').value.trim();
            const password = document.getElementById('password').value;
            const confirm_password = document.getElementById('confirm_password').value;
            const gender = document.getElementById('gender').value;
            const dob = formatDOB(document.getElementById('dob').value);
            const profileImage = document.getElementById('profile_image').files[0];
            const terms = document.getElementById('terms').checked;

            if (!first_name || !last_name || !email || !phone || !password || !confirm_password) {
                return showMessage('Please fill all required fields', true);
            }
            if (!email.match(/^\S+@\S+\.\S+$/)) {
                return showMessage('Please enter a valid email', true);
            }
            if (password.length < 8) {
                return showMessage('Password must be at least 8 characters', true);
            }
            if (password !== confirm_password) {
                return showMessage('Passwords do not match', true);
            }
            if (profileImage && !profileImage.type.startsWith('image/')) {
                return showMessage('Please upload a valid image file', true);
            }
            if (!terms) {
                return showMessage('Please accept Terms & Conditions', true);
            }

            const formData = new FormData();
            formData.append('first_name', first_name);
            formData.append('last_name', last_name);
            formData.append('email', email);
            formData.append('phone', phone);
            formData.append('terms_and_conditions', terms ? '1' : '0');
            formData.append('password', password);
            formData.append('password_confirmation', confirm_password);
            if (gender) formData.append('gender', gender);
            if (dob) formData.append('dob', dob);
            if (profileImage) {
                formData.append('profile_image', profileImage);
            }

            const originalText = submitBtn.innerHTML;
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Creating...';

            try {
                const response = await fetch('https://aerthh.newhopeindia17.com/api/customer/create', {
                    method: 'POST',
                    headers: {
                        'Accept': 'application/json'
                    },
                    body: formData
                });

                const data = await response.json();

                if (response.ok) {
                    const fallbackImage = await fileToDataUrl(profileImage);
                    const userPayload = {
                        ...data,
                        profile_image: resolveProfileImage(data, fallbackImage)
                    };
                    localStorage.setItem('userData', JSON.stringify(userPayload));
                    const name = data.first_name ? ` ${data.first_name}` : '';
                    showMessage(`Account created successfully${name}. Redirecting...`, false);
                    form.reset();
                    setTimeout(() => {
                        window.location.href = '/';
                    }, 1000);
                } else {
                    const errMsg = data.message || data.error || 'Unable to create account. Please try again.';
                    showMessage(errMsg, true);
                }
            } catch (error) {
                showMessage('Network error. Please check your connection and try again.', true);
                console.error('Signup error:', error);
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
            }
        });
    </script>
</body>

</html>
